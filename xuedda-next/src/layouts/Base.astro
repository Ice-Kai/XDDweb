---
import '../styles/global.css';
import { getSetting } from '../lib/settings';
import { getCategoryTree, MODEL_GROUPS, SECTIONS, type CatNode } from '../lib/content';

interface Props { title?: string; description?: string; }
const {
  title = '薛大大设计网 — 建筑·景观·室内设计资源平台',
  description = 'SketchUp 模型、D5/Enscape/Lumion 教程、材质贴图、软件参数一站获取，登录后每日可免费下载 30 个素材。',
} = Astro.props;

// 首页开场页默认关闭：游客可浏览全站，下载链接仍由接口要求登录。
const isHome = Astro.url.pathname === '/';
const introGateEnabled =
  String(process.env.INTRO_GATE_ENABLED || (import.meta.env?.INTRO_GATE_ENABLED as string) || '').toLowerCase() === 'true';
const showIntro = isHome && introGateEnabled;

// 并行运行期：旧站入口（在 .env 设 OLD_SITE_URL=https://old.xuedda.com 即显示「旧版」切换链接；未设则不显示）
const oldSiteUrl = process.env.OLD_SITE_URL || (import.meta.env?.OLD_SITE_URL as string) || '';

// 右上角铃铛消息面板（右侧滑出，三标签）。后续可由后台/DB 提供，现为占位。
const noticeTabs = [
  { key: 'version', name: '版本公告', items: [
    { title: '全新「控制台」上线，账单与数据一目了然', body: '原【消费记录】全面升级为【控制台】，账单与下载任务管理更清晰。', date: '2026-05-15' },
    { title: '新增 MAX 模型分区与「智能分类」', body: '模型栏目新增 MAX 分区，SU 模型按智能大类归整，查找更快。', date: '2026-05-13' },
    { title: '下载提速 & 网盘提取码自动填充', body: '详情页点击下载内联展开网盘链接，百度网盘自动带入提取码。', date: '2026-04-27' },
  ]},
  { key: 'official', name: '官方消息', items: [
    { title: '素材下载规则更新', body: '全站素材免费下载，登录账号后每天可下载 30 个素材。', date: '2026-06-28' },
    { title: '材质贴图库新增 HDR 专区', body: '新增大量 4K HDR 天空 / 夜空 / 室外环境贴图，持续更新。', date: '2026-05-20' },
  ]},
  { key: 'interactive', name: '互动消息', items: [
    { title: '你的反馈已回复', body: '关于「批量下载」的建议已收到，相关功能排期中，感谢支持。', date: '2026-05-18' },
  ]},
];

// 弹窗公告(图片大弹窗，首页，可关闭，本会话一次)。图片放 public/announce.jpg，改文案改这里。
const promo = {
  enabled: false,
  image: '/announce.jpg',          // 用户放真实图，缺省走渐变占位
  title: '网站公告',
  lines: ['静态展示版已上线', '资源下载功能整理中'],
  cta: '立刻查看',
  link: '/c/model',
};

// 后台可配置项：客服二维码、顶部公告。
// AI 生图独立部署：本地可指向 Next.js AI 站，生产可改成 ai.xuedda.com 或新域名。
interface Announce { enabled: boolean; text: string; link: string }
const [csQr, announce, modelTree, textureTree, softwareTree, videoTree] = await Promise.all([
  getSetting<string>('cs_qr', ''),
  getSetting<Announce>('announcement', { enabled: false, text: '', link: '' }),
  getCategoryTree(SECTIONS.model.id),
  getCategoryTree(SECTIONS.texture.id),
  getCategoryTree(SECTIONS.software.id),
  getCategoryTree(SECTIONS.video.id),
]);
const aiImageHref =
  process.env.AI_IMAGE_URL ||
  (import.meta.env?.AI_IMAGE_URL as string) ||
  '/ai-image';
const aiImageDisabled = true;

type P3Group = { name: string; href: string; children: Array<{ name: string; href: string }> };
type P3Item = { name: string; href: string; groups: P3Group[]; disabled?: boolean };

function flattenCats(nodes: CatNode[]) {
  const out: CatNode[] = [];
  const walk = (items: CatNode[]) => {
    for (const item of items) {
      out.push(item);
      walk(item.children || []);
    }
  };
  walk(nodes);
  return out;
}

function visibleCats(nodes: CatNode[]) {
  return nodes.filter((item) => item.isMenu !== false);
}

function modelGroupsForNav(tree: CatNode[]): P3Group[] {
  const all = flattenCats(tree);
  const byId = new Map(all.map((item) => [Number(item.id), item]));
  const groupedIds = new Set<number>();
  const groups: P3Group[] = MODEL_GROUPS.map((group) => {
    const children = group.ids
      .map((id) => byId.get(id))
      .filter((item): item is CatNode => Boolean(item && item.isMenu !== false))
      .map((item) => ({ name: item.name, href: `/c/model?category=${item.id}` }));
    children.forEach((item) => groupedIds.add(Number(item.href.split('=').pop() || 0)));
    return { name: group.name, href: `/c/model?group=${group.key}`, children };
  }).filter((group) => group.children.length);

  const ungrouped = visibleCats(tree)
    .filter((item) => !groupedIds.has(Number(item.id)))
    .map((item) => ({ name: item.name, href: `/c/model?category=${item.id}` }));
  if (ungrouped.length) groups.push({ name: '新增栏目', href: '/c/model', children: ungrouped.slice(0, 16) });
  return groups;
}

function sectionGroupsForNav(tree: CatNode[], slug: string): P3Group[] {
  return visibleCats(tree).slice(0, 10).map((item) => ({
    name: item.name,
    href: `/c/${slug}?category=${item.id}`,
    children: visibleCats(item.children || []).slice(0, 14).map((child) => ({
      name: child.name,
      href: `/c/${slug}?category=${child.id}`,
    })),
  }));
}

const p3NavItems: P3Item[] = [
  { name: 'AI生图', href: aiImageHref, groups: [], disabled: aiImageDisabled },
  { name: '模型素材', href: '/c/model', groups: modelGroupsForNav(modelTree) },
  { name: '灯光贴图', href: '/c/texture', groups: sectionGroupsForNav(textureTree, 'texture') },
  { name: '软件参数', href: '/c/software', groups: sectionGroupsForNav(softwareTree, 'software') },
  { name: '视频教程', href: '/c/video', groups: sectionGroupsForNav(videoTree, 'video') },
];

// 左侧导航：把现有功能重组为更像专业素材站的工作台入口。
const lnavGroups = [
  { label: '入口', items: [
    { name: '首页', desc: '推荐 / 最新', href: '/', icon: 'M3 12l9-9 9 9M5 10v10h14V10', badge: 'NEW' },
    { name: '发布需求', desc: '反馈与投稿', href: '/feedback', icon: 'M12 5v14M5 12h14' },
  ] },
  { label: '看点高级的', icon: 'M12 3l2.2 5.8L20 9l-4.5 3.8 1.5 5.9L12 15.4 7 18.7l1.5-5.9L4 9l5.8-.2L12 3z', items: [
    { name: '模型素材', desc: 'SU / MAX / 文案', href: '/c/model', icon: 'M21 16V8l-9-5-9 5v8l9 5 9-5zM3.3 7L12 12l8.7-5M12 22V12' },
    { name: '灯光和贴图', desc: 'HDRI / 材质 / 光影', href: '/c/texture', icon: 'M3 3h18v18H3zM3 9h18M9 21V9' },
    { name: '软件和参数', desc: '插件 / 预设 / 配置', href: '/c/software', icon: 'M12 2v4M12 18v4M4.9 4.9l2.8 2.8M16.3 16.3l2.8 2.8M2 12h4M18 12h4M4.9 19.1l2.8-2.8M16.3 7.7l2.8-2.8' },
  ] },
  { label: '拿点有用的', icon: 'M20 7h-4V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2H4v14h16V7zM8 7h8', items: [
    { name: 'AI 智能搜索', desc: '模型 / 贴图 / 教程', href: '/ask', icon: 'M11 4a7 7 0 1 0 0 14 7 7 0 0 0 0-14zM21 21l-4.3-4.3', ai: true },
    { name: 'AI 生图', desc: '暂未开放', href: aiImageHref, icon: 'M21 15l-5-5L5 21M3 3h18v18H3zM8.5 8.5h.01', ai: true, disabled: aiImageDisabled },
    { name: 'AI 问答', desc: '设计问题快速问', href: '/chat', icon: 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z', ai: true },
  ] },
  { label: '学点真干货', icon: 'M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5z', items: [
    { name: '视频教程', desc: '渲染 / 建模 / 实战', href: '/c/video', icon: 'M23 7l-7 5 7 5V7zM1 5h15v14H1z' },
    { name: '资源目录', desc: '按栏目浏览全站', href: '/c/model', icon: 'M3 6h18M3 12h18M3 18h18' },
  ] },
];
const curPath = Astro.url.pathname;
const isLnavActive = (href: string) => href === '/' ? curPath === '/' : curPath === href || curPath.startsWith(`${href}/`);

// 主导航（贴合真实一级分类）
const navItems = [
  { name: '首页', href: '/', active: true },
  { name: '模型', href: '/c/model' },
  { name: '灯光贴图', href: '/c/texture' },
  { name: '软件参数', href: '/c/software' },
  { name: '视频教程', href: '/c/video' },
  { name: '其他相关', href: '/c/other' },
  { name: 'AI生图', href: aiImageHref, disabled: aiImageDisabled },
];


// 左侧「今日上新」自动滚动列表（DB 就绪后改为查询最新 contents）
const newItems = [
  { t: 'SU-25 现代别墅建筑设计', m: '05-18 · SKP' },
  { t: 'D5 室内渲染全流程实战', m: '05-17 · 12课时' },
  { t: 'HDR 贴图 · 夜晚星空 6', m: '05-16 · HDR' },
  { t: 'SU-24 商业综合体外观', m: '05-15 · SKP' },
  { t: 'Enscape 4.0 版本发布', m: '05-14 · 渲染器' },
];

// 开场动画 词云（环绕太阳，设计领域词）。x/y 为相对词云容器的百分比定位。
const cloudWords = [
  { w: 'SketchUp', x: 16, y: 22, s: 20, b: 700, o: 0.9, d: 0 },
  { w: '模型', x: 50, y: 8, s: 22, b: 700, o: 0.95, d: 0.6 },
  { w: 'Lumion', x: 82, y: 20, s: 18, b: 600, o: 0.85, d: 1.1 },
  { w: 'Enscape', x: 30, y: 44, s: 16, b: 500, o: 0.8, d: 0.3 },
  { w: '渲染', x: 68, y: 42, s: 19, b: 700, o: 0.9, d: 0.9 },
  { w: 'V-Ray', x: 12, y: 58, s: 15, b: 500, o: 0.75, d: 1.4 },
  { w: 'HDR', x: 50, y: 50, s: 17, b: 600, o: 0.85, d: 0.2 },
  { w: '贴图', x: 88, y: 52, s: 18, b: 700, o: 0.9, d: 1.7 },
  { w: '效果图', x: 26, y: 76, s: 16, b: 600, o: 0.8, d: 0.5 },
  { w: 'D5', x: 60, y: 72, s: 15, b: 500, o: 0.75, d: 1.2 },
  { w: '室内', x: 78, y: 78, s: 17, b: 600, o: 0.85, d: 0.8 },
  { w: '建筑', x: 42, y: 90, s: 16, b: 600, o: 0.8, d: 1.5 },
  { w: 'Rhino', x: 6, y: 38, s: 13, b: 400, o: 0.65, d: 1.0 },
  { w: '景观', x: 94, y: 36, s: 14, b: 500, o: 0.7, d: 0.4 },
  { w: '材质', x: 64, y: 92, s: 14, b: 500, o: 0.7, d: 1.8 },
  { w: '参数', x: 16, y: 90, s: 13, b: 400, o: 0.65, d: 0.7 },
];
---
<!doctype html>
<html lang="zh-CN" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class={showIntro ? 'intro-locked' : ''}>
    <!-- 开场动画（仅首页） -->
    {showIntro && (
    <div class="intro" id="intro">
      <div class="intro-rail">
        <button type="button" class="intro-rail-btn primary" data-auth-open data-mode="login">立即登录</button>
        <button type="button" class="intro-rail-btn" data-auth-open data-mode="register">注册</button>
      </div>

      <div class="intro-slides" id="introSlides">
        <section class="intro-slide active" data-slide="0">
          <div class="intro-sun"></div>
          <span class="intro-spark" style="animation-delay:0s;left:49%"></span>
          <span class="intro-spark" style="animation-delay:.8s;left:51%"></span>
          <span class="intro-spark" style="animation-delay:1.6s;left:50%"></span>
          <span class="intro-spark" style="animation-delay:2.4s;left:48%"></span>
          <div class="intro-logo"><span class="logo-x">X</span><span class="logo-design">Design</span></div>
          <p class="intro-sub"><span>薛大大生态设计</span><i>XUEDDA DESIGN</i></p>
          <div class="intro-cloud">
            {cloudWords.map((c) => (
              <span class="intro-word" style={`left:${c.x}%;top:${c.y}%;font-size:${c.s}px;font-weight:${c.b};opacity:${c.o};animation-delay:${c.d}s`}>{c.w}</span>
            ))}
          </div>
          <div class="intro-device">
            <div class="intro-device-dot"></div>
            <span></span><span></span><span></span>
          </div>
        </section>

        <section class="intro-slide" data-slide="1">
          <div class="intro-copy">
            <p>INSPIRATION BOARD</p>
            <h2>专业设计师在<span>素材库</span>发现、收藏灵感</h2>
            <div class="intro-tabs"><b>每日新传</b><b>室内模型</b><b>灯光贴图</b></div>
          </div>
          <div class="intro-masonry">
            <figure class="im-card tall"><img src="/img/m1.jpg" alt="" /><figcaption>SU模型</figcaption></figure>
            <figure class="im-card"><img src="/img/t1.jpg" alt="" /><figcaption>灯光贴图</figcaption></figure>
            <figure class="im-card mid"><img src="/img/c1.jpg" alt="" /><figcaption>教程</figcaption></figure>
            <figure class="im-card tall"><img src="/img/m3.jpg" alt="" /><figcaption>室内</figcaption></figure>
            <figure class="im-card"><img src="/hero/hero-2.jpg" alt="" /><figcaption>项目</figcaption></figure>
            <figure class="im-card mid"><img src="/img/t3.jpg" alt="" /><figcaption>HDR</figcaption></figure>
            <figure class="im-card"><img src="/img/m5.jpg" alt="" /><figcaption>MAX</figcaption></figure>
            <figure class="im-card tall"><img src="/hero/hero-1.jpg" alt="" /><figcaption>景观</figcaption></figure>
          </div>
        </section>

        <section class="intro-slide" data-slide="2">
          <div class="intro-copy">
            <p>XDESIGN WORKSPACE</p>
            <h2>收藏、检索、下载，把素材整理成自己的工作流</h2>
          </div>
          <div class="intro-feature-grid">
            <article><strong>01</strong><h3>分类找模型</h3><p>建筑、室内、景观、灯光贴图和教程统一入口。</p></article>
            <article><strong>02</strong><h3>AI 搜索</h3><p>用自然语言直接描述你需要的资源。</p></article>
            <article><strong>03</strong><h3>下载记录</h3><p>登录后保留最近打开的网盘资源。</p></article>
          </div>
        </section>
      </div>

      <div class="intro-dots" id="introDots" aria-label="开场翻页">
        <button class="active" type="button" data-slide="0"></button>
        <button type="button" data-slide="1"></button>
        <button type="button" data-slide="2"></button>
      </div>

      <div class="intro-brand"><b>xDesign</b><span>灵感之源，设计之始</span></div>

      <div class="intro-auth" id="introAuth" hidden>
        <button class="ia-close" id="introAuthClose" type="button" aria-label="关闭登录注册">×</button>
        <div class="ia-tabs">
          <button type="button" class="ia-tab active" data-mode="register">注册</button>
          <button type="button" class="ia-tab" data-mode="login">登录</button>
        </div>
        <form class="ia-form" id="introAuthForm">
          <input class="ia-input" name="username" autocomplete="username" placeholder="用户名 / 手机号" required />
          <input class="ia-input" name="password" type="password" autocomplete="current-password" placeholder="密码" required />
          <input class="ia-input ia-confirm" name="confirm" type="password" placeholder="确认密码" />
          <div class="ia-captcha">
            <input type="hidden" name="captchaToken" id="iaCaptchaToken" />
            <input class="ia-input" name="captchaAnswer" id="iaCaptchaAnswer" inputmode="numeric" autocomplete="off" placeholder="输入验证码" required />
            <button class="ia-captcha-code" id="iaCaptchaRefresh" type="button" aria-label="刷新验证码">加载中</button>
          </div>
          <p class="ia-err" id="iaErr"></p>
          <button type="submit" class="ia-submit" id="iaSubmit">注册并进入 →</button>
        </form>
        <div class="ia-oauth">
          <span>第三方登录</span>
          <div>
            <a href="/api/member/oauth/qq/start" class="ia-oauth-btn qq">QQ 登录</a>
            <a href="/api/member/oauth/wechat/start" class="ia-oauth-btn wechat">微信登录</a>
          </div>
        </div>
        <p class="ia-note">注册即同意《用户协议》与《隐私政策》 · <a href="/member/forgot">忘记密码？</a></p>
      </div>
    </div>
    )}

    <!-- 公告：小按钮 + 弹出卡片（进站默认弹一次） -->
    {announce.enabled && announce.text && (
      <div class="announce-wrap" id="announceWrap" data-key={announce.text.slice(0, 60)}>
        <button class="announce-btn" id="announceBtn" aria-label="网站公告">
          <span class="announce-bell">📢</span><span class="announce-btn-label">公告</span>
          <span class="announce-dot"></span>
        </button>
        <div class="announce-pop" id="announcePop">
          <div class="announce-pop-head"><span>📢 网站公告</span><button id="announceClose" aria-label="关闭">✕</button></div>
          <div class="announce-pop-body">
            <p>{announce.text}</p>
            {announce.link && <a href={announce.link} class="announce-pop-link" target="_blank" rel="noopener">查看详情 →</a>}
          </div>
        </div>
      </div>
    )}

    <!-- 弹窗公告（首页） -->
    {showIntro && promo.enabled && (
    <div class="promo-mask" id="promoMask" hidden>
      <div class="promo-card">
        <button class="promo-close" id="promoClose" type="button" aria-label="关闭">✕</button>
        <div class="promo-media" style={`background-image:url('${promo.image}')`}>
          <div class="promo-overlay">
            <h3 class="promo-title">{promo.title}</h3>
            <div class="promo-foot">
              <div class="promo-lines">{promo.lines.map((l) => <p>{l}</p>)}</div>
              <a class="promo-cta" href={promo.link}>{promo.cta}</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    )}

    <!-- NAV -->
    <nav class="nav">
      <div class="container nav-inner">
        <a href="/" class="nav-logo"><span class="nav-logo-dot"></span><span class="nav-logo-text"><b>XDesign</b><span class="nav-logo-cn">薛大大生态设计</span></span></a>
        <ul class="nav-main" id="navMain">
          {navItems.map((n) => <li><a href={n.disabled ? '#' : n.href} class={`${n.active ? 'active' : ''} ${n.disabled ? 'is-disabled' : ''}`} aria-disabled={n.disabled ? 'true' : undefined} data-disabled={n.disabled ? 'true' : undefined} target={n.external && !n.disabled ? '_blank' : undefined} rel={n.external && !n.disabled ? 'noopener' : undefined}>{n.name}</a></li>)}
        </ul>
        <form class="nav-search" action="/ask" method="get">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          <input name="q" placeholder="搜索模型 / 贴图 / 软件 / 教程…" aria-label="搜索" />
        </form>
        <div class="nav-actions">
          <button class="nav-burger" id="navBurger" type="button" aria-label="导航菜单">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>          <div class="nav-cats p3-nav" aria-label="资源栏目">
            {p3NavItems.map((item, index) => (
              <>
                <div class={`p3-item ${item.groups.length ? 'has-menu' : ''} ${item.disabled ? 'is-disabled' : ''}`}>
                  <a class={`p3-link ${item.disabled ? 'is-disabled' : ''}`} href={item.disabled ? '#' : item.href} aria-disabled={item.disabled ? 'true' : undefined} data-disabled={item.disabled ? 'true' : undefined} aria-haspopup={item.groups.length ? 'true' : undefined}>
                    {item.name}
                    {item.groups.length ? <span class="p3-arrow" aria-hidden="true"></span> : null}
                  </a>
                  {item.groups.length ? (
                    <div class="p3-menu" role="menu">
