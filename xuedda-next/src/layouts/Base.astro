    <script is:inline>
      document.addEventListener('click', (event) => {
        const disabledLink = event.target.closest('[data-disabled="true"]');
        if (disabledLink) event.preventDefault();
      });

      // 卡片下载：当前页小弹窗展示网盘链接，不跳详情页
      (function () {
        return;
        let pop;
        const esc = (s) => String(s || '').replace(/[&<>"']/g, (c) => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c]));
        const providerName = (url) => {
          if (/pan\.baidu\.com/i.test(url)) return '百度网盘';
          if (/aliyundrive|alipan/i.test(url)) return '阿里云盘';
          if (/quark\.cn/i.test(url)) return '夸克网盘';
          if (/123pan/i.test(url)) return '123网盘';
          return '网盘链接';
        };
        const ensurePop = () => {
          if (pop) return pop;
          pop = document.createElement('div');
          pop.className = 'download-pop';
          pop.hidden = true;
          document.body.appendChild(pop);
          return pop;
        };
        const close = () => { if (pop) pop.hidden = true; };
        const place = (btn) => {
          const p = ensurePop();
          const r = btn.getBoundingClientRect();
          const w = 300;
          p.style.left = Math.max(12, Math.min(window.innerWidth - w - 12, r.right - w)) + 'px';
          p.style.top = Math.min(window.innerHeight - 180, r.bottom + 8) + 'px';
        };
        const setPop = (p, title, message, links) => {
          p.replaceChildren();
          const x = document.createElement('button');
          x.type = 'button';
          x.className = 'download-pop-x';
          x.setAttribute('aria-label', '关闭');
          x.textContent = '×';
          x.addEventListener('click', close);
          p.appendChild(x);
          const t = document.createElement('div');
          t.className = 'download-pop-title';
          t.textContent = title;
          p.appendChild(t);
          if (message) {
            const m = document.createElement('div');
            m.className = 'download-pop-muted';
            m.textContent = message;
            p.appendChild(m);
          }
          for (const item of links || []) {
            const a = document.createElement('a');
            a.className = 'download-pop-link';
            a.href = item.href;
            a.textContent = item.text;
            if (/^https:\/\//i.test(item.href)) {
              a.target = '_blank';
              a.rel = 'noopener';
            }
            p.appendChild(a);
            if (item.pass) {
              const pass = document.createElement('div');
              pass.className = 'download-pop-muted';
              pass.append('提取码：');
              const b = document.createElement('b');
              b.textContent = item.pass;
              pass.appendChild(b);
              p.appendChild(pass);
            }
          }
        };
        document.addEventListener('click', async (e) => {
          const btn = e.target.closest('[data-dl]');
          if (!btn) { if (pop && !e.target.closest('.download-pop')) close(); return; }
          e.preventDefault();
          e.stopPropagation();
          const p = ensurePop();
          place(btn);
          p.hidden = false;
          const link = btn.closest('a[href^="/d/"]');
          const m = link && link.getAttribute('href').match(/\/d\/(\d+)/);
          if (!m) return;
          setPop(p, '正在获取下载链接...', '请稍等');
          try {
            const res = await fetch('/api/download/' + m[1], { credentials: 'include' });
            const data = await res.json();
            if (res.status === 401) {
              setPop(p, '请先登录或注册', '游客可以浏览素材，查看网盘链接需要账号。', [
                { text: '去登录', href: '/member/login' },
                { text: '注册账号', href: '/member/register' },
              ]);
            } else if (res.status === 429) {
              setPop(p, '今日下载已达上限', data.message || '每个账号每天最多下载 30 个素材，明天再来。');
            } else if (res.status === 403) {
              setPop(p, '暂时无法下载', data.message || '当前账号暂无下载权限。');
            } else if (!res.ok || !data.ok) {
              setPop(p, '暂时无法下载', data.message || '下载链接暂未配置');
            } else {
              const links = (data.files || []).map((f) => ({
                text: f.provider || providerName(f.url),
                href: f.url,
                pass: f.pass || '',
              }));
              setPop(p, data.item?.title || '资源下载', '', links);
            }
          } catch {
            setPop(p, '网络错误', '请刷新后重试。');
          }
        }, true);
        window.addEventListener('scroll', close, { passive: true });
        window.addEventListener('resize', close);
      })();
    </script>

    <script is:inline>
      // 开场页 · 注册/登录门槛
      (function () {
        const intro = document.getElementById('intro');
        if (!intro) return;
        const params = new URLSearchParams(window.location.search);
        const forceIntro = params.has('logout') || params.has('intro');
        if (forceIntro) {
          localStorage.removeItem('xdd-entered');
          sessionStorage.removeItem('xdd-promo');
        }
        const enter = () => {
          intro.classList.add('hide');
          document.body.classList.remove('intro-locked');
          setTimeout(() => intro.remove(), 1100);
        };

        let mode = 'register';
        const form = document.getElementById('introAuthForm');
        const confirm = intro.querySelector('.ia-confirm');
        const submit = document.getElementById('iaSubmit');
        const err = document.getElementById('iaErr');
        const auth = document.getElementById('introAuth');
        const captchaToken = document.getElementById('iaCaptchaToken');
        const captchaAnswer = document.getElementById('iaCaptchaAnswer');
        const captchaRefresh = document.getElementById('iaCaptchaRefresh');
        const slides = Array.from(intro.querySelectorAll('.intro-slide'));
        const dots = Array.from(intro.querySelectorAll('#introDots button'));
        let slide = 0;
        let captchaLoading = false;
        const loadCaptcha = async () => {
          if (!captchaToken || !captchaAnswer || !captchaRefresh || captchaLoading) return;
          captchaLoading = true;
          captchaRefresh.textContent = '刷新中';
          captchaAnswer.value = '';
          try {
            const res = await fetch('/api/member/captcha', { credentials: 'include' });
            const data = await res.json();
            if (!res.ok || !data.ok) throw new Error();
            captchaToken.value = data.token || '';
            captchaRefresh.textContent = data.question || '点击刷新';
          } catch {
            captchaToken.value = '';
            captchaRefresh.textContent = '刷新验证码';
          } finally {
            captchaLoading = false;
          }
        };
        const setSlide = (next) => {
          slide = (Number(next) + slides.length) % slides.length;
          slides.forEach((item, index) => item.classList.toggle('active', index === slide));
          dots.forEach((item, index) => item.classList.toggle('active', index === slide));
        };
        const setMode = (nextMode) => {
          mode = nextMode === 'login' ? 'login' : 'register';
          intro.querySelectorAll('.ia-tab').forEach((x) => x.classList.toggle('active', x.dataset.mode === mode));
          confirm.style.display = mode === 'register' ? 'block' : 'none';
          submit.textContent = mode === 'register' ? '注册并进入 →' : '登录并进入 →';
          err.textContent = '';
          loadCaptcha();
        };
        dots.forEach((dot) => dot.addEventListener('click', () => setSlide(dot.dataset.slide || 0)));
        intro.querySelectorAll('[data-auth-open]').forEach((button) => {
          button.addEventListener('click', () => {
            setMode(button.dataset.mode || 'login');
            auth.hidden = false;
            loadCaptcha();
          });
        });
        captchaRefresh?.addEventListener('click', loadCaptcha);
        document.getElementById('introAuthClose')?.addEventListener('click', () => {
          auth.hidden = true;
        });
        const oauthError = params.get('oauth');
        if (oauthError) {
          setMode('login');
          auth.hidden = false;
          err.textContent = oauthError.includes('missing')
            ? '第三方登录还没有配置 AppId / Secret'
            : '第三方登录失败，请重试或使用账号密码登录';
        }
        fetch('/api/member/me', { credentials: 'include', cache: 'no-store' })
          .then((r) => r.json())
          .then((d) => { if (d.member && !forceIntro) enter(); })
          .catch(() => {});
        intro.querySelectorAll('.ia-tab').forEach((t) => {
          t.addEventListener('click', () => {
            setMode(t.dataset.mode);
          });
        });
        setMode('register');
        form?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const f = new FormData(form);
          const u = (f.get('username') || '').toString().trim();
          const p = (f.get('password') || '').toString();
          const c = (f.get('confirm') || '').toString();
          const captcha = (f.get('captchaAnswer') || '').toString().trim();
          if (!u || !p) { err.textContent = '请输入用户名和密码'; return; }
          if (mode === 'register' && p !== c) { err.textContent = '两次密码不一致'; return; }
          if (!captcha) { err.textContent = '请输入验证码'; return; }
          try {
            const res = await fetch(mode === 'register' ? '/api/member/register' : '/api/member/login', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify({
                username: u,
                password: p,
                captchaToken: (f.get('captchaToken') || '').toString(),
                captchaAnswer: captcha,
              }),
            });
            const data = await res.json();
            if (!res.ok || !data.ok) {
              err.textContent = data.message || '提交失败';
              if (data.captcha) loadCaptcha();
              return;
            }
            enter();
          } catch {
            err.textContent = '网络错误，请稍后重试';
          }
        });
      })();

      // 图片弹窗公告（开场页消失后再弹，可关闭，本会话一次）
      (function () {
        const mask = document.getElementById('promoMask');
        if (!mask) return;
        if (sessionStorage.getItem('xdd-promo') === '1') return;
        const waitIntro = () => {
          if (document.getElementById('intro')) { setTimeout(waitIntro, 400); return; }
          setTimeout(() => { mask.hidden = false; }, 400);
        };
        waitIntro();
        const close = () => { mask.hidden = true; sessionStorage.setItem('xdd-promo', '1'); };
        document.getElementById('promoClose')?.addEventListener('click', close);
        mask.addEventListener('click', (e) => { if (e.target === mask) close(); });
      })();

      // 客服浮窗：默认右侧居中，可拖动并记住位置
      (function () {
        const wrap = document.querySelector('.cs-float');
        const btn = document.getElementById('csBtn');
        const panel = document.getElementById('csPanel');
        if (!wrap || !btn) return;

        const key = 'xdd-cs-pos';
        const margin = 10;
        const topSafe = 70;
        let dragging = false;
        let moved = false;
        let suppressClick = false;
        let startX = 0;
        let startY = 0;
        let baseX = 0;
        let baseY = 0;

        const clamp = (value, min, max) => Math.min(Math.max(value, min), Math.max(min, max));
        const maxX = () => window.innerWidth - wrap.offsetWidth - margin;
        const maxY = () => window.innerHeight - wrap.offsetHeight - margin;
        const applyPos = (x, y) => {
          wrap.style.left = `${clamp(x, margin, maxX())}px`;
          wrap.style.top = `${clamp(y, topSafe, maxY())}px`;
          wrap.style.right = 'auto';
          wrap.style.bottom = 'auto';
          wrap.style.transform = 'none';
        };
        const defaultPos = () => ({
          x: window.innerWidth - wrap.offsetWidth - 22,
          y: Math.round(window.innerHeight / 2 - wrap.offsetHeight / 2),
        });
        const savePos = () => {
          const r = wrap.getBoundingClientRect();
          localStorage.setItem(key, JSON.stringify({ x: Math.round(r.left), y: Math.round(r.top) }));
        };
        const restorePos = () => {
          let pos = null;
          try { pos = JSON.parse(localStorage.getItem(key) || 'null'); } catch {}
          if (!pos || typeof pos.x !== 'number' || typeof pos.y !== 'number') pos = defaultPos();
          applyPos(pos.x, pos.y);
        };

        requestAnimationFrame(restorePos);
        window.addEventListener('resize', () => {
          const r = wrap.getBoundingClientRect();
          applyPos(r.left, r.top);
          savePos();
        });

        btn.addEventListener('pointerdown', (e) => {
          if (e.button !== undefined && e.button !== 0) return;
          dragging = true;
          moved = false;
          startX = e.clientX;
          startY = e.clientY;
          const r = wrap.getBoundingClientRect();
          baseX = r.left;
          baseY = r.top;
          wrap.classList.add('dragging');
          btn.setPointerCapture?.(e.pointerId);
        });
        btn.addEventListener('pointermove', (e) => {
          if (!dragging) return;
          const dx = e.clientX - startX;
          const dy = e.clientY - startY;
          if (Math.abs(dx) + Math.abs(dy) > 5) moved = true;
          applyPos(baseX + dx, baseY + dy);
        });
        const endDrag = () => {
          if (!dragging) return;
          dragging = false;
          wrap.classList.remove('dragging');
          if (moved) {
            suppressClick = true;
            panel?.classList.remove('open');
            savePos();
          }
        };
        btn.addEventListener('pointerup', endDrag);
        btn.addEventListener('pointercancel', endDrag);
        btn.addEventListener('click', (e) => {
          if (suppressClick) {
            suppressClick = false;
            e.preventDefault();
            e.stopPropagation();
            return;
          }
          panel?.classList.toggle('open');
        });
      })();

      // 「公告」按钮 → 打开右侧消息抽屉（与铃铛一致），旧小弹卡停用
      document.getElementById('announceBtn')?.addEventListener('click', (e) => {
        e.stopPropagation();
        const drawer = document.getElementById('noticeDrawer');
        const mask = document.getElementById('noticeMask');
        if (drawer) { drawer.classList.add('open'); if (mask) mask.hidden = false; drawer.setAttribute('aria-hidden', 'false'); }
      });

      // 底部网站公告：进入网站后从浏览器底边浮起，可收起成小入口
      (function () {
        const root = document.getElementById('siteNotice');
        if (!root) return;
        const closeBtn = document.getElementById('siteNoticeClose');
        const openBtn = document.getElementById('siteNoticeOpen');
        const key = 'xdd-site-notice-collapsed';
        const open = () => {
          root.classList.add('open');
          root.classList.remove('collapsed');
          root.setAttribute('aria-expanded', 'true');
          sessionStorage.removeItem(key);
        };
        const collapse = () => {
          root.classList.remove('open');
          root.classList.add('collapsed');
          root.setAttribute('aria-expanded', 'false');
          sessionStorage.setItem(key, '1');
        };
        if (sessionStorage.getItem(key) === '1') {
          root.classList.add('collapsed');
          root.setAttribute('aria-expanded', 'false');
        } else {
          const waitIntro = () => {
            if (document.getElementById('intro')) { setTimeout(waitIntro, 350); return; }
            setTimeout(open, 420);
          };
          waitIntro();
        }
        closeBtn?.addEventListener('click', collapse);
        openBtn?.addEventListener('click', open);
      })();

      // 移动端汉堡菜单
      document.getElementById('navBurger')?.addEventListener('click', () => {
        document.getElementById('navMain')?.classList.toggle('open');
      });

      // 左侧导航 收起/展开（记忆状态）
      (function () {
        const saved = localStorage.getItem('xdd-lnav');
        if (saved === 'collapsed' || (!saved && window.matchMedia('(max-width: 900px)').matches)) {
          document.body.classList.add('lnav-collapsed');
        }
        const set = (c) => {
          document.body.classList.toggle('lnav-collapsed', c);
          localStorage.setItem('xdd-lnav', c ? 'collapsed' : 'open');
        };
        document.getElementById('lnavCollapse')?.addEventListener('click', () => set(true));
        document.getElementById('lnavReopen')?.addEventListener('click', () => set(false));
      })();

      // 会员登录状态
      (function () {
        const guests = document.querySelectorAll('.guest-only');
        const members = document.querySelectorAll('.member-only');
        const path = window.location.pathname;
        const authPage = path.startsWith('/member/login') || path.startsWith('/member/register');
        const adminPage = path.startsWith('/admin');
        fetch('/api/member/me', { credentials: 'include', cache: 'no-store' })
          .then((r) => r.json())
          .then((d) => {
            const logged = !!d.member;
            guests.forEach((el) => el.hidden = logged);
            members.forEach((el) => el.hidden = !logged);
            // Guests may browse the site. Download APIs still require a member account.
          })
          .catch(() => {});
        document.getElementById('memberLogout')?.addEventListener('click', async (event) => {
          event.preventDefault();
          const logout = event.currentTarget;
          logout.setAttribute('aria-disabled', 'true');
          logout.textContent = '退出中...';
          try {
            await fetch('/api/member/logout', { method: 'POST', credentials: 'include', cache: 'no-store' });
          } catch {}
          guests.forEach((el) => el.hidden = false);
          members.forEach((el) => el.hidden = true);
          localStorage.removeItem('xdd-entered');
          sessionStorage.removeItem('xdd-promo');
          window.location.replace('/');
        });
      })();

      // 右侧消息抽屉（铃铛）
      (function () {
        const bell = document.getElementById('noticeBell');
        const drawer = document.getElementById('noticeDrawer');
        const mask = document.getElementById('noticeMask');
        if (!bell || !drawer || !mask) return;
        const open = () => { drawer.classList.add('open'); mask.hidden = false; drawer.setAttribute('aria-hidden', 'false'); bell.querySelector('.notice-bell-dot')?.classList.add('hide'); };
        const close = () => { drawer.classList.remove('open'); mask.hidden = true; drawer.setAttribute('aria-hidden', 'true'); };
        bell.addEventListener('click', () => drawer.classList.contains('open') ? close() : open());
        document.getElementById('noticeClose')?.addEventListener('click', close);
        mask.addEventListener('click', close);
        drawer.querySelectorAll('.notice-tab').forEach((tab) => {
          tab.addEventListener('click', () => {
            const k = tab.dataset.tab;
            drawer.querySelectorAll('.notice-tab').forEach((x) => x.classList.toggle('active', x === tab));
            drawer.querySelectorAll('.notice-pane').forEach((p) => p.classList.toggle('active', p.dataset.pane === k));
          });
        });
      })();
      // 字号调节（阅读模式）：缩放 main 内容，记忆到 localStorage
      (function () {
        const main = document.querySelector('main');
        const apply = (v) => { if (main) main.style.zoom = (v / 100).toString(); const fv = document.getElementById('fontVal'); if (fv) fv.textContent = v + '%'; const fr = document.getElementById('fontRange'); if (fr) fr.value = v; };
        apply(parseInt(localStorage.getItem('xdd-fontsize') || '100', 10));
        const btn = document.getElementById('fontBtn'), pop = document.getElementById('fontPop'), range = document.getElementById('fontRange');
        btn?.addEventListener('click', (e) => { e.stopPropagation(); pop.classList.toggle('open'); });
        document.addEventListener('click', (e) => { if (pop && !pop.contains(e.target) && e.target !== btn && !btn.contains(e.target)) pop.classList.remove('open'); });
        range?.addEventListener('input', () => { apply(+range.value); localStorage.setItem('xdd-fontsize', range.value); });
        document.getElementById('fontReset')?.addEventListener('click', () => { apply(100); localStorage.setItem('xdd-fontsize', '100'); });
      })();

      // 下载弹窗：拦截卡片「下载」按钮，弹出网盘链接（不跳详情页）
      (function () {
        const modal = document.getElementById('dlModal'), body = document.getElementById('dlBody');
        if (!modal || !body) return;
        const close = () => { modal.hidden = true; };
        document.getElementById('dlClose')?.addEventListener('click', close);
        document.getElementById('dlMask')?.addEventListener('click', close);
        function providerName(url) {
          if (/pan\.baidu\.com/i.test(url)) return '百度网盘';
          if (/aliyundrive|alipan/i.test(url)) return '阿里云盘';
          if (/quark\.cn/i.test(url)) return '夸克网盘';
          if (/123pan/i.test(url)) return '123 网盘';
          return '网盘链接';
        }
        function openState(title, message, action) {
          body.replaceChildren();
          const t = document.createElement('div');
          t.className = 'dlm-title';
          t.textContent = title || '资源下载';
          const sub = document.createElement('div');
          sub.className = 'dlm-sub';
          sub.textContent = '下载链接不会在页面源码里暴露，登录后由接口临时读取。';
          const s = document.createElement('div');
          s.className = 'dlm-state';
          const ico = document.createElement('div');
          ico.className = 'ico';
          ico.textContent = 'i';
          s.appendChild(ico);
          s.append(message || '');
          if (action) {
            const a = document.createElement('a');
            a.className = 'btn';
            a.href = action.href;
            a.textContent = action.text;
            s.appendChild(a);
          }
          body.append(t, sub, s);
          modal.hidden = false;
        }
        function openLoading(title) {
          body.replaceChildren();
          const t = document.createElement('div');
          t.className = 'dlm-title';
          t.textContent = title || '正在获取下载链接';
          const sub = document.createElement('div');
          sub.className = 'dlm-sub';
          sub.textContent = '正在读取网盘地址，请稍等。';
          const s = document.createElement('div');
          s.className = 'dlm-state';
          s.appendChild(Object.assign(document.createElement('div'), { className:'dlm-spin' }));
          body.append(t, sub, s);
          modal.hidden = false;
        }
        function openLinks(title, files) {
          body.replaceChildren();
          const t = document.createElement('div');
          t.className = 'dlm-title';
          t.textContent = title || '资源下载';
          const sub = document.createElement('div');
          sub.className = 'dlm-sub';
          sub.textContent = '如果网盘链接失效，请把下方链接地址和提取码一起反馈给管理员。';
          body.append(t, sub);
          const copyText = async (button, value) => {
            await navigator.clipboard?.writeText(value || '');
            button.textContent = '已复制';
            setTimeout(() => { button.textContent = '复制'; }, 1200);
          };
          for (const file of files || []) {
            const row = document.createElement('div');
            row.className = 'dlm-row';
            const k = document.createElement('span');
            k.className = 'k';
            k.textContent = '链接地址';
            const link = document.createElement('div');
            link.className = 'dlm-link';
            const code = document.createElement('code');
            code.className = 'dlm-value';
            code.textContent = file.url;
            const copyUrl = document.createElement('button');
            copyUrl.type = 'button';
            copyUrl.className = 'dlm-copy';
            copyUrl.textContent = '复制';
            copyUrl.addEventListener('click', () => copyText(copyUrl, file.url));
            const open = document.createElement('a');
            open.className = 'dlm-open';
            open.href = file.url;
            open.target = '_blank';
            open.rel = 'noopener';
            open.textContent = '打开';
            link.append(code, copyUrl, open);
            row.append(k, link);
            body.appendChild(row);
            if (file.pass) {
              const passRow = document.createElement('div');
              passRow.className = 'dlm-row';
              const passK = document.createElement('span');
              passK.className = 'k';
              passK.textContent = '提取码';
              const code = document.createElement('code');
              code.className = 'dlm-value dlm-pass';
              code.textContent = file.pass;
              const copy = document.createElement('button');
              copy.type = 'button';
              copy.className = 'dlm-copy';
              copy.textContent = '复制';
              copy.addEventListener('click', () => copyText(copy, file.pass));
              passRow.append(passK, code, copy);
              body.appendChild(passRow);
            }
          }
          modal.hidden = false;
        }
        async function doDownload(id, title) {
          openLoading(title);
          try {
            const res = await fetch('/api/download/' + encodeURIComponent(id), { credentials:'include' });
            const data = await res.json().catch(() => ({}));
            if (res.status === 401) return openState('请先登录或注册', '游客可以浏览素材，查看网盘链接需要账号。', { text:'去登录', href:'/member/login' });
            if (res.status === 429) return openState('今日下载已达上限', data.message || '每个账号每天最多下载 30 个素材，明天再来。');
            if (res.status === 403) return openState('暂时无法下载', data.message || '当前账号暂无下载权限。');
            if (!res.ok || !data.ok) return openState('暂时无法下载', data.message || '下载链接暂未配置');
            openLinks(data.item?.title || title || '资源下载', data.files || []);
          } catch {
            openState('网络错误', '请刷新后重试。');
          }
        }
        // 委托：资源卡片和「下载」按钮都不进入详情页，直接弹出下载链接
        document.addEventListener('click', (e) => {
          const trigger = e.target.closest('.btn-dl, a[data-card-id], a[href^="/d/"]');
          if (!trigger) return;
          const card = trigger.closest('[data-card-id], a[href^="/d/"]');
          const href = trigger.matches?.('a[href^="/d/"]') ? trigger.getAttribute('href') : (card?.getAttribute?.('href') || '');
          const m = href.match(/\/d\/(\d+)/);
          const id = trigger.dataset?.downloadId || card?.dataset?.cardId || m?.[1];
          if (!id) return;
          e.preventDefault(); e.stopPropagation();
          const title = card?.querySelector?.('.card-title,.rank-title')?.textContent || trigger.dataset?.title || trigger.textContent || '';
          doDownload(id, title);
        }, true);
        const initialDownload = new URLSearchParams(window.location.search).get('download');
        if (initialDownload) {
          setTimeout(() => doDownload(initialDownload, '资源下载'), 120);
        }
      })();

      // 主题切换（默认深色，记忆到 localStorage）
      const root = document.documentElement;
      root.setAttribute('data-theme', localStorage.getItem('xdd-theme') || 'dark');
      document.getElementById('themeToggle')?.addEventListener('click', () => {
        const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        root.setAttribute('data-theme', next);
        localStorage.setItem('xdd-theme', next);
      });

      // 左侧侧栏 收起/展开
      const panel = document.getElementById('sidebarPanel');
      document.getElementById('sidebarToggle')?.addEventListener('click', () => panel?.classList.toggle('open'));

      // Hero 轮播
      const slides = document.querySelectorAll('.hero-slide');
      const dots = document.querySelectorAll('.hero-dot');
      if (slides.length > 1) {
        let cur = 0, tmr;
        const goTo = (n) => {
          slides[cur].classList.remove('active'); dots[cur]?.classList.remove('active');
          cur = (n + slides.length) % slides.length;
          slides[cur].classList.add('active'); dots[cur]?.classList.add('active');
        };
        const start = () => { clearInterval(tmr); tmr = setInterval(() => goTo(cur + 1), 5000); };
        dots.forEach((d, i) => d.addEventListener('click', () => { goTo(i); start(); }));
        start();
      }

      // 滚动揭示 + 导航阴影
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          const p = e.target.closest('.grid-5,.grid-4,.grid-sw,.grid-3');
          const delay = p ? Array.from(p.children).indexOf(e.target) * 60 : 0;
          setTimeout(() => e.target.classList.add('visible'), delay);
          io.unobserve(e.target);
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -28px 0px' });
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      const nav = document.querySelector('.nav');
      window.addEventListener('scroll', () => {
        if (nav) nav.style.boxShadow = window.scrollY > 50 ? '0 2px 18px rgba(0,0,0,.1)' : '';
      }, { passive: true });
    </script>
  </body>
</html>
