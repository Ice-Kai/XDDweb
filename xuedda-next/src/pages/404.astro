---
import Base from '../layouts/Base.astro';
---
<Base title="页面走丢了 - 薛大大设计网">
  <section class="section">
    <div class="container" style="max-width:640px;text-align:center;padding:72px 20px;">
      <p class="section-label">404</p>
      <h1 style="font-size:clamp(28px,6vw,44px);margin:8px 0 12px;">页面走丢了</h1>
      <p style="color:var(--text-lo);margin-bottom:28px;">你访问的地址不存在或已被移动。可以从下面的入口重新开始。</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href="/" class="btn-primary">返回首页</a>
        <a href="/c/model" class="btn-secondary">浏览素材</a>
      </div>
    </div>
  </section>
</Base>
