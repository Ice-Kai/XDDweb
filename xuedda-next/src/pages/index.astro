---
import Base from '../layouts/Base.astro';
import { getLatestDownloads, coverUrl, TOP_CATEGORY, type DownloadItem } from '../lib/content';
import { getSetting, DEFAULT_HERO, type HeroData } from '../lib/settings';

// 首页 Hero：后台可自定义（settings.home_hero），未设置则用默认
const hero = (await getSetting<HeroData>('home_hero', DEFAULT_HERO)) || DEFAULT_HERO;
const heroSlides = hero.slides?.length ? hero.slides : DEFAULT_HERO.slides;

// 静态发布版：首页各版块从本地内容数组读取。
const [models, courses, materials, software, bilibiliUrl] = await Promise.all([
  getLatestDownloads({ rootCategoryId: TOP_CATEGORY.model, limit: 5 }),
  getLatestDownloads({ rootCategoryId: TOP_CATEGORY.video, limit: 5 }),
  getLatestDownloads({ rootCategoryId: TOP_CATEGORY.texture, limit: 5 }),
  getLatestDownloads({ rootCategoryId: TOP_CATEGORY.software, limit: 5 }),
  getSetting<string>('bilibili_url', ''),
]);

const aiImageHref =
  process.env.AI_IMAGE_URL ||
  (import.meta.env?.AI_IMAGE_URL as string) ||
  '/ai-image';
const aiImageDisabled = true;
const bilibiliProfileUrl = 'https://space.bilibili.com/218538613?spm_id_from=333.337.search-card.all.click';
const mobileCategoryCards = [
  {
    title: '模型素材',
    desc: '建筑 · 室内 · 景观',
    href: '/c/model',
    tone: 'cool',
    cover: coverUrl(models[0]?.cover || ''),
    icon: 'M12 2 3 7v10l9 5 9-5V7z|M3 7l9 5 9-5M12 12v10',
  },
  {
    title: '平面素材',
    desc: '贴图 · PSD · 文案',
    href: '/c/texture',
    tone: 'warm',
    cover: coverUrl(materials[0]?.cover || ''),
    icon: 'rect|circle|image',
  },
  {
    title: '视频教程',
    desc: 'D5 · SU 系统课',
    href: '/c/video',
    tone: 'cool',
    cover: coverUrl(courses[0]?.cover || ''),
    icon: 'video',
  },
  {
    title: '软件资源',
    desc: '安装包 · 参数',
    href: '/c/software',
    tone: 'warm',
    cover: coverUrl(software[0]?.cover || ''),
    icon: 'grid',
  },
];

const quickEntries = [
  { name: 'AI 功能', label: 'AI', desc: '生图入口暂未开放，后续独立接入。', href: aiImageHref, action: '暂未开放', disabled: aiImageDisabled },
  { name: '公众号 / B站链接', label: 'MEDIA', desc: '打开 B站视频主页；公众号二维码暂未放置。', href: bilibiliUrl || bilibiliProfileUrl, action: '打开 B站' },
  { name: '素材下载', label: 'DL', desc: '进入模型、平面素材、软件参数素材库。', href: '/c/model', action: '浏览素材' },
  { name: '功能反馈', label: 'FB', desc: '提交问题、失效链接和功能建议。', href: '/feedback', action: '提交反馈' },
];

function priceLabel(_it: DownloadItem) {
  // 全站资源统一标记为免费
  return '免费';
}
function sizeLabel(it: DownloadItem) {
  const raw = String(it.size || '').trim();
  if (!raw) return '— MB';
  if (/gb/i.test(raw)) return raw.replace(/gb/i, 'GB');
  if (/mb/i.test(raw)) return raw.replace(/mb/i, 'MB');
  if (/kb/i.test(raw)) return raw.replace(/kb/i, 'KB');
  const n = Number(raw.replace(/[^0-9.]/g, ''));
  if (!Number.isFinite(n) || n <= 0) return raw;
  if (n > 1024 * 1024) return (n / 1024 / 1024).toFixed(1) + 'MB';
  return n + 'MB';
}
const arrow = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';
---
<Base>
  <!-- 手机首页（仅手机端显示，桌面 display:none；还原 design 稿） -->
  <section class="m-home" aria-label="手机首页">
    <header class="mh-greet">
      <div class="mh-hello">
        <strong>你好，设计师</strong>
        <span>今天想找哪类素材？</span>
      </div>
      <button class="mh-bell" type="button" data-notice-open aria-label="公告">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 8a6 6 0 1 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
        <i class="mh-dot"></i>
      </button>
    </header>
    <form class="mh-search" action="/search" method="get">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      <input name="q" placeholder="搜索模型 / 贴图 / 教程" />
    </form>

    <h2 class="mh-h">浏览分类</h2>
    <div class="mh-cats">
      {mobileCategoryCards.map((card) => (
        <a class={`mh-cat ${card.tone}`} href={card.href} target={card.external ? '_blank' : undefined} rel={card.external ? 'noopener' : undefined}>
          {card.cover ? <img class="mh-cat-img" src={card.cover} alt={card.title} loading="lazy" /> : null}
          <span class="mh-cat-ovl"></span>
          <span class="mh-cat-ico">
            {card.icon === 'rect|circle|image' ? (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.8"/><path d="m21 16-5-5L5 21"/></svg>
            ) : card.icon === 'video' ? (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="4" width="20" height="16" rx="3"/><path d="M10 9l5 3-5 3z" fill="currentColor"/></svg>
            ) : card.icon === 'grid' ? (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
            ) : (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2 3 7v10l9 5 9-5V7z"/><path d="M3 7l9 5 9-5M12 12v10"/></svg>
            )}
          </span>
          <span class="mh-cat-t"><strong>{card.title}</strong><em>{card.desc}</em></span>
        </a>
      ))}
    </div>

    <h2 class="mh-h">快速入口</h2>
    <div class="mh-quick scroll">
      <a class="mh-q" href="/c/model">
        <span class="mh-q-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M12 3v12m0 0 4-4m-4 4-4-4"/><path d="M5 19h14"/></svg></span>
        <span class="mh-q-name">素材下载</span>
      </a>
      <a class="mh-q is-off" href="#" aria-disabled="true" data-disabled="true">
        <span class="mh-q-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 3l1.7 4.1L18 9l-4.3 1.9L12 15l-1.7-4.1L6 9l4.3-1.9z"/><path d="M19 14l.8 1.9 2 .8-2 .8L19 20l-.8-1.7-2-.8 2-.8z"/></svg></span>
        <span class="mh-q-name">AI 生图</span>
      </a>
      <a class="mh-q" href={bilibiliUrl || bilibiliProfileUrl} target="_blank" rel="noopener">
        <span class="mh-q-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M10 9l5 3-5 3z" fill="currentColor" stroke="none"/></svg></span>
        <span class="mh-q-name">视频教程</span>
      </a>
      <a class="mh-q" href={bilibiliUrl || bilibiliProfileUrl} target="_blank" rel="noopener">
        <span class="mh-q-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="7" width="18" height="13" rx="2.5"/><path d="M8 7 5 3M16 7l3-4"/></svg></span>
        <span class="mh-q-name">B站视频</span>
      </a>
      <button class="mh-q mh-desktop-q" type="button" data-exit-mobile>
        <span class="mh-q-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="13" rx="2"/><path d="M8 21h8M12 17v4"/></svg></span>
        <span class="mh-q-name">恢复电脑</span>
      </button>
      <a class="mh-q" href="/feedback">
        <span class="mh-q-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15a2 2 0 0 1-2 2H8l-4 4V5a2 2 0 0 1 2-2h13a2 2 0 0 1 2 2z"/></svg></span>
        <span class="mh-q-name">功能反馈</span>
      </a>
    </div>

    <h2 class="mh-h">最新素材</h2>
    <div class="m-card-grid mh-latest">
      {models.slice(0, 4).map((m) => (
        <a href={`/d/${m.id}`} class="m-asset-card">
          <span class="m-cover">
            {coverUrl(m.cover) ? <img src={coverUrl(m.cover)} alt={m.title} loading="lazy" /> : <i>MODEL</i>}
            <b>{priceLabel(m)}</b>
          </span>
          <strong>{m.title}</strong>
          <span class="m-asset-meta">{m.size || '-- MB'} · {m.fileType || 'SKP 模型'}</span>
        </a>
      ))}
    </div>
  </section>

  <script>
    document.querySelectorAll('.mh-quick').forEach((rail) => {
      rail.addEventListener('wheel', (event) => {
        if (Math.abs(event.deltaY) <= Math.abs(event.deltaX)) return;
        event.preventDefault();
        rail.scrollLeft += event.deltaY;
      }, { passive: false });
    });
  </script>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-slides">
      {heroSlides.map((src, i) => (
        <div class={`hero-slide ${i === 0 ? 'active' : ''}`} style={`background-image:url('${src}')`}></div>
      ))}
    </div>
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <p class="hero-tag">{hero.tag}</p>
      <h1 class="hero-title">{hero.titleL1}<br>{hero.titleL2}</h1>
      <p class="hero-sub">{hero.sub}</p>
      <div class="hero-cta">
        <a href={hero.btn1.href} class="btn-primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
          {hero.btn1.text}
        </a>
        <a href={hero.btn2.href} class="btn-secondary">{hero.btn2.text} <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      </div>
    </div>
    <div class="hero-dots">{heroSlides.map((_, i) => <div class={`hero-dot ${i === 0 ? 'active' : ''}`}></div>)}</div>
  </section>

  <!-- 快速入口（置于最新上传之上） -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <div><p class="section-label">QUICK ACCESS</p><h2 class="section-title">快速入口</h2><p class="section-desc">把常用功能集中到这里，少一点栏目，多一点直接可用。</p></div>
      </div>
      <div class="quick-entry-grid reveal">
        {quickEntries.map((entry) => (
          <a href={entry.disabled ? '#' : entry.href} class={`quick-entry-card ${entry.disabled ? 'disabled' : ''}`} aria-disabled={entry.disabled ? 'true' : undefined} data-disabled={entry.disabled ? 'true' : undefined} target={!entry.disabled && entry.href.startsWith('http') ? '_blank' : undefined} rel={!entry.disabled && entry.href.startsWith('http') ? 'noopener' : undefined}>
            <span class="quick-entry-mark">{entry.label}</span>
            <span class="quick-entry-copy">
              <strong>{entry.name}</strong>
              <em>{entry.desc}</em>
            </span>
            <span class="quick-entry-action">{entry.action} <Fragment set:html={arrow} /></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SU模型精选（最新上传） -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <div><p class="section-label">SU MODEL</p><h2 class="section-title">每日最近上传</h2><p class="section-desc">每次新上传的 SU 模型自动置顶展示，建筑、工装、家装、园林持续更新。</p></div>
        <a href="/c/model" class="section-more">查看全部 <Fragment set:html={arrow} /></a>
      </div>
      <div class="grid-5">
        {models.map((m) => (
          <article data-card-id={m.id} class="card reveal">
            <button class="card-img-wrap" type="button" data-preview-src={coverUrl(m.cover)} data-preview-title={m.title} aria-label={`预览 ${m.title}`}>
              {coverUrl(m.cover) ? <img src={coverUrl(m.cover)} alt={m.title} loading="lazy" /> : null}
              <span class="card-cat cat-arch">{priceLabel(m)}</span>
            </button>
            <div class="card-body">
              <h3 class="card-title">{m.title}</h3>
              <p class="card-desc">{m.summary || '暂无简介'}</p>
              <div class="card-footer download-footer">
                <span class="card-size">{m.size || '-- MB'}</span>
                <span class="card-foot-r"><span class="card-type">{m.fileType || 'SKP 模型'}</span><span class="btn-dl" data-dl data-download-id={m.id} role="button" tabindex="0">下载</span></span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 薛大大教学（视频教程 最新） -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <div><p class="section-label">COURSE</p><h2 class="section-title">薛大大教学</h2><p class="section-desc">D5、Layout、SU 等系统教程，最新更新。</p></div>
        <a href="/c/video" class="section-more">查看全部 <Fragment set:html={arrow} /></a>
      </div>
      <div class="grid-5">
        {courses.map((c) => (
          <article data-card-id={c.id} class="card course-card reveal">
            <button class="card-img-wrap" type="button" data-preview-src={coverUrl(c.cover)} data-preview-title={c.title} aria-label={`预览 ${c.title}`}>
              {coverUrl(c.cover) ? <img src={coverUrl(c.cover)} alt={c.title} loading="lazy" /> : null}
              <span class="card-cat cat-d5">{priceLabel(c)}</span>
              <div class="course-play"><div class="play-btn"><svg width="15" height="15" viewBox="0 0 24 24" fill="#0d0900"><polygon points="5 3 19 12 5 21 5 3"/></svg></div></div>
            </button>
            <div class="card-body">
              <h3 class="card-title">{c.title}</h3>
              <div class="course-lessons">⏱ {c.created_at}</div>
              <div class="card-footer" style="margin-top:11px;"><span style="font-size:11px;color:var(--text-lo)">👁 {c.hits} 观看</span><span class="btn-watch">观看</span></div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 平面素材（最新上传） -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <div><p class="section-label">GRAPHIC</p><h2 class="section-title">平面素材</h2><p class="section-desc">贴图、PSD、文案参考与平面资料持续更新。</p></div>
        <a href="/c/texture" class="section-more">更多素材 <Fragment set:html={arrow} /></a>
      </div>
      <div class="grid-5">
        {materials.map((m) => (
          <article data-card-id={m.id} class="card reveal">
            <button class="card-img-wrap" type="button" data-preview-src={coverUrl(m.cover)} data-preview-title={m.title} aria-label={`预览 ${m.title}`}>
              {coverUrl(m.cover) ? <img src={coverUrl(m.cover)} alt={m.title} loading="lazy" /> : null}
              <span class="card-cat cat-mat">{priceLabel(m)}</span>
            </button>
            <div class="card-body">
              <h3 class="card-title">{m.title}</h3>
              <p class="card-desc">{m.summary || '暂无简介'}</p>
              <div class="card-footer download-footer">
                <span class="card-size">{m.size || '-- MB'}</span>
                <span class="card-foot-r"><span class="card-type">{m.fileType || '贴图素材'}</span><span class="btn-dl" data-dl data-download-id={m.id} role="button" tabindex="0">下载</span></span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>


  <!-- 软件资源（最新上传） -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <div><p class="section-label">SOFTWARE</p><h2 class="section-title">软件资源</h2><p class="section-desc">SketchUp、Enscape、插件等设计软件安装包及参数资源。</p></div>
        <a href="/c/software" class="section-more">更多软件 <Fragment set:html={arrow} /></a>
      </div>
      <div class="grid-5">
        {software.map((s) => (
          <article data-card-id={s.id} class="card reveal">
            <button class="card-img-wrap" type="button" data-preview-src={coverUrl(s.cover)} data-preview-title={s.title} aria-label={`预览 ${s.title}`}>
              {coverUrl(s.cover) ? <img src={coverUrl(s.cover)} alt={s.title} loading="lazy" /> : null}
              <span class="card-cat cat-inter">{priceLabel(s)}</span>
            </button>
            <div class="card-body">
              <h3 class="card-title">{s.title}</h3>
              <p class="card-desc">{s.summary || '暂无简介'}</p>
              <div class="card-footer download-footer">
                <span class="card-size">{s.size || '-- MB'}</span>
                <span class="card-foot-r"><span class="card-type">{s.fileType || '软件 · 参数'}</span><span class="btn-dl" data-dl data-download-id={s.id} role="button" tabindex="0">下载</span></span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>
