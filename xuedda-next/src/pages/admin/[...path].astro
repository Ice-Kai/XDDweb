---
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>后台管理 - 薛大大生态设计</title>
    <style is:global>
      :root {
        --ink:#18181b;
        --muted:#6b7280;
        --quiet:#9ca3af;
        --paper:#f6f6f7;
        --panel:#ffffff;
        --panel-2:#fafafa;
        --line:#e6e6ea;
        --line-soft:#f0f0f2;
        --gold:#18181b;
        --gold-2:#3f3f46;
        --gold-pale:#f4f4f5;
        --gold-border:#e6e6ea;
        --dark:#f4f4f5;
        --dark-2:#eeeef0;
        --danger:#dc2626;
        --ok:#16a34a;
        --warn:#b45309;
        --shadow:0 1px 3px rgba(0,0,0,.08),0 1px 2px rgba(0,0,0,.04);
        --shadow-soft:0 1px 2px rgba(0,0,0,.05);
      }
      * { box-sizing:border-box; }
      html,body { min-height:100%; }
      body {
        margin:0;
        color:var(--ink);
        background:var(--paper);
        font-family:"Microsoft YaHei","PingFang SC",system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
        font-size:14px;
      }
      button,input,textarea,select { font:inherit; }
      button { border:0; cursor:pointer; }
      a { color:inherit; text-decoration:none; }
      .hide { display:none !important; }

      .login-shell { min-height:100vh; display:grid; place-items:center; padding:26px; }
      .login-panel { width:min(440px,100%); border:1px solid var(--line); border-radius:10px; background:var(--panel); box-shadow:var(--shadow); padding:28px; }
      .login-kicker { color:var(--gold); font-size:11px; font-weight:900; letter-spacing:.18em; text-transform:uppercase; }
      .login-panel h1 { margin:6px 0 8px; font-size:30px; line-height:1.15; }
      .login-panel p { margin:0 0 22px; color:var(--muted); }

      .shell { min-height:100vh; display:grid; grid-template-columns:264px minmax(0,1fr); }
      .side {
        position:sticky; top:0; height:100vh; overflow:auto; padding:20px 14px;
        background:#fbfbfc;
        color:var(--ink); border-right:1px solid var(--line);
      }
      .brand { display:flex; align-items:center; gap:12px; padding:8px 8px 18px; border-bottom:1px solid var(--line); margin-bottom:14px; min-width:0; }
      .brand-mark { flex:0 0 auto; width:40px; height:40px; display:grid; place-items:center; border-radius:8px; background:#18181b; color:#fff; font-weight:1000; letter-spacing:.04em; }
      .brand b { display:block; font-size:16px; line-height:1.2; }
      .brand span { display:block; margin-top:2px; font-size:11px; letter-spacing:.12em; color:var(--quiet); text-transform:uppercase; }
      .side-section { margin:18px 8px 7px; font-size:10px; letter-spacing:.16em; color:var(--quiet); text-transform:uppercase; }
      .nav { display:grid; gap:5px; }
      .nav-btn { min-height:44px; width:100%; display:flex; align-items:center; justify-content:space-between; gap:10px; border-radius:8px; padding:10px 11px; background:transparent; color:var(--muted); transition:background .18s,color .18s,transform .18s; }
      .nav-btn:hover { color:var(--ink); background:var(--gold-pale); transform:translateX(2px); }
      .nav-btn.active { color:var(--ink); background:var(--gold-pale); box-shadow:inset 3px 0 0 var(--gold); }
      .nav-left { display:flex; align-items:center; gap:10px; min-width:0; }
      .nav-ico { width:24px; height:24px; display:grid; place-items:center; border-radius:7px; background:#f0f0f2; color:var(--gold-2); font-size:11px; font-weight:900; }
      .nav-text { min-width:0; overflow:hidden; white-space:nowrap; text-overflow:ellipsis; font-weight:800; }
      .nav-count { min-width:22px; padding:2px 7px; border-radius:999px; background:#f0f0f2; color:var(--quiet); font-size:11px; font-weight:900; }
      .side-note { margin:20px 6px 0; padding:12px; border:1px solid var(--line); border-radius:8px; background:#fff; color:var(--muted); font-size:12px; line-height:1.7; }

      .main { min-width:0; padding:22px 24px 28px; }
      .topbar { position:sticky; top:0; z-index:20; margin:-22px -24px 22px; padding:16px 24px; display:flex; align-items:center; justify-content:space-between; gap:16px; background:rgba(246,246,247,.85); backdrop-filter:blur(12px) saturate(1.5); border-bottom:1px solid var(--line); }
      .page-title { display:flex; align-items:baseline; gap:12px; }
      .page-title h1 { margin:0; font-size:24px; line-height:1.2; letter-spacing:0; }
      .page-title span { color:var(--muted); font-size:13px; }
      .top-actions { display:flex; align-items:center; gap:8px; }
      .admin-pill { color:var(--muted); font-size:12px; padding:8px 10px; border:1px solid var(--line); border-radius:999px; background:var(--panel); }

      .btn { display:inline-flex; align-items:center; justify-content:center; gap:7px; min-height:38px; padding:0 13px; border-radius:6px; background:#18181b; color:#fff; font-weight:900; white-space:nowrap; transition:transform .15s,box-shadow .15s,background .15s,border-color .15s; }
      .btn:hover { transform:translateY(-1px); box-shadow:0 4px 12px rgba(0,0,0,.14); }
      .btn.secondary { background:var(--panel-2); color:var(--ink); border:1px solid var(--line); box-shadow:none; }
      .btn.secondary:hover,.btn.ghost:hover { border-color:var(--gold-border); color:var(--gold); }
      .btn.ghost { background:transparent; color:var(--muted); border:1px solid var(--line); box-shadow:none; }
      .btn.danger { background:rgba(239,107,87,.10); color:var(--danger); border:1px solid rgba(239,107,87,.26); box-shadow:none; }
      .btn.small { min-height:31px; padding:0 10px; font-size:12px; }

      .view { display:none; }
      .view.active { display:block; }
      .dash-grid { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:12px; margin-bottom:16px; }
      .stat-card { position:relative; min-height:112px; overflow:hidden; padding:18px; border:1px solid var(--line); border-radius:9px; background:var(--panel); box-shadow:var(--shadow-soft); transition:border-color .25s,box-shadow .3s,transform .3s; }
      .stat-card:hover { border-color:var(--gold-border); box-shadow:var(--shadow); transform:translateY(-2px); }
      .stat-card span { display:block; color:var(--muted); font-size:13px; font-weight:800; }
      .stat-card b { display:block; margin-top:10px; font-size:34px; line-height:1; }
      .stat-card small { display:block; margin-top:10px; color:var(--muted); font-size:12px; }

      .board { display:grid; grid-template-columns:minmax(0,1fr) 420px; gap:16px; align-items:start; }
      .board.wide-left { grid-template-columns:280px minmax(0,1fr) 420px; }
      .material-console { display:grid; grid-template-columns:minmax(0,1fr); gap:16px; align-items:start; }
      .material-side { position:sticky; top:82px; max-height:calc(100vh - 104px); display:flex; flex-direction:column; }
      .material-side .category-tree { max-height:none; flex:1; }
      .category-actions { display:grid; grid-template-columns:1fr 1fr; gap:8px; padding:10px; border-bottom:1px solid var(--line); background:var(--panel-2); }
      .material-workspace { display:grid; gap:16px; min-width:0; }
      .material-search { display:flex; flex-wrap:wrap; align-items:center; gap:9px; padding:12px; border:1px solid var(--line); border-radius:10px; background:var(--panel); box-shadow:var(--shadow-soft); }
      .material-search > #contentQ { flex:1 1 240px; min-width:200px; }
      .material-search > .select { flex:0 0 auto; min-width:120px; }
      .material-grid { display:grid; grid-template-columns:minmax(0,1fr); gap:16px; align-items:start; }
      /* 编辑抽屉 + 批量抽屉：列布局，内容区滚动、底栏固定 */
      /* 编辑抽屉：右侧滑出 */
      .material-upload { position:fixed; top:0; right:0; z-index:60; width:min(580px,94vw); height:100vh; display:flex; flex-direction:column; overflow:hidden; border-left:1px solid var(--line); background:var(--panel); transform:translateX(101%); transition:transform .26s cubic-bezier(.4,0,.2,1); box-shadow:-14px 0 44px rgba(0,0,0,.14); }
      .material-upload.open { transform:none; }
      /* 批量抽屉：全屏居中大面板 */
      .batch-upload { position:fixed; inset:2.5vh 2.5vw; z-index:60; display:flex; flex-direction:column; overflow:hidden; border:1px solid var(--line); border-radius:14px; background:var(--panel); opacity:0; transform:translateY(14px) scale(.99); pointer-events:none; transition:opacity .2s,transform .2s cubic-bezier(.4,0,.2,1); box-shadow:0 30px 80px rgba(0,0,0,.28); }
      .batch-upload.open { opacity:1; transform:none; pointer-events:auto; }
      .material-upload .panel-head,.batch-upload .panel-head { flex:0 0 auto; }
      .material-upload .panel-body,.batch-upload .panel-body { flex:1 1 auto; overflow:auto; }
      /* 批量步骤在全屏下铺满宽度 */
      .batch-upload .panel-body { width:100%; padding:0 8px; }
      /* 可搜索栏目选择器 */
      .cat-selected { font-size:12.5px; font-weight:700; color:var(--gold); padding:2px 0; }
      .cat-search-list { max-height:240px; overflow:auto; border:1px solid var(--line); border-radius:8px; background:var(--panel); display:grid; gap:1px; padding:4px; }
      .cat-opt { text-align:left; border:0; background:transparent; border-radius:6px; padding:7px 10px; font-size:12.5px; color:var(--ink); cursor:pointer; display:flex; justify-content:space-between; gap:8px; }
      .cat-opt:hover { background:rgba(0,0,0,.05); }
      .cat-opt.active { background:var(--gold); color:#0d0900; font-weight:800; }
      .cat-opt .co-path { color:var(--quiet); font-size:11px; }
      .cat-opt.active .co-path { color:rgba(0,0,0,.55); }
      .drawer-footer { flex:0 0 auto; display:flex; gap:10px; align-items:center; padding:14px 16px; border-top:1px solid var(--line); background:var(--panel); box-shadow:0 -8px 20px rgba(0,0,0,.05); }
      .drawer-footer .btn.primary { flex:1; min-height:42px; font-size:14px; font-weight:800; }
      .batch-import-footer { gap:14px; }
      .batch-import-footer .btn.primary { flex:0 0 220px; }
      .batch-status { flex:1; min-height:auto; margin:0; color:var(--muted); font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
      .drawer-overlay { position:fixed; inset:0; z-index:55; background:rgba(20,20,25,.34); }
      .user-drawer { position:fixed; top:0; right:0; z-index:60; width:min(640px,96vw); height:100vh; overflow:auto; border-radius:0; border-left:1px solid var(--line); background:var(--panel); transform:translateX(101%); transition:transform .26s cubic-bezier(.4,0,.2,1); box-shadow:-14px 0 44px rgba(0,0,0,.14); }
      .user-drawer.open { transform:none; }
      .user-meta { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
      .user-meta div { border:1px solid var(--line); border-radius:8px; padding:8px 10px; background:var(--panel-2); font-size:13px; word-break:break-all; }
      .user-meta b { display:block; color:var(--quiet); font-size:11px; font-weight:700; margin-bottom:3px; }
      .batch-import-box { display:grid; gap:10px; padding:12px; border-top:1px solid var(--line); }
      .batch-import-box .textarea { min-height:132px; }
      .batch-pick { display:flex; flex-wrap:wrap; gap:8px; align-items:center; }
      /* 配对预览：真·table，Excel/Notion 网格 */
      .batch-rows { overflow:auto; }
      .batch-xls { width:100%; border-collapse:collapse; table-layout:fixed; background:var(--panel); }
      .batch-xls th { background:#eef0f3; color:#3f3f46; font-size:12px; font-weight:800; text-align:left; padding:9px 8px; border:1px solid var(--line); border-bottom:2px solid #d4d4d8; position:sticky; top:0; z-index:2; }
      .batch-xls td { border:1px solid var(--line); padding:4px 6px; vertical-align:middle; }
      .batch-xls tbody tr:nth-child(even) td { background:#fafbfc; }
      .batch-xls .br-thumb { width:72px; height:52px; object-fit:cover; border-radius:5px; border:1px solid var(--line); display:block; margin:0 auto; }
      .batch-xls .input,.batch-xls .select { width:100%; min-width:0; min-height:30px; padding:5px 7px; font-size:12.5px; border:0; background:transparent; }
      .batch-xls .input:focus,.batch-xls .select:focus { background:#fff; box-shadow:inset 0 0 0 2px var(--gold); border-radius:4px; outline:none; }
      .batch-xls .input.miss { background:#fff5f5; box-shadow:inset 0 0 0 1px #dc2626; border-radius:4px; }
      .batch-xls .br-idx { display:block; text-align:center; font-weight:800; color:var(--quiet); font-size:13px; }
      .batch-xls .br-rm { display:block; width:100%; text-align:center; color:var(--danger); font-weight:900; font-size:16px; background:transparent; }
      /* 批量上传：Excel 风工作台，工具栏在上、表格为主体 */
      .batch-sheet-tools { display:grid; grid-template-columns:minmax(280px,1.1fr) minmax(260px,1fr) minmax(360px,1.4fr); gap:12px; padding:14px 16px; border-bottom:1px solid var(--line); background:#fbfbfc; }
      .batch-tool { display:grid; gap:8px; min-width:0; align-content:start; }
      .batch-tool-title { display:flex; align-items:center; gap:8px; font-weight:900; font-size:12px; color:#18181b; }
      .batch-tool-title::before { content:""; width:6px; height:6px; border-radius:50%; background:#18181b; }
      .batch-tool-note { color:var(--quiet); font-size:11.5px; line-height:1.5; }
      .batch-defaults { display:flex; flex-wrap:wrap; gap:8px; align-items:center; }
      .batch-defaults .select,.batch-defaults .input { width:auto; min-width:120px; max-width:170px; }
      .batch-sheet-main { display:grid; grid-template-rows:auto minmax(0,1fr); min-height:360px; }
      .batch-sheet-bar { display:flex; flex-wrap:wrap; gap:8px; align-items:center; justify-content:space-between; padding:10px 16px; border-bottom:1px solid var(--line); background:#fff; }
      .batch-sheet-bar .left,.batch-sheet-bar .right { display:flex; flex-wrap:wrap; gap:8px; align-items:center; }
      .batch-step { padding:14px 16px; border-bottom:1px solid var(--line); display:grid; gap:9px; }
      .batch-step:last-child { border-bottom:0; }
      .batch-step-t { display:flex; align-items:center; gap:8px; font-weight:800; font-size:13.5px; color:#18181b; }
      .bs-num { flex:0 0 auto; width:20px; height:20px; border-radius:50%; background:#18181b; color:#fff; font-size:12px; font-weight:800; display:grid; place-items:center; }
      .batch-step > small { color:var(--quiet); font-size:11.5px; }
      .batch-step .textarea { min-height:108px; font-size:12.5px; }
      .batch-bulk { min-height:96px; resize:vertical; font-family:ui-monospace,SFMono-Regular,Consolas,"Microsoft YaHei",sans-serif; }
      .batch-row { display:grid; grid-template-columns:var(--bcols); align-items:stretch; background:var(--panel); }
      .batch-row:nth-child(even) { background:#fafbfc; }
      .batch-row > * { border-right:1px solid var(--line); border-bottom:1px solid var(--line); display:flex; align-items:center; padding:4px 6px; min-width:0; }
      .batch-row > *:last-child { border-right:0; }
      .batch-row .input,.batch-row .select { width:100%; min-height:32px; padding:5px 7px; font-size:12.5px; min-width:0; border:0 !important; background:transparent !important; }
      .batch-row .input:focus,.batch-row .select:focus { background:#fff !important; box-shadow:inset 0 0 0 2px var(--gold); border-radius:4px; }
      .batch-row .input.miss { background:#fff5f5 !important; box-shadow:inset 0 0 0 1px #dc2626; border-radius:4px; }
      .br-cover { justify-content:center; }
      .br-cover img { width:74px; height:52px; object-fit:cover; border-radius:5px; border:1px solid var(--line); }
      .br-link { flex-direction:column; gap:2px; align-items:stretch; }
      .br-link .br-pass { min-height:26px; font-size:11.5px; }
      .br-idx { justify-content:center; font-weight:800; color:var(--quiet); font-size:13px; font-variant-numeric:tabular-nums; }
      .br-rm { justify-content:center; }
      .br-rm-btn,.batch-row > .br-rm { color:var(--danger); font-weight:900; font-size:16px; }
      .file-note { color:var(--quiet); font-size:12px; line-height:1.5; }
      .panel { border:1px solid var(--line); border-radius:9px; background:var(--panel); box-shadow:var(--shadow-soft); overflow:hidden; transition:border-color .25s,box-shadow .3s; }
      .panel:hover { border-color:#dcdce0; }
      .panel-head { min-height:64px; display:flex; align-items:center; justify-content:space-between; gap:12px; padding:14px 16px; border-bottom:1px solid var(--line); background:var(--panel); }
      .panel-title h2 { margin:0; font-size:17px; }
      .panel-title p { margin:2px 0 0; color:var(--quiet); font-size:12px; }
      .panel-body { padding:14px; }
      .toolbar { display:grid; grid-template-columns:minmax(220px,1fr) 150px 132px 132px 84px auto auto; gap:9px; padding:12px 14px; border-bottom:1px solid var(--line); background:var(--panel); }
      .batchbar { display:flex; align-items:center; gap:8px; flex-wrap:wrap; padding:10px 14px; border-bottom:1px solid var(--line); background:var(--panel-2); }
      .bm-group { display:inline-flex; align-items:center; gap:6px; padding:3px 6px; border:1px dashed var(--line); border-radius:8px; }
      .bm-label { font-size:11.5px; color:var(--quiet); font-weight:700; }
      .batchbar-hint { padding:6px 14px; font-size:12px; color:var(--quiet); background:var(--panel-2); border-bottom:1px solid var(--line); }
      .input,.select,.textarea { width:100%; border:1px solid var(--line); border-radius:8px; background:var(--panel-2); color:var(--ink); outline:none; padding:9px 11px; min-height:38px; }
      .textarea { min-height:88px; resize:vertical; }
      .input::placeholder,.textarea::placeholder { color:var(--quiet); }
      .input:focus,.select:focus,.textarea:focus { border-color:#18181b; box-shadow:0 0 0 3px rgba(24,24,27,.08); }
      .table-wrap { overflow:auto; max-height:calc(100vh - 250px); background:var(--panel); }
      .category-board .table-wrap { max-height:calc(100vh - 218px); }
      .category-searchbar { display:flex; align-items:center; gap:8px; padding:12px 14px; border-bottom:1px solid var(--line); background:var(--panel-2); }
      .category-searchbar .input { flex:1; min-width:180px; background:#fff; }
      /* Excel 风网格表：清晰分行线 + 淡竖向网格 + 隔行底色 + 粗表头 */
      table { width:100%; border-collapse:separate; border-spacing:0; font-size:13px; border:1px solid var(--line); border-radius:8px; overflow:hidden; }
      th { position:sticky; top:0; z-index:1; background:#eef0f3; color:#3f3f46; font-size:11px; letter-spacing:.05em; text-transform:uppercase; font-weight:800; border-bottom:2px solid #d4d4d8; }
      th,td { padding:12px 14px; border-bottom:1px solid var(--line); border-right:1px solid var(--line-soft); text-align:left; vertical-align:middle; }
      th:last-child,td:last-child { border-right:0; }
      tbody tr:last-child td { border-bottom:0; }
      tbody tr:nth-child(even) td { background:#f7f8fa; }
      tr.clickable { cursor:pointer; }
      tr.clickable:hover td { background:#eaf1fb; }
      tr.selected td { background:#dfeafb; }
      .thumb { width:54px; height:42px; border-radius:7px; object-fit:cover; background:var(--panel-2); border:1px solid var(--line); }
      .fallback-thumb { width:54px; height:42px; display:grid; place-items:center; border-radius:7px; background:var(--dark); color:var(--gold); font-size:11px; font-weight:1000; }
      .resource-cell { display:block; min-width:220px; }
      .resource-title { font-weight:900; overflow:hidden; white-space:nowrap; text-overflow:ellipsis; }
      .resource-sub { margin-top:3px; color:var(--quiet); font-size:12px; overflow:hidden; white-space:nowrap; text-overflow:ellipsis; }
      .mono { font-variant-numeric:tabular-nums; font-family:ui-monospace,SFMono-Regular,Consolas,monospace; }
      .pill { display:inline-flex; align-items:center; min-height:24px; margin:1px 3px 1px 0; padding:3px 8px; border-radius:999px; background:var(--panel-2); color:var(--muted); font-size:12px; font-weight:900; border:1px solid var(--line); }
      .pill.ok { background:#ecfdf3; color:#15803d; border-color:#c5ecd2; }
      .pill.off { background:#f4f4f5; color:var(--quiet); }
      .pill.warn { background:#fef6e7; color:var(--warn); border-color:#f5e3c2; }
      .pill.bad { background:#fdecec; color:#b91c1c; border-color:#f3c2c2; }
      .row-actions { display:flex; gap:6px; flex-wrap:wrap; }
      .empty { padding:28px 10px; color:var(--muted); text-align:center; }
      .message { min-height:20px; margin:10px 2px 0; color:var(--muted); font-size:12px; }
      .message.ok { color:var(--ok); }
      .message.error { color:var(--danger); }
      .editor { position:sticky; top:82px; max-height:calc(100vh - 104px); overflow:auto; }
      .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
      .field { display:grid; gap:6px; }
      .field.wide { grid-column:1 / -1; }
      .field > span { color:var(--muted); font-size:12px; font-weight:900; }
      .field small { color:var(--quiet); font-size:12px; line-height:1.5; }
      .upload-form { gap:14px; }
      .upload-step { grid-column:1 / -1; border:1px solid var(--line); border-radius:9px; background:#fafafa; overflow:hidden; }
      .upload-step-head { display:flex; align-items:center; justify-content:space-between; gap:10px; padding:11px 12px; border-bottom:1px solid var(--line); background:#fff; }
      .upload-step-title { display:flex; align-items:center; gap:8px; min-width:0; font-weight:900; }
      .upload-step-index { width:22px; height:22px; display:grid; place-items:center; border-radius:5px; background:#18181b; color:#fff; font-size:12px; font-weight:1000; }
      .upload-step-hint { color:var(--quiet); font-size:12px; white-space:nowrap; }
      .upload-step-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; padding:12px; }
      .upload-step-grid .wide { grid-column:1 / -1; }
      .choice-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:8px; }
      .choice-grid .select,.choice-grid .input { min-height:40px; }
      .batchbar strong { color:var(--ink); font-size:12px; margin-right:2px; }
      .upload-row { display:grid; grid-template-columns:minmax(0,1fr) auto; gap:8px; }
      .size-picker { display:grid; grid-template-columns:minmax(0,1fr) 88px; gap:8px; }
      .upload-btn { position:relative; display:inline-flex; align-items:center; justify-content:center; min-height:38px; padding:0 12px; border-radius:8px; border:1px solid var(--gold-border); background:var(--gold-pale); color:var(--gold); font-weight:900; white-space:nowrap; cursor:pointer; }
      .upload-btn input { position:absolute; inset:0; opacity:0; cursor:pointer; }
      .file-input-hidden { position:absolute; width:1px; height:1px; opacity:0; pointer-events:none; }
      .drawer-actions { grid-column:1 / -1; display:flex; gap:8px; flex-wrap:wrap; padding-top:2px; }
      .category-tree { display:flex; flex-direction:column; gap:0; max-height:calc(100vh - 250px); overflow:auto; padding:8px 6px; }
      /* 层级分明的树：主栏目=分组标题(高/粗/彩块/同色计数)，子栏目=缩进小字+连接符 */
      .cat-node { width:100%; display:flex; align-items:center; justify-content:space-between; gap:8px; border:0; border-radius:8px; padding:0 10px; background:transparent; color:var(--ink); text-align:left; transition:background .12s; }
      .cat-node:hover { background:rgba(0,0,0,.055); }
      /* 全部资源：黑色锚点，独立醒目 */
      .cat-all { min-height:40px; font-weight:800; font-size:13.5px; background:#18181b; color:#fff; margin-bottom:8px; }
      .cat-all:hover { background:#000; }
      .cat-all .pill { background:rgba(255,255,255,.2); color:#fff; border-color:transparent; }
      /* 主栏目：分组标题感——更高、更粗、彩色方块、组间留白 */
      .cat-root { min-height:36px; margin-top:6px; font-weight:800; font-size:14px; color:#111118; }
      .cat-root:first-of-type { margin-top:0; }
      .cat-root .cat-chev { color:#52525b; font-size:11px; font-weight:900; }
      .cat-ico { flex:0 0 auto; }
      .cat-node.active .cat-ico { stroke:#0d0900; }
      /* 子栏目：明显更小更淡、缩进、灰色连接符 */
      .cat-sub { min-height:27px; font-size:12.5px; font-weight:500; color:#6b6b73; }
      .cat-sub .cat-conn { flex:0 0 auto; color:#c8c8d0; font-size:12px; }
      /* 选中（叶子）：金色高亮 */
      .cat-node.active { background:var(--gold) !important; color:#0d0900; font-weight:700; }
      .cat-node.active .cat-chev,.cat-node.active .cat-conn { color:#0d0900; }
      .cat-node.active .pill { background:rgba(0,0,0,.14) !important; color:#0d0900 !important; border-color:transparent !important; }
      .cat-left { display:flex; align-items:center; gap:7px; min-width:0; }
      .cat-chev { flex:0 0 auto; width:12px; text-align:center; font-size:9px; color:var(--quiet); }
      .cat-node .pill { background:#f4f4f5; border:1px solid var(--line); color:var(--muted); font-variant-numeric:tabular-nums; font-weight:700; }
      .cat-root .pill { font-weight:800; }   /* 计数底色由 JS 按组上色 */
      .cat-node .pill.zero { opacity:.4; font-weight:600; }
      #contentRows td { padding:16px 14px; font-size:13.5px; }
      #contentRows .resource-title { font-size:14px; }
      #contentRows .resource-sub { font-size:12.5px; margin-top:4px; }
      .content-pager { display:flex; flex-wrap:wrap; align-items:center; gap:6px; padding:14px 2px 2px; }
      .pg-btn { min-width:34px; min-height:32px; padding:0 11px; border:1px solid var(--line); border-radius:7px; background:var(--panel); color:var(--ink); font-size:13px; font-weight:700; }
      .pg-btn:hover:not(:disabled) { border-color:#18181b; }
      .pg-btn.active { background:#18181b; color:#fff; border-color:#18181b; }
      .pg-btn:disabled { opacity:.4; cursor:default; }
      .pg-gap { color:var(--quiet); padding:0 2px; }
      .pg-info { margin-left:6px; color:var(--muted); font-size:12px; }
      .cat-name { overflow:hidden; white-space:nowrap; text-overflow:ellipsis; }
      .category-table { min-width:900px; }
      .category-table th:nth-child(1),.category-table td:nth-child(1) { width:86px; }
      .category-table th:nth-child(2),.category-table td:nth-child(2) { width:78px; color:var(--quiet); }
      .category-table th:nth-child(4),.category-table td:nth-child(4) { width:126px; }
      .category-table th:nth-child(5),.category-table td:nth-child(5) { width:86px; }
      .category-table th:nth-child(6),.category-table td:nth-child(6) { width:86px; }
      .category-table th:nth-child(7),.category-table td:nth-child(7) { width:116px; }
      .category-group-row td {
        padding:10px 14px;
        background:linear-gradient(90deg,#f8eddc,#fff 72%) !important;
        border-top:2px solid #ead6b5;
        border-bottom:1px solid #ead6b5;
      }
      .category-group-title { display:flex; align-items:center; gap:10px; }
      .category-group-title strong { color:#111118; font-size:14px; font-weight:1000; }
      .category-group-title span { display:inline-flex; align-items:center; height:22px; padding:0 8px; border-radius:999px; background:#fff; color:#a36a12; border:1px solid #efd9b5; font-size:12px; font-weight:900; }
      .sort-input { width:62px; min-height:30px; padding:5px 8px; border-color:transparent; border-radius:999px; background:var(--panel-2); text-align:center; font-weight:900; color:var(--gold); }
      .sort-input:focus { background:var(--dark-2); border-color:var(--gold); }
      .category-name { min-width:300px; }
      .cat-name-wrap { display:flex; align-items:center; gap:7px; min-width:0; }
      .cat-guide { font-family:ui-monospace,'Cascadia Mono',Consolas,monospace; color:#cbd5e1; white-space:pre; font-size:14px; line-height:1; letter-spacing:1px; flex:0 0 auto; }
      .cat-row-ico { flex:0 0 auto; }
      .cat-label { overflow:hidden; white-space:nowrap; text-overflow:ellipsis; font-weight:600; color:#3f3f46; }
      .cat-label.root { font-weight:800; font-size:14px; color:#111118; }
      .category-panel .panel-head,.data-panel .panel-head { background:var(--panel); }
      .form-panel { border-color:var(--gold-border); }
      .form-panel .panel-head { background:#fafafa; color:var(--ink); border-bottom-color:var(--line); }
      .form-panel .panel-title p { color:var(--quiet); }
      .form-panel .panel-body { background:var(--panel); }
      .feedback-list { display:grid; gap:10px; }
      .feedback-card { border:1px solid var(--line); border-radius:10px; background:var(--panel-2); padding:13px; display:grid; gap:9px; }
      .feedback-card h3 { margin:0; font-size:15px; }
      .feedback-meta { display:flex; gap:8px; flex-wrap:wrap; color:var(--muted); font-size:12px; }
      .feedback-body,.feedback-reply { white-space:pre-wrap; line-height:1.7; }
      .feedback-reply { border:1px solid var(--gold-border); border-radius:8px; background:var(--gold-pale); padding:10px; }
      .notice-admin-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; align-items:start; }
      .notice-admin-card { border:1px solid var(--line); border-radius:12px; background:var(--panel-2); overflow:hidden; }
      .notice-admin-card.full { grid-column:1 / -1; }
      .notice-admin-head { display:flex; align-items:center; justify-content:space-between; gap:12px; padding:14px 16px; border-bottom:1px solid var(--line); background:var(--panel); }
      .notice-admin-head h3 { margin:0; font-size:15px; font-weight:900; color:var(--ink); }
      .notice-admin-head p { margin:3px 0 0; color:var(--muted); font-size:12px; }
      .notice-admin-rows { display:grid; gap:10px; padding:14px; }
      .notice-edit-row { display:grid; grid-template-columns:1fr 130px auto; gap:8px; padding:12px; border:1px solid var(--line); border-radius:10px; background:#fff; }
      .notice-edit-row textarea { grid-column:1 / -1; min-height:72px; resize:vertical; }
      .notice-edit-row .row-actions { justify-content:flex-end; }
      .notice-popup-grid { display:grid; grid-template-columns:130px 1fr 1fr; gap:12px; padding:14px; }
      .notice-popup-preview { width:100%; aspect-ratio:4/3; border-radius:12px; border:1px dashed var(--line); background:linear-gradient(135deg,#f8f5ef,#fff); object-fit:cover; }
      .notice-popup-grid .wide { grid-column:2 / -1; }
      .notice-savebar { display:flex; align-items:center; justify-content:flex-end; gap:10px; padding:12px 14px; border-top:1px solid var(--line); background:var(--panel); }

      @media (max-width:1280px) {
        .board,.board.wide-left { grid-template-columns:1fr; }
        .notice-admin-grid { grid-template-columns:1fr; }
        .material-console,.material-grid { grid-template-columns:1fr; }
        .material-side { position:static; max-height:none; }
        .editor { position:static; max-height:none; }
        .table-wrap,.category-tree { max-height:none; }
      }
      @media (max-width:820px) {
        .shell { grid-template-columns:1fr; }
        .side { position:static; height:auto; }
        .main { padding:12px; }
        .topbar { margin:-12px -12px 12px; flex-direction:column; align-items:flex-start; }
        .dash-grid { grid-template-columns:1fr 1fr; }
        .toolbar,.material-search { grid-template-columns:1fr; }
        .form-grid { grid-template-columns:1fr; }
        .upload-step-grid,.choice-grid { grid-template-columns:1fr; }
        .upload-step-hint { white-space:normal; }
      }
    </style>
  </head>
  <body>
    <div id="login" class="login-shell">
      <form id="loginForm" class="login-panel">
        <div class="login-kicker">XDesign Admin</div>
        <h1>后台管理</h1>
        <p>登录后管理栏目、分类上传、资源链接、封面和用户反馈。</p>
        <label class="field"><span>账号</span><input id="loginUser" class="input" autocomplete="username" /></label>
        <label class="field"><span>密码</span><input id="loginPass" class="input" type="password" autocomplete="current-password" /></label>
        <p id="loginMsg" class="message"></p>
        <button class="btn" type="submit">进入后台</button>
      </form>
    </div>

    <div id="app" class="shell hide">
      <aside class="side">
        <div class="brand"><div class="brand-mark">XD</div><div><b>薛大大生态设计</b><span>asset control</span></div></div>
        <div class="side-section">Manage</div>
        <nav class="nav">
          <button class="nav-btn active" data-view="dashboard" type="button"><span class="nav-left"><span class="nav-ico">01</span><span class="nav-text">工作台</span></span><span class="nav-count" id="navDashCount">-</span></button>
          <button class="nav-btn" data-view="categories" type="button"><span class="nav-left"><span class="nav-ico">02</span><span class="nav-text">栏目管理</span></span><span class="nav-count" id="navCategoryCount">-</span></button>
          <button class="nav-btn" data-view="contents" type="button"><span class="nav-left"><span class="nav-ico">03</span><span class="nav-text">资源管理</span></span><span class="nav-count" id="navResourceCount">-</span></button>
          <button class="nav-btn" data-view="feedback" type="button"><span class="nav-left"><span class="nav-ico">04</span><span class="nav-text">反馈管理</span></span><span class="nav-count" id="navFeedbackCount">-</span></button>
          <button class="nav-btn" data-view="notices" type="button"><span class="nav-left"><span class="nav-ico">05</span><span class="nav-text">消息公告</span></span><span class="nav-count" id="navNoticeCount">3</span></button>
          <button class="nav-btn" data-view="users" type="button"><span class="nav-left"><span class="nav-ico">06</span><span class="nav-text">用户管理</span></span><span class="nav-count" id="navUserCount">-</span></button>
          <button class="nav-btn" data-view="logs" type="button"><span class="nav-left"><span class="nav-ico">07</span><span class="nav-text">操作日志</span></span><span class="nav-count" id="navLogCount"></span></button>
        </nav>
        <div class="side-note">现在按旧 PHP 流程：先维护栏目树，再在指定栏目下新增/编辑资源，支持排序、显示状态、批量移动和分类上传。</div>
      </aside>

      <main class="main">
        <header class="topbar">
          <div class="page-title"><h1 id="pageTitle">工作台</h1><span id="pageHint">站点数据与近期维护动作</span></div>
          <div class="top-actions"><span id="adminName" class="admin-pill"></span><button id="logout" class="btn secondary" type="button">退出</button></div>
        </header>

        <section id="dashboardView" class="view active">
          <div class="dash-grid">
            <div class="stat-card"><span>资源总数</span><b id="sResources">-</b><small>新资源表 contents</small></div>
            <div class="stat-card"><span>栏目节点</span><b id="sCategories">-</b><small>旧栏目树 lz_category</small></div>
            <div class="stat-card"><span>会员数量</span><b id="sMembers">-</b><small>legacy 会员表</small></div>
            <div class="stat-card"><span>反馈记录</span><b id="sFeedback">-</b><small>待回复与已回复</small></div>
          </div>
          <div class="board">
            <div class="panel">
              <div class="panel-head"><div class="panel-title"><h2>管理流程</h2><p>对齐旧版 PHP 后台</p></div><button id="refreshAll" class="btn ghost" type="button">刷新</button></div>
              <div class="panel-body">
                <p class="message">栏目管理负责新增、删减、导航显示和排序；资源管理负责按栏目上传封面/附件、维护网盘链接、排序、推荐、置顶、显示状态和批量移动。</p>
              </div>
            </div>
            <div class="panel">
              <div class="panel-head"><div class="panel-title"><h2>快速动作</h2><p>常用入口</p></div></div>
              <div class="panel-body">
                <div class="row-actions">
                  <button class="btn" id="quickNew" type="button">新增资源</button>
                  <button class="btn secondary" id="quickCategory" type="button">新增栏目</button>
                  <button class="btn ghost" id="quickFeedback" type="button">处理反馈</button>
                  <a class="btn ghost" href="/" target="_blank" rel="noopener">打开前台</a>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section id="categoriesView" class="view">
          <div class="board category-board">
            <div class="panel data-panel category-panel">
              <div class="panel-head">
                <div class="panel-title"><h2>栏目树</h2><p>新增、编辑、删除、排序和导航显示</p></div>
                <div class="row-actions"><button id="newRootCategory" class="btn" type="button">新增一级栏目</button><button id="saveCategorySort" class="btn secondary" type="button">保存排序</button></div>
              </div>
              <div class="category-searchbar">
                <input id="categoryQ" class="input" placeholder="搜索栏目名称、ID、路径…" />
                <button id="categoryClear" class="btn ghost small" type="button">清空</button>
              </div>
              <div class="table-wrap">
                <table class="category-table">
                  <thead><tr><th style="width:70px">排序</th><th>ID</th><th>栏目名称</th><th>模型</th><th>导航</th><th>资源</th><th>操作</th></tr></thead>
                  <tbody id="categoryRows"></tbody>
                </table>
              </div>
              <div class="panel-body"><p id="categoryMsg" class="message"></p></div>
            </div>
            <aside class="panel editor form-panel">
              <div class="panel-head"><div class="panel-title"><h2 id="categoryEditorTitle">新增栏目</h2><p id="categoryEditorHint">可创建父子栏目</p></div><button id="resetCategory" class="btn ghost small" type="button">清空</button></div>
              <div class="panel-body">
                <form id="categoryForm" class="form-grid">
                  <input id="catId" type="hidden" />
                  <label class="field wide"><span>栏目名称</span><input id="catName" class="input" required /></label>
                  <label class="field"><span>上级栏目</span><select id="catParent" class="select"></select></label>
                  <label class="field"><span>内容模型</span><select id="catType" class="select"><option value="download">下载资源</option><option value="course">课程</option><option value="article">文章</option><option value="picture">图集</option><option value="mp4">视频</option><option value="question">问答</option><option value="page">单页</option><option value="link">链接</option></select></label>
                  <label class="field"><span>排序</span><input id="catSort" class="input" type="number" value="20" /></label>
                  <label class="field"><span>导航显示</span><select id="catMenu" class="select"><option value="1">显示</option><option value="0">隐藏</option></select></label>
                  <div class="field wide"><span>封面 URL</span><div class="upload-row"><input id="catCover" class="input" /><button id="catCoverPick" class="upload-btn" type="button">上传封面</button><input id="catCoverUpload" class="file-input-hidden" type="file" accept="image/jpeg,image/png,image/webp,image/gif" /></div></div>
                  <label class="field wide"><span>关键词</span><input id="catKeywords" class="input" /></label>
                  <label class="field wide"><span>栏目链接/别名</span><input id="catUrl" class="input" /></label>
                  <label class="field wide"><span>描述</span><textarea id="catDescription" class="textarea"></textarea></label>
                  <div class="drawer-actions"><button class="btn" type="submit">保存栏目</button><button id="deleteCategory" class="btn danger" type="button">删除栏目</button><button id="newChildCategory" class="btn secondary" type="button">给当前栏目加子栏目</button></div>
                </form>
              </div>
            </aside>
          </div>
        </section>

        <section id="contentsView" class="view">
          <div class="material-console">
            <div class="material-workspace">
              <div class="material-search">
                <input id="contentQ" class="input" placeholder="输入关键词搜索…" />
                <select id="contentField" class="select"><option value="all">全部字段</option><option value="title">仅标题(素材名)</option><option value="keywords">仅关键词</option><option value="summary">仅简介</option></select>
                <select id="contentCategory" class="select"></select>
                <select id="contentFormat" class="select"><option value="">全部类型</option><option value="SU">SU / SKP</option><option value="MAX">3ds Max</option><option value="PSD">PSD素材</option><option value="D5">D5</option><option value="CAD">CAD</option><option value="TEXT">文本</option><option value="OTHER">其他</option></select>
                <select id="contentStatus" class="select"><option value="all">全部状态</option><option value="show">显示中</option><option value="hidden">已隐藏</option><option value="vip">VIP</option><option value="recommend">推荐</option><option value="top">置顶</option></select>
                <select id="contentLimit" class="select"><option>20</option><option>50</option><option>100</option></select>
                <button id="contentSearch" class="btn" type="button">搜索</button>
                <button id="contentReset" class="btn ghost" type="button">重置</button>
                <select id="contentOrder" class="select" style="display:none"><option value="newest">最新</option><option value="sort">排序优先</option><option value="hits">浏览量</option><option value="downloads">下载量</option><option value="oldest">最早</option></select>
              </div>

              <div class="material-grid">
                <div class="panel data-panel">
                  <div class="panel-head">
                    <div class="panel-title"><h2>素材库</h2><p>选中素材后可批量隐藏、移动或编辑</p></div>
                    <div class="row-actions"><button id="batchOpen" class="btn" type="button">批量上传</button><button id="newContent" class="btn secondary" type="button">单个新增</button></div>
                  </div>
                  <div class="batchbar">
                    <span id="selectedCount" class="pill">已选 0</span>
                    <button id="batchSelectAll" class="btn ghost small" type="button">全选本页</button>
                    <button id="batchSelectNone" class="btn ghost small" type="button">取消选择</button>
                    <strong>批量操作</strong>
                    <span class="bm-group"><span class="bm-label">迁移到</span><select id="batchMoveTo" class="select" style="max-width:200px"></select><button id="batchMove" class="btn secondary small" type="button">迁移栏目</button></span>
                    <span class="bm-group"><span class="bm-label">改类型</span><select id="batchTypeTo" class="select" style="max-width:140px"><option value="">选择类型…</option><option value="SU">SU / SKP</option><option value="MAX">3ds Max</option><option value="PSD">PSD素材</option><option value="D5">D5</option><option value="CAD">CAD</option><option value="TEXT">文本</option><option value="OTHER">其他</option></select><button id="batchType" class="btn secondary small" type="button">批量改类型</button></span>
                    <button id="batchBulkShow" class="btn ghost small" type="button">批量显示</button>
                    <button id="batchHide" class="btn ghost small" type="button">批量隐藏</button>
                    <button id="batchDelete" class="btn danger small" type="button">批量删除</button>
                    <button id="scanLinks" class="btn ghost small" type="button">扫描本页链接</button>
                  </div>
                  <div class="batchbar-hint">提示：勾选首项后按住 <b>Shift</b> 点末项可范围多选。</div>
                  <div class="table-wrap">
                    <table>
                      <thead><tr><th style="width:38px"><input id="checkAllContents" type="checkbox" /></th><th>素材</th><th>栏目</th><th>类型/大小</th><th>序号</th><th>状态</th><th>数据</th><th>操作</th></tr></thead>
                      <tbody id="contentRows"></tbody>
                    </table>
                  </div>
                  <div class="panel-body"><div id="contentPager" class="content-pager"></div><p id="contentMsg" class="message"></p></div>
                </div>

