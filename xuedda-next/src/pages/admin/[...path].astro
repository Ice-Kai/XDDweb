          CAD:'CAD 图纸',
          TEXT:'文本参考',
          OTHER:kind === 'texture' ? '灯光贴图' : '其他资源',
        };
        $('fFileType').value = labels[format] || labels.OTHER;
      }

      $('loginForm').onsubmit = async (event) => {
        event.preventDefault();
        setMsg('loginMsg', '登录中...');
        try {
          await api('/api/admin/login', json('POST', { username:$('loginUser').value, password:$('loginPass').value }));
          setMsg('loginMsg', '');
          await bootstrap();
        } catch (error) {
          setMsg('loginMsg', error.message, 'error');
        }
      };
      $('logout').onclick = async () => { await fetch('/api/admin/logout', { method:'POST', credentials:'include' }); location.reload(); };
      document.querySelectorAll('.nav-btn').forEach((button) => button.addEventListener('click', () => setView(button.dataset.view)));
      // ── 用户管理 ──────────────────────────────────────────────
      const LEVEL_NAMES = ['普通会员', '月卡', '季卡/半年卡', '年卡'];
      function fmtDateTime(v) { if (!v) return '—'; const s = String(v).replace('T', ' ').slice(0, 16); return s || '—'; }
      function tsToDateInput(sec) { const n = Number(sec || 0); if (!n) return ''; const d = new Date(n * 1000); if (Number.isNaN(d.getTime())) return ''; return d.toISOString().slice(0, 10); }
      function dateInputToTs(str) { if (!str) return 0; const t = Date.parse(str + 'T00:00:00'); return Number.isNaN(t) ? 0 : Math.floor(t / 1000); }
      function openUserDrawer() { $('userDrawer').classList.add('open'); $('userOverlay').classList.remove('hide'); }
      function closeUserDrawer() { $('userDrawer')?.classList.remove('open'); $('userOverlay')?.classList.add('hide'); }
      async function loadUsers() {
        setMsg('userMsg', '正在读取用户...');
        const q = encodeURIComponent($('userQ').value || '');
        const limit = Number($('userLimit').value || 20);
        const date = $('userDate').value || '';
        const field = $('userField').value || 'login';
        const data = await api(`/api/admin/users?q=${q}&limit=${limit}&page=${state.userPage}&date=${encodeURIComponent(date)}&field=${field}`);
        state.userRows = data.rows || [];
        renderUserRows();
        renderUserPager(Number(data.total || 0), limit, state.userPage);
        setMsg('userMsg', `共 ${data.total || 0} 个用户`, 'ok');
        // 当日统计条：选了日期就显示「YYYY-MM-DD 登录/注册 N 人」
        const stat = $('userDayStat');
        if (date) {
          const label = field === 'register' ? '注册' : '登录';
          stat.textContent = `${date} ${label} ${Number(data.total || 0).toLocaleString()} 人`;
        } else { stat.textContent = ''; }
      }
      function localDateStr(offsetDays) {
        const d = new Date(); d.setDate(d.getDate() - (offsetDays || 0));
        const p = (n) => String(n).padStart(2, '0');
        return `${d.getFullYear()}-${p(d.getMonth() + 1)}-${p(d.getDate())}`;
      }
      function renderUserRows() {
        const tbody = $('userRows');
        tbody.replaceChildren();
        if (!state.userRows.length) { const tr = document.createElement('tr'); const td = el('td', 'empty', '没有符合条件的用户'); td.colSpan = 7; tr.appendChild(td); tbody.appendChild(tr); return; }
        for (const u of state.userRows) {
          const tr = document.createElement('tr');
          tr.className = 'clickable';
          tr.onclick = () => openUser(u.id);
          tr.appendChild(el('td', 'mono', u.id));
          const who = el('td');
          who.appendChild(el('div', 'resource-title', u.nickname || u.user_name || u.email || `用户${u.id}`));
          who.appendChild(el('div', 'resource-sub', u.user_name || u.email || (u.user_type == 2 ? '微信用户' : u.user_type == 1 ? 'QQ用户' : '')));
          tr.appendChild(who);
          const lv = el('td');
          lv.appendChild(el('span', `pill ${Number(u.level) > 0 ? 'warn' : 'off'}`, LEVEL_NAMES[Number(u.level) || 0] || '普通'));
          tr.appendChild(lv);
          tr.appendChild(el('td', 'mono', u.integral ?? 0));
          tr.appendChild(el('td', '', fmtDateTime(u.create_time)));
          tr.appendChild(el('td', '', fmtDateTime(u.last_login_time)));
          const act = el('td');
          const edit = el('button', 'btn small', '管理'); edit.type = 'button'; edit.onclick = (e) => { e.stopPropagation(); openUser(u.id); };
          act.appendChild(edit);
          tr.appendChild(act);
          tbody.appendChild(tr);
        }
      }
      function renderUserPager(total, limit, page) {
        const wrap = $('userPager');
        wrap.replaceChildren();
        const pages = Math.max(1, Math.ceil(total / (limit || 20)));
        if (pages <= 1) return;
        const mk = (label, p, disabled, active) => { const b = el('button', `pg-btn ${active ? 'active' : ''}`.trim(), label); b.type = 'button'; if (disabled) b.disabled = true; else b.onclick = () => { state.userPage = p; loadUsers(); }; return b; };
        wrap.appendChild(mk('上一页', page - 1, page <= 1));
        const nums = [];
        for (let n = 1; n <= pages; n += 1) if (n === 1 || n === pages || Math.abs(n - page) <= 2) nums.push(n);
        let prev = 0;
        for (const n of nums) { if (n - prev > 1) wrap.appendChild(el('span', 'pg-gap', '…')); wrap.appendChild(mk(String(n), n, false, n === page)); prev = n; }
        wrap.appendChild(mk('下一页', page + 1, page >= pages));
        wrap.appendChild(el('span', 'pg-info', `共 ${total} 个 · ${page}/${pages} 页`));
      }
      async function openUser(id) {
        setMsg('userMsg', '正在读取用户详情...');
        const data = await api(`/api/admin/users/${id}`);
        const u = data.user;
        state.currentUserId = Number(u.id);
        $('userDrawerTitle').textContent = u.nickname || u.user_name || `用户 #${u.id}`;
        $('userDrawerSub').textContent = `ID ${u.id} · ${u.user_name || u.email || '—'}`;
        const meta = $('userMeta');
        meta.replaceChildren();
        const cell = (label, val) => { const d = document.createElement('div'); d.appendChild(el('b', '', label)); d.appendChild(document.createTextNode(text(val))); return d; };
        meta.appendChild(cell('用户名', u.user_name || '—'));
        meta.appendChild(cell('邮箱', u.email || '—'));
        meta.appendChild(cell('注册时间', fmtDateTime(u.create_time)));
        meta.appendChild(cell('最后登录', fmtDateTime(u.last_login_time)));
        meta.appendChild(cell('累计签到', `${u.all_sign_num || 0} 次`));
        meta.appendChild(cell('登录方式', u.user_type == 2 ? '微信' : u.user_type == 1 ? 'QQ' : '账号'));
        $('uLevel').value = String(Number(u.level) || 0);
        $('uIntegral').value = u.integral ?? 0;
        $('uExp').value = tsToDateInput(u.exp_time);
        const logs = data.logs || [];
        $('uLogCount').textContent = logs.length ? `最近 ${logs.length} 条` : '暂无下载记录';
        const body = $('uLogRows');
        body.replaceChildren();
        if (!logs.length) { const tr = document.createElement('tr'); const td = el('td', 'empty', '该用户暂无下载记录'); td.colSpan = 2; tr.appendChild(td); body.appendChild(tr); }
        for (const lg of logs) {
          const tr = document.createElement('tr');
          tr.appendChild(el('td', '', lg.title || `资源 #${lg.data_id}`));
          tr.appendChild(el('td', '', fmtDateTime(lg.create_time ? new Date(Number(lg.create_time) * 1000).toISOString() : '')));
          body.appendChild(tr);
        }
        setMsg('userMsg', '', '');
        openUserDrawer();
      }
      async function saveUser() {
        if (!state.currentUserId) return;
        const payload = { integral: Number($('uIntegral').value || 0), level: Number($('uLevel').value || 0), exp_time: dateInputToTs($('uExp').value) };
        await api(`/api/admin/users/${state.currentUserId}`, json('PATCH', payload));
        setMsg('userMsg', '已保存用户积分 / 会员', 'ok');
        closeUserDrawer();
        await loadUsers();
      }
      $('userSearch').onclick = () => { state.userPage = 1; loadUsers(); };
      $('userReset').onclick = () => { $('userQ').value = ''; $('userDate').value = ''; $('userField').value = 'login'; state.userPage = 1; loadUsers(); };
      $('userRefresh').onclick = () => loadUsers();
      $('userQ').onkeydown = (e) => { if (e.key === 'Enter') { state.userPage = 1; loadUsers(); } };
      $('userLimit').onchange = () => { state.userPage = 1; loadUsers(); };
      $('userDate').onchange = () => { state.userPage = 1; loadUsers(); };
      $('userField').onchange = () => { if ($('userDate').value) { state.userPage = 1; loadUsers(); } };
      document.querySelectorAll('[data-userday]').forEach((b) => { b.onclick = () => {
        const v = b.getAttribute('data-userday');
        if (v === 'clear') { $('userDate').value = ''; }
        else { $('userField').value = 'login'; $('userDate').value = localDateStr(Number(v)); }
        state.userPage = 1; loadUsers();
      }; });
      $('uSave').onclick = saveUser;
      $('userDrawerClose').onclick = closeUserDrawer;
      $('userOverlay').onclick = closeUserDrawer;

      // ── 操作日志 + 链接扫描 ──────────────────────────────────
      const ACTION_NAMES = { create:'新增', update:'编辑', hide:'隐藏', show:'显示', move:'移动', batch:'批量', user:'用户', delete:'删除' };
      const TARGET_NAMES = { content:'资源', category:'栏目', member:'用户', feedback:'反馈' };
      function buildPager(wrapId, total, limit, page, go) {
        const wrap = $(wrapId);
        wrap.replaceChildren();
        const pages = Math.max(1, Math.ceil(total / (limit || 20)));
        if (pages <= 1) return;
        const mk = (label, p, dis, act) => { const b = el('button', `pg-btn ${act ? 'active' : ''}`.trim(), label); b.type = 'button'; if (dis) b.disabled = true; else b.onclick = () => go(p); return b; };
        wrap.appendChild(mk('上一页', page - 1, page <= 1));
        const nums = [];
        for (let n = 1; n <= pages; n += 1) if (n === 1 || n === pages || Math.abs(n - page) <= 2) nums.push(n);
        let prev = 0;
        for (const n of nums) { if (n - prev > 1) wrap.appendChild(el('span', 'pg-gap', '…')); wrap.appendChild(mk(String(n), n, false, n === page)); prev = n; }
        wrap.appendChild(mk('下一页', page + 1, page >= pages));
        wrap.appendChild(el('span', 'pg-info', `共 ${total} 条 · ${page}/${pages} 页`));
      }
      async function loadLogs() {
        setMsg('logMsg', '正在读取日志...');
        const params = new URLSearchParams({ page: String(state.logPage), limit: '30' });
        const logDate = $('logDate')?.value || '';
        const logAction = $('logAction')?.value || 'all';
        const logQ = $('logQ')?.value.trim() || '';
        if (logDate) params.set('date', logDate);
        if (logAction && logAction !== 'all') params.set('action', logAction);
        if (logQ) params.set('q', logQ);
        const data = await api(`/api/admin/logs?${params.toString()}`);
        state.logRows = data.rows || [];
        const tbody = $('logRows');
        tbody.replaceChildren();
        if (!state.logRows.length) { const tr = document.createElement('tr'); const td = el('td', 'empty', '暂无操作日志'); td.colSpan = 4; tr.appendChild(td); tbody.appendChild(tr); }
        for (const r of state.logRows) {
          const tr = document.createElement('tr');
          tr.appendChild(el('td', '', fmtDateTime(r.created_at)));
          const act = el('td');
          act.appendChild(el('span', `pill ${r.action === 'hide' ? 'bad' : r.action === 'create' ? 'ok' : 'warn'}`, ACTION_NAMES[r.action] || r.action));
          tr.appendChild(act);
          const obj = el('td');
          const targetName = TARGET_NAMES[r.target_type] || r.target_type || '对象';
          obj.appendChild(el('div', 'resource-title', `${targetName} · ${r.title || `#${r.target_id}`}`));
          if (r.detail) obj.appendChild(el('div', 'resource-sub', r.detail));
          tr.appendChild(obj);
          tr.appendChild(el('td', '', r.admin || 'admin'));
          tbody.appendChild(tr);
        }
        buildPager('logPager', Number(data.total || 0), 30, state.logPage, (p) => { state.logPage = p; loadLogs(); });
        const scope = [logDate, ACTION_NAMES[logAction] || '', logQ ? `关键词：${logQ}` : ''].filter(Boolean).join(' · ');
        setMsg('logMsg', `${scope ? `${scope} · ` : ''}共 ${data.total || 0} 条日志`, 'ok');
      }
      async function scanCurrentLinks() {
        const ids = state.contentRows.map((r) => Number(r.id)).filter(Boolean);
        if (!ids.length) return setMsg('contentMsg', '当前列表没有资源', 'error');
        setMsg('contentMsg', `正在扫描 ${ids.length} 条链接（百度较慢，请稍候）...`);
        try {
          const data = await api('/api/admin/scan-links', json('POST', { ids }));
          for (const r of data.results || []) state.linkStatus[r.id] = r.status;
          renderContentRows();
          const s = data.summary || {};
          setMsg('contentMsg', `扫描完成：有效 ${s.ok || 0} · 失效 ${s.dead || 0} · 未知 ${s.unknown || 0}`, s.dead ? 'error' : 'ok');
        } catch (e) { setMsg('contentMsg', e.message || '扫描失败', 'error'); }
      }
      $('logRefresh').onclick = () => { loadLogs(); };
      $('logSearch').onclick = () => { state.logPage = 1; loadLogs(); };
      $('logClear').onclick = () => { $('logDate').value = ''; $('logAction').value = 'all'; $('logQ').value = ''; state.logPage = 1; loadLogs(); };
      $('logToday').onclick = () => { $('logDate').value = localDateStr(0); state.logPage = 1; loadLogs(); };
      $('logDate').onchange = () => { state.logPage = 1; loadLogs(); };
      $('logAction').onchange = () => { state.logPage = 1; loadLogs(); };
      $('logQ').onkeydown = (e) => { if (e.key === 'Enter') { e.preventDefault(); state.logPage = 1; loadLogs(); } };
      $('scanLinks').onclick = scanCurrentLinks;

      $('refreshAll').onclick = () => Promise.all([loadStats(), loadCategories()]);
      $('quickNew').onclick = () => { setView('contents'); resetContentForm(); openDrawer(); };
      $('quickCategory').onclick = () => { setView('categories'); resetCategoryForm(); };
      $('quickFeedback').onclick = () => setView('feedback');
      const _addRoot = $('addUploadRootCategory'); if (_addRoot) _addRoot.onclick = () => { setView('categories'); resetCategoryForm(0); };
      const _addChild = $('addUploadChildCategory'); if (_addChild) _addChild.onclick = () => { setView('categories'); resetCategoryForm(Number($('fCategory').value || state.activeCategoryId || 0)); };
      $('newRootCategory').onclick = () => resetCategoryForm(0);
      $('resetCategory').onclick = () => resetCategoryForm();
      $('categoryQ').oninput = () => renderCategories();
      $('categoryClear').onclick = () => { $('categoryQ').value = ''; renderCategories(); };
      $('newChildCategory').onclick = () => resetCategoryForm(Number($('catId').value || 0));
      $('categoryForm').onsubmit = saveCategory;
      $('deleteCategory').onclick = deleteCategory;
      $('saveCategorySort').onclick = saveCategorySort;
      $('newContent').onclick = () => { resetContentForm(); openDrawer(); };
      $('closeEditor').onclick = resetContentForm;
      $('drawerClose').onclick = closeDrawer;
      $('drawerOverlay').onclick = closeAllDrawers;
      $('batchClose').onclick = closeBatch;
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeDrawer(); });
      $('contentSearch').onclick = () => { state.contentPage = 1; loadContents(); };
      $('contentReset').onclick = () => { $('contentQ').value = ''; $('contentField').value = 'all'; $('contentFormat').value = ''; $('contentCategory').value = '0'; $('contentStatus').value = 'all'; $('contentOrder').value = 'newest'; state.activeCategoryId = 0; state.contentPage = 1; renderCategoryTree(); loadContents(); };
      $('contentCategory').onchange = () => { state.activeCategoryId = Number($('contentCategory').value || 0); renderCategoryTree(); state.contentPage = 1; loadContents(); };
      $('contentField').onchange = () => { state.contentPage = 1; loadContents(); };
      $('contentFormat').onchange = () => { state.contentPage = 1; loadContents(); };
      $('contentStatus').onchange = loadContents;
      $('contentOrder').onchange = loadContents;
      $('contentLimit').onchange = loadContents;
      $('contentForm').onsubmit = saveContent;
      $('fNetdiskRaw').oninput = applyNetdiskParse;
      $('fAssetKind').onchange = syncUploadType;
      $('fModelFormat').onchange = syncUploadType;
      $('hideContent').onclick = hideCurrentContent;
      $('copyResourceUrl').onclick = async () => { await navigator.clipboard?.writeText($('fFileUrl').value || ''); setMsg('contentMsg', $('fFileUrl').value ? '已复制下载链接' : '下载链接为空', $('fFileUrl').value ? 'ok' : 'error'); };
      $('checkAllContents').onchange = (event) => { state.selectedContentIds.clear(); if (event.currentTarget.checked) for (const row of state.contentRows) state.selectedContentIds.add(Number(row.id)); state.lastCheckIndex = -1; renderContentRows(); };
      $('batchSelectAll').onclick = () => { for (const row of state.contentRows) state.selectedContentIds.add(Number(row.id)); renderContentRows(); };
      $('batchSelectNone').onclick = () => { state.selectedContentIds.clear(); state.lastCheckIndex = -1; renderContentRows(); };
      $('batchMove').onclick = () => batchContent('move');
      $('batchType').onclick = () => batchContent('type');
      $('batchBulkShow').onclick = () => batchContent('show');
      $('batchHide').onclick = () => batchContent('hide');
      $('batchDelete').onclick = () => batchContent('delete');
      bindFilePicker('catCoverPick', 'catCoverUpload');
      bindFilePicker('coverPick', 'coverUpload');
      bindFilePicker('resourcePick', 'resourceUpload');
      bindFilePicker('noticePopupPick', 'noticePopupUpload');
      $('catCoverUpload').onchange = (event) => handleUpload(event.currentTarget, 'cover', 'catCover');
      $('coverUpload').onchange = (event) => handleUpload(event.currentTarget, 'cover', 'fCover');
      $('resourceUpload').onchange = (event) => handleUpload(event.currentTarget, 'resource', 'fFileUrl');
      $('noticePopupUpload').onchange = (event) => uploadNoticePopupImage(event.currentTarget);
      $('noticePopupImage').oninput = () => {
        const url = $('noticePopupImage').value.trim();
        $('noticePopupPreview').src = url;
        $('noticePopupPreview').style.display = url ? 'block' : 'none';
      };
      $('noticeAddVersion').onclick = () => addNotice('version');
      $('noticeAddOfficial').onclick = () => addNotice('official');
      $('noticeReload').onclick = loadNotices;
      $('noticeSave').onclick = saveNotices;
      $('batchPick').onchange = (event) => { addBatchFiles(event.currentTarget.files); event.currentTarget.value = ''; };
      $('batchPickDir').onchange = (event) => { addBatchFiles(event.currentTarget.files); event.currentTarget.value = ''; };
      $('batchModelFormat').onchange = () => {
        const format = $('batchModelFormat').value || 'SU';
        const kind = assetKindForFormat(format, $('batchAssetKind').value || 'model');
        if (kind !== $('batchAssetKind').value) $('batchAssetKind').value = kind;
        if (format === 'PSD') {
          const id = ensurePsdCategory('batchCategory');
          if (id) $('batchCatSelected').textContent = '已选：' + categoryPathName(id);
        }
        for (const item of state.batchItems) {
          if (!item.fileType) item.fileType = fileTypeForFormat(format);
          item.modelFormat = inferModelFormatFromType(item.fileType, format);
        }
        renderBatchRows();
      };
      $('batchClear').onclick = () => { state.batchItems.forEach((it) => { if (it.preview) URL.revokeObjectURL(it.preview); }); state.batchItems = []; renderBatchRows(); };
      $('batchSortName').onclick = () => sortBatch('name');
      $('batchSortTime').onclick = () => sortBatch('time');
      $('batchApplyText').onclick = applyBatchText;
      $('batchApplyName').onclick = applyBatchNaming;
      $('batchApplySummary').onclick = applyBatchSummaryAll;
      $('batchCatSearch').oninput = (e) => renderBatchCatList(e.currentTarget.value);
      $('batchTxt').onchange = async (event) => { const f = event.currentTarget.files?.[0]; if (f) { $('batchBulk').value = await f.text(); setMsg('contentMsg', `已读取 ${f.name}，点「解析并配对」`, 'ok'); } event.currentTarget.value = ''; };
      $('batchOpen').onclick = () => openBatch();
      $('batchImport').onclick = async () => {
        const btn = $('batchImport');
        if (btn.disabled) return;
        btn.disabled = true;
        const oldText = btn.textContent;
        btn.textContent = '正在导入…';
        try {
          await batchImportResources();
        } catch (error) {
          console.error('[batch import failed]', error);
          setBatchMsg(error.message || '批量导入失败', 'error');
        } finally {
          btn.disabled = false;
          btn.textContent = oldText || '压缩并导入';
        }
      };
      $('feedbackSearch').onclick = () => { state.feedbackPage = 1; loadFeedback(); };
      $('feedbackRefresh').onclick = loadFeedback;
      $('feedbackReset').onclick = () => { $('feedbackQ').value = ''; $('feedbackStatus').value = 'all'; state.feedbackPage = 1; loadFeedback(); };

      bootstrap();
    </script>
  </body>
</html>
