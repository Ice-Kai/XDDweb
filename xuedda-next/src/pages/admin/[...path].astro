---
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>后台管理 — 薛大大设计网</title>
    <style>
      body { margin:0; font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:#f6f4ef; color:#191714; }
      .wrap { max-width:1180px; margin:0 auto; padding:30px 18px; }
      .top { display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:18px; }
      .panel { background:#fff; border:1px solid #e4ded2; border-radius:10px; padding:20px; box-shadow:0 12px 30px rgba(50,35,10,.06); }
      input,textarea,select { width:100%; box-sizing:border-box; border:1px solid #ddd5c8; border-radius:8px; padding:10px 12px; font:inherit; margin:6px 0 12px; background:#fff; }
      button { border:0; border-radius:8px; padding:10px 16px; background:#c9963c; color:#100b02; font-weight:700; cursor:pointer; }
      table { width:100%; border-collapse:collapse; margin-top:12px; font-size:14px; }
      th,td { border-bottom:1px solid #eee8dc; padding:10px; text-align:left; }
      .muted { color:#776f64; font-size:13px; }
      .grid { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:16px; }
      .stat b { display:block; font-size:28px; }
      .hide { display:none; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="top">
        <div><h1>后台管理</h1><p class="muted">先恢复核心内容管理，复杂上传和媒体库后续继续补齐。</p></div>
        <button id="logout" class="hide">退出</button>
      </div>
      <div id="login" class="panel">
        <h2>管理员登录</h2>
        <input id="u" placeholder="账号" />
        <input id="p" type="password" placeholder="密码" />
        <p id="err" class="muted"></p>
        <button id="loginBtn">登录</button>
      </div>
      <div id="app" class="hide">
        <div class="grid">
          <div class="panel stat"><b id="sResources">-</b><span>资源</span></div>
          <div class="panel stat"><b id="sCategories">-</b><span>分类</span></div>
          <div class="panel stat"><b id="sMembers">-</b><span>会员</span></div>
        </div>
        <div class="panel">
          <h2>资源列表</h2>
          <input id="q" placeholder="搜索标题" />
          <button id="search">搜索</button>
          <table><thead><tr><th>ID</th><th>标题</th><th>分类</th><th>状态</th></tr></thead><tbody id="rows"></tbody></table>
        </div>
      </div>
    </div>
    <script>
      const $ = (id) => document.getElementById(id);
      async function api(url, opts) {
        const r = await fetch(url, { credentials:'include', ...opts });
        const j = await r.json();
        if (!r.ok || !j.ok) throw new Error(j.message || '请求失败');
        return j;
      }
      async function load() {
        try {
          await api('/api/admin/me');
          $('login').classList.add('hide'); $('app').classList.remove('hide'); $('logout').classList.remove('hide');
          const stats = await api('/api/admin/stats');
          $('sResources').textContent = stats.stats.resources; $('sCategories').textContent = stats.stats.categories; $('sMembers').textContent = stats.stats.members;
          await loadRows();
        } catch { $('login').classList.remove('hide'); $('app').classList.add('hide'); }
      }
      async function loadRows() {
        const data = await api('/api/admin/contents?q=' + encodeURIComponent($('q').value || ''));
        $('rows').innerHTML = data.rows.map((r) => `<tr><td>${r.id}</td><td>${r.title}</td><td>${r.category_id}</td><td>${r.is_show ? '显示' : '隐藏'}</td></tr>`).join('');
      }
      $('loginBtn').onclick = async () => {
        try { await api('/api/admin/login', { method:'POST', headers:{'content-type':'application/json'}, body:JSON.stringify({ username:$('u').value, password:$('p').value }) }); load(); }
        catch(e) { $('err').textContent = e.message; }
      };
      $('logout').onclick = async () => { await fetch('/api/admin/logout', { method:'POST', credentials:'include' }); location.reload(); };
      $('search').onclick = loadRows;
      load();
    </script>
  </body>
</html>
