        const sizePart = parts.find((part) => /^\d+(?:\.\d+)?\s*(?:GB|MB|KB|G|M)$/i.test(part));
        const passPart = parts.find((part) => /^(?:[A-Za-z0-9]{4}|提取码|访问码|密码|pwd|pass|code)/i.test(part));
        const summaryPart = parts.find((part) => /^(?:简介|摘要|说明|描述)[:：]/.test(part));
