      function parseShareText(value) {
        const raw = text(value).trim();
        if (!raw) return { url:'', pass:'', title:'', size:'', summary:'' };
        const urlMatch = raw.match(/https?:\/\/[^\s|，,；;]+/i);
        const passMatch = raw.match(/(?:提取码|访问码|密码|pwd|pass|code)[:：\s]*([A-Za-z0-9]{3,12})/i) || raw.match(/[?&]pwd=([A-Za-z0-9]{3,12})/i);
        const sizeMatch = raw.match(/(\d+(?:\.\d+)?\s*(?:GB|MB|KB|G|M))/i);
        const summaryMatch = raw.match(/(?:简介|摘要|说明|描述)[:：]\s*([^|；;\n]+)/i);
        const sharedFileMatch = raw.match(/(?:通过网盘分享的文件|分享的文件|文件名|名称)[:：]\s*([^\n\r]+?)(?=\s*(?:链接|https?:\/\/|提取码|访问码|密码|--|，|,|；|;|$))/i);
        const title = raw
          .replace(sharedFileMatch?.[0] || '', '')
          .replace(urlMatch?.[0] || '', '')
          .replace(passMatch?.[0] || '', '')
          .replace(sizeMatch?.[0] || '', '')
          .replace(summaryMatch?.[0] || '', '')
          .replace(/--?来自百度网盘.*$/i, '')
          .replace(/[|，,；;]+/g, ' ')
          .replace(/\s+/g, ' ')
          .trim();
        return {
          url: urlMatch?.[0] || '',
          pass: passMatch?.[1] || '',
          title: sharedFileMatch?.[1]?.trim() || title,
          size: sizeMatch?.[1] || '',
          summary: summaryMatch?.[1]?.trim() || '',
