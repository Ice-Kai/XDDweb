---
import Base from '../../layouts/Base.astro';
---

<Base title="会员注册 - 薛大大设计网">
  <section class="auth-page">
    <form class="auth-card" id="registerForm">
      <p class="section-label">MEMBER</p>
      <h1>注册会员</h1>
      <input name="username" placeholder="用户名 / 邮箱 / 手机号" autocomplete="username" required />
      <input name="password" type="password" placeholder="密码至少 6 位" autocomplete="new-password" required />
      <div class="auth-captcha">
        <input type="hidden" name="captchaToken" id="captchaToken" />
        <input name="captchaAnswer" id="captchaAnswer" inputmode="numeric" autocomplete="off" placeholder="输入验证码" required />
        <button id="captchaRefresh" type="button">加载中</button>
      </div>
      <label class="auth-agree">
        <input type="checkbox" name="agreementAccepted" value="1" required />
        <span>我已阅读并同意 <a href="/terms" target="_blank" rel="noopener">《用户协议与素材使用规则》</a></span>
      </label>
      <p class="auth-error" id="err"></p>
      <button class="btn-primary" type="submit">同意并继续</button>
      <div class="auth-oauth" aria-label="第三方登录">
        <a href="/api/member/oauth/qq/start">QQ 登录</a>
        <a href="/api/member/oauth/wechat/start">微信登录</a>
      </div>
      <div class="auth-links">
        <a href="/member/login">已有账号？去登录</a>
      </div>
    </form>
  </section>
  <script>
    const token = document.getElementById('captchaToken') as HTMLInputElement | null;
    const answer = document.getElementById('captchaAnswer') as HTMLInputElement | null;
    const refresh = document.getElementById('captchaRefresh') as HTMLButtonElement | null;
    async function loadCaptcha() {
      if (!token || !answer || !refresh) return;
      refresh.textContent = '刷新中';
      answer.value = '';
      try {
        const res = await fetch('/api/member/captcha', { credentials: 'include' });
        const json = await res.json();
        token.value = json.token || '';
        refresh.textContent = json.question || '刷新验证码';
      } catch {
        token.value = '';
        refresh.textContent = '刷新验证码';
      }
    }
    refresh?.addEventListener('click', loadCaptcha);
    loadCaptcha();

    document.getElementById('registerForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.currentTarget as HTMLFormElement;
      const err = document.getElementById('err');
      const data = Object.fromEntries(new FormData(form).entries());
      if (!data.agreementAccepted) {
        if (err) err.textContent = '请先阅读并同意用户协议。';
        return;
      }
      const res = await fetch('/api/member/register', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (!res.ok || !json.ok) {
        if (err) err.textContent = json.message || '注册失败';
        if (json.captcha) loadCaptcha();
        return;
      }
      location.href = '/';
    });
  </script>
</Base>
