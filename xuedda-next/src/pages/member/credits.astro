---
import Base from '../../layouts/Base.astro';
---
<Base title="创作积分 - 薛大大设计网">
  <main class="credit-page container">
    <header class="credit-head">
      <p>AI CREDITS</p>
      <h1>创作积分</h1>
      <span>充值积分用于 AI 生图与后续 AI 功能，素材下载继续免费。</span>
    </header>

    <section class="credit-hero" aria-labelledby="balanceLabel">
      <div class="balance-copy">
        <span id="balanceLabel">当前可用积分</span>
        <div class="balance-line"><strong id="balance">--</strong><b>积分</b></div>
        <em>AI 生图最低 <b id="generationCost">15</b> 积分/次，实际按模型与清晰度计费</em>
      </div>
      <div class="hero-actions">
        <a href="#topup" class="topup-cta">立即充值</a>
        <a href="/ai-image" class="create-link">进入 AI 创作</a>
      </div>
    </section>

    <section class="topup-section" id="topup" aria-labelledby="topupTitle">
      <div class="section-heading">
        <div>
          <small>TOP UP</small>
          <h2 id="topupTitle">充值积分</h2>
          <p>输入任意金额，微信扫码支付，成功后积分自动到账。</p>
        </div>
        <span class="payment-badge">微信支付</span>
      </div>

      <div class="topup-body">
        <form class="custom-form" id="customTopupForm" novalidate>
          <label for="customAmount">充值金额（元）</label>
          <div class="amount-field">
            <span>¥</span>
            <input id="customAmount" name="amount" type="text" inputmode="decimal" autocomplete="off" placeholder="1.00 - 5000.00" aria-describedby="customPreview customMessage" />
          </div>
          <div class="quick-amounts" aria-label="快捷充值金额">
            <button type="button" data-amount="10">¥10</button>
            <button type="button" data-amount="30">¥30</button>
            <button type="button" data-amount="50">¥50</button>
            <button type="button" data-amount="100">¥100</button>
            <button type="button" data-amount="200">¥200</button>
            <button type="button" data-amount="500">¥500</button>
          </div>
          <div class="credits-preview" id="customPreview"><span>输入金额后显示到账积分</span></div>
          <button class="custom-buy" id="customBuy" type="submit">微信扫码充值</button>
          <output id="customMessage" aria-live="polite"></output>
        </form>

        <aside class="rate-card">
          <small>RATE</small>
          <div class="rate-num"><strong>100</strong><span>积分 / 元</span></div>
          <ul>
            <li>按微信实付金额到账，<b>1 元 = 100 积分</b></li>
            <li>支持 ¥1.00 - ¥5000.00，最多两位小数</li>
            <li>生图失败自动退还本次积分</li>
          </ul>
        </aside>
      </div>

      <p class="payment-note">二维码有效期 15 分钟。订单金额与到账积分由服务器校验，请勿向陌生人转账。</p>
    </section>

    <section class="utility-grid">
      <article class="redeem-panel">
        <small>REDEEM</small>
        <h2>卡密兑换</h2>
        <p>已有积分卡密？输入完整卡密后立即到账。</p>
        <form id="redeemForm">
          <input id="redeemCode" autocomplete="off" placeholder="XD-AB12CD34-EF56GH78" maxlength="80" />
          <button>兑换</button>
        </form>
        <output id="redeemMessage" aria-live="polite"></output>
      </article>
      <article class="rules-panel">
        <small>HOW IT WORKS</small>
        <h2>积分说明</h2>
        <ol>
          <li><b>1</b><span>输入充值金额，微信扫码支付</span></li>
          <li><b>2</b><span>支付结果确认后积分自动进入当前账号</span></li>
          <li><b>3</b><span>生图失败时，系统自动退还本次消耗积分</span></li>
        </ol>
      </article>
    </section>

    <section class="ledger">
      <header>
        <div><small>HISTORY</small><h2>积分明细</h2></div>
        <button id="reload" type="button">刷新</button>
      </header>
      <div class="table-wrap">
        <table>
          <thead><tr><th>时间</th><th>事项</th><th>变动</th><th>余额</th></tr></thead>
          <tbody id="ledger"><tr><td colspan="4">正在读取积分明细...</td></tr></tbody>
        </table>
      </div>
    </section>

    <div class="recharge-mask" id="rechargeMask" hidden>
      <section class="recharge-dialog" role="dialog" aria-modal="true" aria-labelledby="rechargeTitle">
        <button class="recharge-close" id="rechargeClose" type="button" aria-label="关闭">×</button>
        <small>WECHAT PAY</small>
        <h2 id="rechargeTitle">微信扫码充值</h2>
        <p id="rechargeProduct">请输入充值金额</p>
        <div class="pay-loading" id="payLoading">正在创建安全支付订单...</div>
        <img id="payQr" src="" alt="微信支付二维码" hidden />
        <span id="payStatus">打开微信扫一扫，二维码 15 分钟内有效，支付后积分自动到账。</span>
        <code id="payOrder"></code>
      </section>
    </div>
  </main>

  <style is:global>
    .credit-page{max-width:1180px;padding-top:108px;padding-bottom:80px;color:var(--text-hi)}
    .credit-head{margin-bottom:24px}
    .credit-head p,.credit-page small{margin:0;color:var(--gold);font-family:var(--font-mono);font-size:11px;font-weight:800;letter-spacing:.16em}
    .credit-head h1{margin:7px 0 8px;font-size:36px;letter-spacing:0}
    .credit-head span{color:var(--text-lo);font-size:14px}
    .credit-hero{display:flex;align-items:center;justify-content:space-between;gap:32px;padding:32px 36px;border:1px solid var(--gold-border);border-radius:8px;background:linear-gradient(110deg,var(--bg-card) 0%,var(--gold-pale) 100%);box-shadow:var(--shadow-card)}
    .balance-copy>span,.balance-copy em{display:block;color:var(--text-lo);font-size:13px;font-style:normal}
    .balance-line{display:flex;align-items:baseline;gap:9px;margin:6px 0 8px}
    .balance-line strong{font-family:var(--font-mono);font-size:48px;line-height:1}
    .balance-line>b{color:var(--gold);font-size:13px}
    .balance-copy em b{color:var(--gold)}
    .hero-actions{display:flex;align-items:center;gap:10px}
    .topup-cta,.create-link{display:grid;place-items:center;height:44px;padding:0 21px;border-radius:7px;font-size:14px;font-weight:900;transition:transform .18s ease,box-shadow .18s ease}
    .topup-cta{background:var(--gold);color:#171006;box-shadow:0 8px 22px rgba(200,145,39,.22)}
    .create-link{border:1px solid var(--border);background:var(--bg-card);color:var(--text-hi)}
    .topup-cta:hover,.create-link:hover{transform:translateY(-2px)}
    .topup-section{scroll-margin-top:88px;margin-top:18px;padding:26px;border:1px solid var(--border);border-radius:8px;background:var(--bg-card);box-shadow:var(--shadow-card)}
    .section-heading{display:flex;align-items:flex-start;justify-content:space-between;gap:20px}
    .section-heading h2,.utility-grid h2,.ledger h2{margin:5px 0 0;font-size:20px}
    .section-heading p{margin:7px 0 0;color:var(--text-lo);font-size:13px}
    .payment-badge{padding:6px 9px;border:1px solid var(--gold-border);border-radius:6px;color:var(--gold);background:var(--gold-pale);font-size:12px;font-weight:800;white-space:nowrap}
    .topup-body{display:grid;grid-template-columns:minmax(0,1.35fr) minmax(240px,.65fr);gap:22px;margin-top:22px}
    .custom-form{display:flex;flex-direction:column;gap:14px;padding:24px;border:1px solid var(--gold-border);border-radius:10px;background:linear-gradient(150deg,var(--gold-pale),var(--bg-elevated) 70%)}
    .custom-form>label{color:var(--text-md);font-size:12px;font-weight:800;letter-spacing:.02em}
    .amount-field{display:flex;height:64px;align-items:center;border:1px solid var(--border);border-radius:9px;background:var(--bg-card);transition:border-color .18s ease,box-shadow .18s ease}
    .amount-field:focus-within{border-color:var(--gold);box-shadow:0 0 0 3px rgba(200,145,39,.14)}
    .amount-field span{display:grid;width:52px;place-items:center;border-right:1px solid var(--border);color:var(--gold);font:900 22px var(--font-mono)}
    .amount-field input{width:100%;height:100%;min-width:0;padding:0 16px;border:0;outline:0;background:transparent;color:var(--text-hi);font:800 28px var(--font-mono)}
    .quick-amounts{display:grid;grid-template-columns:repeat(6,1fr);gap:8px}
    .quick-amounts button{height:42px;padding:0 6px;border:1px solid var(--border);border-radius:7px;background:var(--bg-card);color:var(--text-md);font:800 13px var(--font-mono);cursor:pointer;transition:border-color .15s ease,color .15s ease,background .15s ease}
    .quick-amounts button:hover,.quick-amounts button.active{border-color:var(--gold);color:var(--gold);background:var(--gold-pale)}
    .credits-preview{display:flex;align-items:baseline;gap:8px;min-height:30px;padding:12px 14px;border:1px dashed var(--gold-border);border-radius:8px;background:var(--bg-card);color:var(--text-lo);font-size:13px}
    .credits-preview b{color:var(--gold);font-family:var(--font-mono);font-size:24px;font-weight:900}
    .custom-buy{height:52px;border:0;border-radius:9px;background:var(--gold);color:#171006;font:900 16px var(--font-base);cursor:pointer;box-shadow:0 10px 26px rgba(200,145,39,.24);transition:transform .16s ease,filter .16s ease}
    .custom-buy:hover{transform:translateY(-2px);filter:brightness(1.05)}
    .custom-buy:disabled{cursor:wait;opacity:.55;transform:none;box-shadow:none}
    .custom-form output{display:block;min-height:16px;color:var(--text-lo);font-size:12px}
    .custom-form output.error{color:#ca553f}
    .rate-card{display:flex;flex-direction:column;gap:12px;padding:24px;border:1px solid var(--border);border-radius:10px;background:var(--bg-elevated)}
    .rate-num{display:flex;align-items:baseline;gap:8px}
    .rate-num strong{font-family:var(--font-mono);font-size:46px;line-height:1;color:var(--gold)}
    .rate-num span{color:var(--text-lo);font-size:13px}
    .rate-card ul{display:grid;gap:10px;margin:6px 0 0;padding:0;list-style:none}
    .rate-card li{position:relative;padding-left:18px;color:var(--text-md);font-size:12.5px;line-height:1.6}
    .rate-card li::before{content:"";position:absolute;left:0;top:8px;width:6px;height:6px;border-radius:50%;background:var(--gold)}
    .rate-card li b{color:var(--gold)}
    .payment-note{margin:16px 0 0;color:var(--text-lo);font-size:11px;line-height:1.6}
    .utility-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px}
    .redeem-panel,.rules-panel,.ledger{border:1px solid var(--border);border-radius:8px;background:var(--bg-card);box-shadow:var(--shadow-card)}
    .redeem-panel,.rules-panel{padding:22px}
    .redeem-panel p{margin:12px 0;color:var(--text-md);font-size:13px}
    .redeem-panel form{display:flex;gap:8px}
    .redeem-panel input{min-width:0;flex:1;height:42px;padding:0 12px;border:1px solid var(--border);border-radius:7px;background:var(--bg-elevated);color:var(--text-hi);font:13px var(--font-mono)}
    .redeem-panel form button{height:42px;padding:0 18px;border:0;border-radius:7px;background:var(--text-hi);color:var(--bg-card);font:800 13px var(--font-base);cursor:pointer}
    .redeem-panel output{display:block;min-height:20px;margin-top:9px;color:var(--text-lo);font-size:12px}
    .redeem-panel output.error{color:#ca553f}.redeem-panel output.ok{color:#16865a}
    .rules-panel ol{display:grid;gap:10px;margin:15px 0 0;padding:0;list-style:none}
    .rules-panel li{display:flex;align-items:center;gap:10px;color:var(--text-md);font-size:13px}
    .rules-panel li b{display:grid;place-items:center;width:24px;height:24px;border:1px solid var(--gold-border);border-radius:50%;color:var(--gold);font-family:var(--font-mono);font-size:11px}
    .ledger{margin-top:14px;overflow:hidden}
    .ledger>header{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:18px 22px;border-bottom:1px solid var(--border)}
    .ledger>header button{height:34px;padding:0 14px;border:1px solid var(--border);border-radius:7px;background:var(--bg-elevated);color:var(--text-md);font:800 13px var(--font-base);cursor:pointer}
    .table-wrap{overflow:auto}.ledger table{width:100%;border-collapse:collapse;font-size:13px}
    .ledger th,.ledger td{padding:13px 22px;border-bottom:1px solid var(--border);color:var(--text-md);text-align:left}
    .ledger th{background:var(--bg-elevated);color:var(--text-lo);font-size:12px}.ledger tr:last-child td{border-bottom:0}
    .plus{color:#16865a!important;font-weight:800}.minus{color:#c55342!important;font-weight:800}
    .recharge-mask{position:fixed;inset:0;z-index:800;display:grid;place-items:center;padding:18px;background:rgba(10,10,12,.62);backdrop-filter:blur(5px)}
    .recharge-mask[hidden]{display:none}.recharge-dialog{position:relative;width:min(390px,100%);padding:28px;border:1px solid var(--border);border-radius:8px;background:var(--bg-card);box-shadow:0 28px 80px rgba(0,0,0,.35);text-align:center}
    .recharge-dialog h2{margin:5px 0 8px;font-size:22px}.recharge-dialog p{color:var(--text-hi);font-weight:800}
    .recharge-dialog img{display:block;width:214px;height:214px;object-fit:contain;margin:16px auto 10px;padding:8px;border:1px solid var(--border);border-radius:7px;background:#fff}
    .recharge-dialog>span{display:block;color:var(--text-lo);font-size:12px;line-height:1.7}.recharge-dialog code{display:block;margin-top:10px;color:var(--text-lo);font-size:10px}
    .pay-loading{display:grid;place-items:center;min-height:214px;margin:16px 0 10px;border:1px dashed var(--border);border-radius:7px;color:var(--text-lo);font-size:13px}
    .recharge-close{position:absolute;top:10px;right:10px;width:32px;height:32px;border:0;border-radius:6px;background:var(--bg-elevated);color:var(--text-md);font-size:20px;cursor:pointer}
    @media(max-width:820px){.topup-body{grid-template-columns:1fr}.utility-grid{grid-template-columns:1fr}}
    @media(max-width:620px){.credit-page{padding:84px 14px 44px}.credit-head h1{font-size:30px}.credit-hero{align-items:flex-start;flex-direction:column;padding:24px}.hero-actions{width:100%}.topup-cta,.create-link{flex:1;padding:0 10px}.topup-section{padding:20px 14px}.section-heading{align-items:center}.custom-form{padding:18px 15px}.amount-field{height:58px}.amount-field input{font-size:24px}.quick-amounts{grid-template-columns:repeat(3,1fr)}.balance-line strong{font-size:42px}.ledger th,.ledger td{padding:12px;white-space:nowrap}}
  </style>

  <script>
    const $ = (id) => document.getElementById(id);
    const txt = (value) => String(value ?? '');
    let paymentTimer = 0;
    let currentOrder = '';

    function amountToFen(value) {
      const normalized = String(value || '').trim();
      if (!/^\d{1,4}(?:\.\d{1,2})?$/.test(normalized)) return 0;
      const [yuan, cents = ''] = normalized.split('.');
      return Number(yuan) * 100 + Number(`${cents}00`.slice(0, 2));
    }

    function updateCustomPreview() {
      const amountFen = amountToFen($('customAmount').value);
      const output = $('customMessage');
      output.className = '';
      output.textContent = '';
      document.querySelectorAll('.quick-amounts button').forEach((button) => {
        button.classList.toggle('active', Number(button.dataset.amount) * 100 === amountFen);
      });
      if (!amountFen) {
        $('customPreview').innerHTML = '<span>输入金额后显示到账积分</span>';
        return 0;
      }
      if (amountFen < 100 || amountFen > 500000) {
        $('customPreview').innerHTML = '<span>支持 ¥1.00 - ¥5000.00</span>';
        return amountFen;
      }
      $('customPreview').innerHTML = `<span>本次到账</span><b>${amountFen}</b><span>积分</span>`;
      return amountFen;
    }

    async function openRecharge(product, button, requestBody) {
      clearInterval(paymentTimer);
      currentOrder = '';
      $('rechargeProduct').textContent = `${txt(product.name)}：${txt(product.credits)} 积分 / ¥${Number(product.price).toFixed(2)}`;
      $('payLoading').hidden = false;
      $('payLoading').textContent = '正在创建安全支付订单...';
      $('payQr').hidden = true;
      $('payQr').removeAttribute('src');
      $('payStatus').textContent = '打开微信扫一扫，二维码 15 分钟内有效，支付后积分自动到账。';
      $('payOrder').textContent = '';
      $('rechargeMask').hidden = false;
      button.disabled = true;
      try {
        const response = await fetch('/api/member/credit-orders', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(requestBody),
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.ok) throw new Error(data.message || '创建支付订单失败');
        currentOrder = data.orderSn;
        $('payLoading').hidden = true;
        $('payQr').src = data.qrDataUrl;
        $('payQr').hidden = false;
        $('payOrder').textContent = `订单号 ${data.orderSn}`;
        paymentTimer = window.setInterval(checkPayment, 2000);
      } catch (error) {
        $('payLoading').textContent = error instanceof Error ? error.message : '创建支付订单失败';
        $('payStatus').textContent = '请稍后重试或联系网站客服。';
      } finally {
        button.disabled = false;
      }
    }

    async function checkPayment() {
      if (!currentOrder) return;
      const response = await fetch(`/api/member/credit-orders?orderSn=${encodeURIComponent(currentOrder)}`, { credentials: 'include' });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || !data.ok) return;
      const status = data.order?.status;
      if (status === 'paid') {
        clearInterval(paymentTimer);
        $('payQr').hidden = true;
        $('payLoading').hidden = false;
        $('payLoading').textContent = '支付成功，积分已到账';
        $('payStatus').textContent = `本次到账 ${data.order.credits} 积分`;
        $('payOrder').textContent = '';
        await load();
        setTimeout(() => { $('rechargeMask').hidden = true; }, 1800);
      } else if (status === 'closed' || status === 'failed') {
        clearInterval(paymentTimer);
        $('payStatus').textContent = status === 'closed' ? '二维码已过期，请关闭后重新下单。' : '支付订单创建失败，请关闭后重试。';
      }
    }

    function renderLedger(rows) {
      const root = $('ledger');
      root.replaceChildren();
      if (!rows.length) {
        root.innerHTML = '<tr><td colspan="4">暂无积分记录</td></tr>';
        return;
      }
      rows.forEach((row) => {
        const amount = Number(row.amount || 0);
        const tr = document.createElement('tr');
        tr.innerHTML = `<td>${txt(row.created_at)}</td><td>${txt(row.description || row.kind)}</td><td class="${amount >= 0 ? 'plus' : 'minus'}">${amount >= 0 ? '+' : ''}${amount}</td><td>${txt(row.balance_after)}</td>`;
        root.appendChild(tr);
      });
    }

    async function load() {
      const response = await fetch('/api/member/credits', { credentials: 'include' });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || !data.ok) {
        location.href = '/member/login?next=/member/credits';
        return;
      }
      $('balance').textContent = txt(data.balance);
      $('generationCost').textContent = txt(data.minimumGenerationCost);
      renderLedger(data.ledger || []);
    }

    function closeRecharge() {
      clearInterval(paymentTimer);
      currentOrder = '';
      $('rechargeMask').hidden = true;
    }

    $('redeemForm').addEventListener('submit', async (event) => {
      event.preventDefault();
      const output = $('redeemMessage');
      output.className = '';
      output.textContent = '正在兑换...';
      const response = await fetch('/api/member/credits', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ code: $('redeemCode').value }),
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || !data.ok) {
        output.className = 'error';
        output.textContent = data.message || '兑换失败';
        return;
      }
      output.className = 'ok';
      output.textContent = `兑换成功，已到账 ${data.credits} 积分`;
      $('redeemCode').value = '';
      load();
    });

    $('customAmount').addEventListener('input', updateCustomPreview);
    document.querySelectorAll('.quick-amounts button').forEach((button) => {
      button.addEventListener('click', () => {
        $('customAmount').value = Number(button.dataset.amount).toFixed(2);
        updateCustomPreview();
        $('customAmount').focus();
      });
    });
    $('customTopupForm').addEventListener('submit', async (event) => {
      event.preventDefault();
      const amountFen = updateCustomPreview();
      const output = $('customMessage');
      if (amountFen < 100 || amountFen > 500000) {
        output.className = 'error';
        output.textContent = '请输入 1.00 至 5000.00 元之间的有效金额，最多保留两位小数。';
        $('customAmount').focus();
        return;
      }
      const button = $('customBuy');
      await openRecharge({ name: '自定义充值', credits: amountFen, price: amountFen / 100 }, button, { amountFen });
    });

    $('reload').addEventListener('click', load);
    $('rechargeClose').addEventListener('click', closeRecharge);
    $('rechargeMask').addEventListener('click', (event) => {
      if (event.target === $('rechargeMask')) closeRecharge();
    });
    load();
  </script>
</Base>
