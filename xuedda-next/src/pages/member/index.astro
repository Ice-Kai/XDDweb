---
import Base from '../../layouts/Base.astro';
---

<Base title="会员中心 - 薛大大设计网">
  <main class="account-page">
    <div class="container account-shell">
      <header class="account-heading">
        <div>
          <p class="section-label">MEMBER CENTER</p>
          <h1>会员中心</h1>
          <p>集中查看积分、素材下载和 AI 创作任务。</p>
        </div>
        <div class="account-actions">
          <a href="/member/credits">积分充值</a>
          <a href="/api/member/logout?next=/">退出登录</a>
        </div>
      </header>

      <section class="account-overview" aria-label="账户概览">
        <div class="account-person">
          <span class="account-avatar" id="accountAvatar">XD</span>
          <div>
            <strong id="accountName">正在读取账户...</strong>
            <span id="accountLevel">普通会员</span>
          </div>
        </div>
        <dl class="account-metrics">
          <div><dt>可用积分</dt><dd id="creditBalance">0</dd></div>
          <div><dt>今日下载</dt><dd><span id="todayDownloads">0</span><small>/ 30</small></dd></div>
          <div><dt>AI 创作</dt><dd id="generationCount">0</dd></div>
        </dl>
      </section>

      <nav class="account-tabs" aria-label="会员记录">
        <button class="active" type="button" data-tab="downloads">下载记录 <span id="downloadCount">0</span></button>
        <button type="button" data-tab="credits">积分明细</button>
        <button type="button" data-tab="generations">生图记录</button>
      </nav>

      <section class="account-records">
        <div class="record-toolbar">
          <div>
            <strong id="recordTitle">下载记录</strong>
            <span id="recordDescription">最近打开过的素材链接，可随时回查。</span>
          </div>
          <button id="refreshRecords" type="button" title="刷新记录" aria-label="刷新记录">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6v5h-5M4 18v-5h5"/><path d="M18.5 9a7 7 0 0 0-12-2L4 11M5.5 15a7 7 0 0 0 12 2l2.5-4"/></svg>
          </button>
        </div>

        <div class="record-panel active" data-panel="downloads">
          <div class="record-table-wrap">
            <table class="record-table">
              <thead><tr><th class="record-idx-head">#</th><th>素材名称</th><th class="record-action-head">操作</th></tr></thead>
              <tbody id="downloadRows"><tr><td colspan="3" class="record-empty">正在读取下载记录...</td></tr></tbody>
            </table>
          </div>
        </div>

        <div class="record-panel" data-panel="credits" hidden>
          <div class="record-table-wrap">
            <table class="record-table">
              <thead><tr><th>变动说明</th><th>类型</th><th>积分变动</th><th>变动后余额</th><th>时间</th></tr></thead>
              <tbody id="creditRows"><tr><td colspan="5" class="record-empty">正在读取积分明细...</td></tr></tbody>
            </table>
          </div>
        </div>

        <div class="record-panel" data-panel="generations" hidden>
          <div class="record-table-wrap">
            <table class="record-table">
              <thead><tr><th>创作描述</th><th>画幅</th><th>消耗</th><th>提交时间</th><th>状态</th><th>结果</th></tr></thead>
              <tbody id="generationRows"><tr><td colspan="6" class="record-empty">正在读取生图记录...</td></tr></tbody>
            </table>
          </div>
        </div>
      </section>
    </div>
  </main>

  <style>
    .account-page { min-height:calc(100vh - 64px); padding:48px 0 80px; background:var(--bg); }
    .account-shell { max-width:1280px; }
    .account-heading { display:flex; align-items:flex-end; justify-content:space-between; gap:24px; margin-bottom:26px; }
    .account-heading h1 { margin:5px 0 6px; color:var(--text-hi); font-size:32px; line-height:1.2; letter-spacing:0; }
    .account-heading p:last-child { margin:0; color:var(--text-lo); font-size:14px; }
    .account-actions { display:flex; align-items:center; gap:9px; }
    .account-actions a { display:inline-flex; align-items:center; justify-content:center; height:38px; padding:0 15px; border:1px solid var(--border); border-radius:7px; background:var(--bg-elevated); color:var(--text-md); font-size:13px; font-weight:800; }
    .account-actions a:first-child { border-color:var(--gold); background:var(--gold); color:#171006; }
    .account-overview { display:grid; grid-template-columns:minmax(280px,1fr) minmax(520px,.9fr); align-items:stretch; border:1px solid var(--border); border-radius:8px; background:var(--bg-card); box-shadow:var(--shadow-card); overflow:hidden; }
    .account-person { display:flex; align-items:center; gap:15px; min-height:112px; padding:22px 26px; }
    .account-avatar { width:50px; height:50px; display:grid; place-items:center; flex:0 0 50px; border-radius:8px; background:#171717; color:#fff; font-size:13px; font-weight:900; }
    .account-person div { min-width:0; display:flex; flex-direction:column; gap:6px; }
    .account-person strong { overflow:hidden; color:var(--text-hi); font-size:19px; text-overflow:ellipsis; white-space:nowrap; }
    .account-person span:last-child { color:var(--text-lo); font-size:12px; }
    .account-metrics { display:grid; grid-template-columns:repeat(3,1fr); margin:0; border-left:1px solid var(--border); }
    .account-metrics div { display:flex; flex-direction:column; justify-content:center; gap:8px; padding:20px 24px; border-left:1px solid var(--border); }
    .account-metrics div:first-child { border-left:0; }
    .account-metrics dt { color:var(--text-lo); font-size:12px; }
    .account-metrics dd { margin:0; color:var(--text-hi); font-family:var(--font-mono); font-size:25px; font-weight:800; }
    .account-metrics small { margin-left:4px; color:var(--text-lo); font-size:12px; font-weight:500; }
    .account-tabs { display:flex; gap:28px; margin-top:30px; border-bottom:1px solid var(--border); }
    .account-tabs button { position:relative; height:48px; padding:0; border:0; background:none; color:var(--text-lo); font-family:var(--font-base); font-size:14px; font-weight:800; cursor:pointer; }
    .account-tabs button::after { content:''; position:absolute; left:0; right:0; bottom:-1px; height:2px; background:transparent; }
    .account-tabs button.active { color:var(--text-hi); }
    .account-tabs button.active::after { background:var(--gold); }
    .account-tabs span { display:inline-grid; min-width:22px; height:20px; margin-left:5px; padding:0 5px; place-items:center; border-radius:999px; background:var(--bg-elevated); color:var(--text-lo); font-size:11px; }
    .account-records { margin-top:18px; border:1px solid var(--border); border-radius:8px; background:var(--bg-card); box-shadow:var(--shadow-card); overflow:hidden; }
    .record-toolbar { min-height:68px; display:flex; align-items:center; justify-content:space-between; gap:20px; padding:14px 18px; border-bottom:1px solid var(--border); }
    .record-toolbar div { display:flex; flex-direction:column; gap:4px; }
    .record-toolbar strong { color:var(--text-hi); font-size:15px; }
    .record-toolbar span { color:var(--text-lo); font-size:12px; }
    .record-toolbar button { width:36px; height:36px; display:grid; place-items:center; border:1px solid var(--border); border-radius:7px; background:var(--bg-elevated); color:var(--text-md); cursor:pointer; }
    .record-toolbar svg { width:17px; height:17px; fill:none; stroke:currentColor; stroke-width:1.8; }
    .record-toolbar button.loading svg { animation:recordSpin .8s linear infinite; }
    @keyframes recordSpin { to { transform:rotate(360deg); } }
    .record-table-wrap { overflow:auto; }
    .record-table { width:100%; min-width:680px; border-collapse:collapse; font-size:13px; }
    .record-table th { height:42px; padding:0 14px; background:var(--bg-elevated); color:var(--text-lo); font-size:12px; font-weight:800; text-align:left; white-space:nowrap; }
    .record-table td { height:50px; padding:9px 14px; border-top:1px solid var(--border); color:var(--text-md); vertical-align:middle; }
    .record-table tbody tr:nth-child(even) { background:color-mix(in srgb,var(--text-hi) 2.6%,transparent); }
    .record-table tbody tr:hover { background:color-mix(in srgb,var(--gold) 7%,transparent); }
    .record-table td:not(:first-child) { border-left:1px solid color-mix(in srgb,var(--border) 55%,transparent); }
    .record-title { max-width:430px; color:var(--text-hi) !important; font-weight:800; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .record-idx-head { width:56px; }
    .record-idx { width:56px; color:var(--text-lo) !important; font-family:var(--font-mono,monospace); font-weight:700; text-align:center; }
    .record-title-doc::before { content:"📄"; margin-right:8px; opacity:.7; font-size:13px; }
    .record-action-head { width:128px; }
    .record-tag,.record-status { display:inline-flex; align-items:center; min-height:24px; padding:2px 8px; border-radius:5px; background:var(--bg-elevated); color:var(--text-md); font-size:11px; font-weight:700; white-space:nowrap; }
    .record-status.success { background:rgba(26,160,91,.1); color:#15945a; }
    .record-status.waiting { background:rgba(201,150,60,.12); color:var(--gold); }
    .record-status.failed { background:rgba(205,65,65,.1); color:#c94141; }
    .record-delta.plus { color:#15945a; font-weight:900; }
    .record-delta.minus { color:#c94141; font-weight:900; }
    .record-link { display:inline-flex; align-items:center; justify-content:center; height:30px; padding:0 10px; border:1px solid var(--gold-border); border-radius:6px; background:var(--gold-soft); color:var(--gold); font-size:12px; font-weight:800; }
    .record-link.disabled { opacity:.42; pointer-events:none; }
    .record-error { max-width:380px; color:#c94141 !important; font-size:12px; line-height:1.45; }
    .record-empty { height:110px !important; text-align:center; color:var(--text-lo) !important; }
    @media (max-width:820px) {
      .account-page { padding:22px 0 92px; }
      .account-shell { width:100%; padding:0 14px; }
      .account-heading { align-items:flex-start; margin-bottom:18px; }
      .account-heading h1 { font-size:25px; }
      .account-heading p:last-child { display:none; }
      .account-actions a:first-child { display:none; }
      .account-overview { grid-template-columns:1fr; }
      .account-person { min-height:86px; padding:16px; }
      .account-metrics { border-top:1px solid var(--border); border-left:0; }
      .account-metrics div { padding:15px 12px; text-align:center; }
      .account-metrics dd { font-size:20px; }
      .account-tabs { gap:20px; overflow-x:auto; }
      .account-tabs button { flex:0 0 auto; }
      .record-toolbar { min-height:62px; }
      .record-table { min-width:620px; }
    }
  </style>

  <script>
    const descriptions = {
      downloads: ['下载记录', '最近打开过的素材链接，可随时回查。'],
      credits: ['积分明细', '充值、兑换、生图消费和失败退款都会完整记录。'],
      generations: ['生图记录', '查看 AI 任务状态、积分消耗和失败原因。'],
    };
    const state = { downloads: [], credits: [], generations: [] };
    const qs = (selector) => document.querySelector(selector);
    const text = (value) => String(value ?? '');
    const escapeTime = (value) => text(value).replace('T', ' ').slice(0, 19) || '--';

    function td(value, className = '') {
      const node = document.createElement('td');
      node.className = className;
      node.textContent = text(value);
      return node;
    }
    function empty(tbody, colspan, message) {
      tbody.replaceChildren();
      const row = document.createElement('tr');
      const cell = td(message, 'record-empty');
      cell.colSpan = colspan;
      row.append(cell);
      tbody.append(row);
    }
    function badge(value, className = '') {
      const span = document.createElement('span');
      span.className = `record-status ${className}`.trim();
      span.textContent = value;
      return span;
    }
    function renderDownloads() {
      const tbody = document.getElementById('downloadRows');
      if (!tbody) return;
      tbody.replaceChildren();
      if (!state.downloads.length) return empty(tbody, 3, '还没有下载记录。');
      state.downloads.forEach((item, index) => {
        const row = document.createElement('tr');
        row.append(td(String(index + 1), 'record-idx'));
        row.append(td(item.title || '资源已下架', 'record-title record-title-doc'));
        const action = td('');
        const link = document.createElement('a');
        link.className = item.available && item.contentId ? 'record-link btn-dl' : 'record-link disabled';
        link.href = '#';
        link.textContent = item.available && item.contentId ? '打开链接' : '不可用';
        if (item.available && item.contentId) { link.dataset.downloadId = item.contentId; link.dataset.title = item.title || '资源下载'; }
        action.append(link); row.append(action); tbody.append(row);
      });
    }
    function renderCredits() {
      const tbody = document.getElementById('creditRows');
      if (!tbody) return;
      tbody.replaceChildren();
      if (!state.credits.length) return empty(tbody, 5, '还没有积分变动记录。');
      const kindNames = { redeem:'卡密兑换', generation:'AI 生图', refund:'失败退款', admin:'后台调整', purchase:'积分充值' };
      state.credits.forEach((item) => {
        const row = document.createElement('tr');
        row.append(td(item.description || '积分变动', 'record-title'));
        const kind = td(''); kind.append(badge(kindNames[item.kind] || item.kind || '积分')); row.append(kind);
        const amount = Number(item.amount || 0); row.append(td(`${amount > 0 ? '+' : ''}${amount}`, `record-delta ${amount >= 0 ? 'plus' : 'minus'}`));
        row.append(td(item.balance_after ?? '--')); row.append(td(escapeTime(item.created_at))); tbody.append(row);
      });
    }
    function renderGenerations() {
      const tbody = document.getElementById('generationRows');
      if (!tbody) return;
      tbody.replaceChildren();
      if (!state.generations.length) return empty(tbody, 6, '还没有 AI 生图记录。');
      const statusNames = { processing:'生成中', completed:'已完成', failed:'生成失败', cancelled:'已取消' };
      state.generations.forEach((item) => {
        const row = document.createElement('tr');
        row.append(td(item.prompt || '未命名任务', item.error ? 'record-error' : 'record-title'));
        row.append(td(item.ratio || '--')); row.append(td(`${Number(item.creditCost || 0)} 积分`)); row.append(td(escapeTime(item.createdAt)));
        const status = td(''); const statusClass = item.status === 'completed' ? 'success' : item.status === 'processing' ? 'waiting' : 'failed'; status.append(badge(statusNames[item.status] || item.status, statusClass)); row.append(status);
        const result = td('');
        if (item.image) { const link = document.createElement('a'); link.className = 'record-link'; link.href = item.image; link.target = '_blank'; link.rel = 'noopener'; link.textContent = '查看图片'; result.append(link); }
        else result.textContent = item.error || (item.status === 'processing' ? '正在生成' : '--');
        if (item.error) result.className = 'record-error';
        row.append(result); tbody.append(row);
      });
    }
    async function jsonFetch(url) {
      const response = await fetch(url, { credentials:'include', cache:'no-store' });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(data.message || '请求失败');
      return data;
    }
    async function loadAll() {
      const refresh = document.getElementById('refreshRecords');
      refresh?.classList.add('loading');
      try {
        const me = await jsonFetch('/api/member/me');
        if (!me.member) { location.href = '/member/login?next=/member'; return; }
        const [downloads, credits, generations] = await Promise.allSettled([
          jsonFetch('/api/member/downloads?limit=50'),
          jsonFetch('/api/member/credits'),
          jsonFetch('/api/ai-image/generate'),
        ]);
        const name = me.member.nickname || me.member.username || '设计师';
        qs('#accountName').textContent = name;
        qs('#accountLevel').textContent = me.isVip ? 'VIP 会员' : '普通会员';
        qs('#accountAvatar').textContent = name.slice(0, 2).toUpperCase();
        if (downloads.status === 'fulfilled') {
          state.downloads = downloads.value.rows || [];
          qs('#todayDownloads').textContent = downloads.value.todayCount || 0;
          qs('#downloadCount').textContent = state.downloads.length;
          const daily = qs('.account-metrics small'); if (daily) daily.textContent = `/ ${downloads.value.dailyLimit || 30}`;
        } else empty(document.getElementById('downloadRows'), 3, '下载记录读取失败，请稍后重试。');
        if (credits.status === 'fulfilled') { state.credits = credits.value.ledger || []; qs('#creditBalance').textContent = credits.value.balance || 0; }
        else empty(document.getElementById('creditRows'), 5, '积分功能尚未初始化或暂时不可用。');
        if (generations.status === 'fulfilled') { state.generations = generations.value.tasks || []; qs('#generationCount').textContent = state.generations.length; }
        else empty(document.getElementById('generationRows'), 6, '生图记录暂时不可用。');
        renderDownloads(); renderCredits(); renderGenerations();
      } catch (error) {
        if (/登录/.test(error?.message || '')) location.href = '/member/login?next=/member';
      } finally { refresh?.classList.remove('loading'); }
    }
    document.querySelectorAll('[data-tab]').forEach((button) => button.addEventListener('click', () => {
      const tab = button.dataset.tab;
      document.querySelectorAll('[data-tab]').forEach((node) => node.classList.toggle('active', node === button));
      document.querySelectorAll('[data-panel]').forEach((panel) => { const active = panel.dataset.panel === tab; panel.hidden = !active; panel.classList.toggle('active', active); });
      qs('#recordTitle').textContent = descriptions[tab][0]; qs('#recordDescription').textContent = descriptions[tab][1];
    }));
    document.getElementById('refreshRecords')?.addEventListener('click', loadAll);
    loadAll();
  </script>
</Base>
