---
import Base from '../../layouts/Base.astro';
---
<Base title="会员登录 — 薛大大设计网">
  <section class="auth-page">
    <form class="auth-card" id="loginForm">
      <p class="section-label">MEMBER</p>
      <h1>会员登录</h1>
      <input name="username" placeholder="用户名 / 邮箱" autocomplete="username" required />
      <input name="password" type="password" placeholder="密码" autocomplete="current-password" required />
      <p class="auth-error" id="err"></p>
      <button class="btn-primary" type="submit">登录</button>
      <a href="/member/register">还没有账号？去注册</a>
    </form>
  </section>
  <script>
    document.getElementById('loginForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.currentTarget as HTMLFormElement;
      const err = document.getElementById('err');
      const data = Object.fromEntries(new FormData(form).entries());
      const res = await fetch('/api/member/login', { method: 'POST', headers: { 'content-type': 'application/json' }, credentials: 'include', body: JSON.stringify(data) });
      const json = await res.json();
      if (!res.ok || !json.ok) { if (err) err.textContent = json.message || '登录失败'; return; }
      location.href = '/member';
    });
  </script>
</Base>
