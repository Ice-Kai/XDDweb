---
import Base from '../layouts/Base.astro';
import { getDownloads, coverUrl, type DownloadItem } from '../lib/content';

const q = (Astro.url.searchParams.get('q') || '').trim();
const sort = (Astro.url.searchParams.get('sort') as 'newest' | 'popular' | 'downloads') || 'newest';
const items = q ? await getDownloads({ q, sort, limit: 40 }) : [];
function priceLabel(_it: DownloadItem) { return '免费'; }
const sorts: { k: string; t: string }[] = [{ k: 'newest', t: '最新' }, { k: 'popular', t: '最热' }, { k: 'downloads', t: '下载' }];
---
<Base title={q ? `搜索：${q} - 薛大大生态设计` : '搜索 - 薛大大生态设计'}>
  <div class="container">
    <div style="padding:28px 0 8px;">
      <form action="/search" method="get" style="margin-bottom:8px;">
        <div style="display:flex;flex:1;min-width:220px;align-items:center;gap:8px;height:46px;padding:0 18px;border:1px solid var(--border);border-radius:999px;background:var(--bg-card);">
          <input name="q" value={q} placeholder="搜索模型、贴图、软件、教程..." autofocus style="flex:1;background:none;border:none;outline:none;color:var(--text-hi);font-size:15px;" />
          <button type="submit" class="btn-primary" style="height:34px;padding:0 22px;">搜索</button>
        </div>
      </form>
    </div>

    {q ? (
      <div style="padding-bottom:50px;">
        <div class="section-head" style="margin:14px 0 18px;">
          <div><p class="section-label">SEARCH</p><h2 class="section-title">“{q}” 的搜索结果（{items.length}{items.length === 40 ? '+' : ''}）</h2></div>
          <div class="sort-group">
            {sorts.map((s) => (<a href={`/search?q=${encodeURIComponent(q)}${s.k !== 'newest' ? `&sort=${s.k}` : ''}`} class={`sort-btn ${sort === s.k ? 'active' : ''}`}>{s.t}</a>))}
          </div>
        </div>
        {items.length === 0 ? (
          <div class="mpage-empty">没有找到与“{q}”相关的资源，换个关键词试试。</div>
        ) : (
          <div class="grid-5">
            {items.map((m) => (
              <a href="#" data-card-id={m.id} class="card reveal visible">
                <div class="card-img-wrap">
                  {coverUrl(m.cover) ? <img src={coverUrl(m.cover)} alt={m.title} loading="lazy" /> : null}
                  <span class="card-cat cat-arch">{priceLabel(m)}</span>
                </div>
                <div class="card-body">
                  <h3 class="card-title">{m.title}</h3>
                  <p class="card-desc">{m.summary || '暂无简介'}</p>
                  <div class="card-footer download-footer">
                    <span class="card-size">{m.size || '-- MB'}</span>
                    <span class="card-foot-r"><span class="card-type">{m.fileType || '资源'}</span><span class="btn-dl" data-dl data-download-id={m.id} role="button" tabindex="0">下载</span></span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    ) : (
      <div class="mpage-empty" style="padding:80px 0;">输入关键词开始搜索全站资源。</div>
    )}
  </div>
</Base>
