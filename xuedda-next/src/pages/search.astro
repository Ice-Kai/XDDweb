---
import Base from '../layouts/Base.astro';
import { getDownloads, coverUrl, type DownloadItem } from '../lib/content';

const q = (Astro.url.searchParams.get('q') || '').trim();
const sort = (Astro.url.searchParams.get('sort') as 'newest' | 'popular' | 'downloads') || 'newest';
const items = q ? await getDownloads({ q, sort, limit: 40 }) : [];
const hotTerms = ['现代别墅', '原木贴图', 'D5 教程', 'HDR 天空', '商业综合体'];
const historyTerms = ['客厅模型', '大理石', '茶室空间'];
const suggestTerms = ['现代极简别墅', '新中式庭院', 'PBR 木纹', 'Enscape 参数', 'SketchUp 插件'];
function priceLabel(_it: DownloadItem) { return '免费'; }
const sorts: { k: 'newest' | 'popular' | 'downloads'; t: string }[] = [
  { k: 'newest', t: '最新' },
  { k: 'popular', t: '最热' },
  { k: 'downloads', t: '下载' },
];
---
<Base title={q ? `搜索：${q} - 薛大大设计网` : '搜索 - 薛大大设计网'}>
  <section class="m-search-page">
    <form class="m-search-top" action="/search" method="get">
      <label class="m-search-input">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <input name="q" value={q} placeholder="搜索模型 / 贴图 / 教程" autofocus />
      </label>
      <a href="/" class="m-search-cancel">取消</a>
    </form>

    {!q ? (
      <>
        <div class="m-search-block">
          <div class="m-search-title"><strong>历史搜索</strong><a href="/">清除</a></div>
          <div class="m-chip-flow">{historyTerms.map((term) => <a href={`/search?q=${encodeURIComponent(term)}`}>{term}</a>)}</div>
        </div>
        <div class="m-search-block">
          <div class="m-search-title hot"><strong>热门搜索</strong></div>
          <div class="m-hot-list">
            {hotTerms.map((term, index) => (
              <a href={`/search?q=${encodeURIComponent(term)}`} class="m-hot-row">
                <span>{index + 1}</span>
                <strong>{term}</strong>
                {index < 2 ? <em>HOT</em> : null}
              </a>
            ))}
          </div>
        </div>
        <div class="m-search-block">
          <div class="m-search-title"><strong>大家都在搜</strong></div>
          <div class="m-chip-flow soft">{suggestTerms.map((term) => <a href={`/search?q=${encodeURIComponent(term)}`}>{term}</a>)}</div>
        </div>
      </>
    ) : (
      <div class="m-search-results">
        <div class="m-list-control">
          <span>找到 {items.length}{items.length === 40 ? '+' : ''} 个结果</span>
          <div>{sorts.map((s) => <a href={`/search?q=${encodeURIComponent(q)}${s.k !== 'newest' ? `&sort=${s.k}` : ''}`} class={sort === s.k ? 'active' : ''}>{s.t}</a>)}</div>
        </div>
        {items.length === 0 ? (
          <div class="m-empty">没有找到相关资源，换个关键词试试。</div>
        ) : (
          <div class="m-card-grid">
            {items.map((m) => (
              <a href={`/d/${m.id}`} class="m-asset-card">
                <span class="m-cover">
                  {coverUrl(m.cover) ? <img src={coverUrl(m.cover)} alt={m.title} loading="lazy" /> : <i>{m.fileType || 'PREVIEW'}</i>}
                  <b>{priceLabel(m)}</b>
                </span>
                <strong>{m.title}</strong>
                <span class="m-asset-meta">{m.size || '-- MB'} · {m.fileType || '资源'}</span>
              </a>
            ))}
          </div>
        )}
      </div>
    )}
  </section>

  <div class="container desktop-page">
    <div style="padding:28px 0 8px;">
      <form action="/search" method="get" style="margin-bottom:8px;">
        <div style="display:flex;flex:1;min-width:220px;align-items:center;gap:8px;height:46px;padding:0 18px;border:1px solid var(--border);border-radius:999px;background:var(--bg-card);">
          <input name="q" value={q} placeholder="搜索模型、贴图、软件、教程..." autofocus style="flex:1;background:none;border:none;outline:none;color:var(--text-hi);font-size:15px;" />
          <button type="submit" class="btn-primary" style="height:34px;padding:0 22px;">搜索</button>
        </div>
      </form>
    </div>

    {q ? (
      <div style="padding-bottom:50px;">
        <div class="section-head" style="margin:14px 0 18px;">
          <div><p class="section-label">SEARCH</p><h2 class="section-title">“{q}” 的搜索结果（{items.length}{items.length === 40 ? '+' : ''}）</h2></div>
          <div class="sort-group">
            {sorts.map((s) => (<a href={`/search?q=${encodeURIComponent(q)}${s.k !== 'newest' ? `&sort=${s.k}` : ''}`} class={`sort-btn ${sort === s.k ? 'active' : ''}`}>{s.t}</a>))}
          </div>
        </div>
        {items.length === 0 ? (
          <div class="mpage-empty">没有找到与“{q}”相关的资源，换个关键词试试。</div>
        ) : (
          <div class="grid-5">
            {items.map((m) => (
              <article data-card-id={m.id} class="card reveal visible">
                <button class="card-img-wrap" type="button" data-preview-src={coverUrl(m.cover)} data-preview-title={m.title} aria-label={`预览 ${m.title}`}>
                  {coverUrl(m.cover) ? <img src={coverUrl(m.cover)} alt={m.title} loading="lazy" /> : null}
                  <span class="card-cat cat-arch">{priceLabel(m)}</span>
                </button>
                <div class="card-body">
                  <h3 class="card-title">{m.title}</h3>
                  <p class="card-desc">{m.summary || '暂无简介'}</p>
                  <div class="card-footer download-footer">
                    <span class="card-size">{m.size || '-- MB'}</span>
                    <span class="card-foot-r"><span class="card-type">{m.fileType || '资源'}</span><span class="btn-dl" data-dl data-download-id={m.id} role="button" tabindex="0">下载</span></span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        )}
      </div>
    ) : (
      <div class="mpage-empty" style="padding:80px 0;">输入关键词开始搜索全站资源。</div>
    )}
  </div>
</Base>
