---
import Base from '../../layouts/Base.astro';
import { getCategoryTree, getDownloads, countDownloads, getDescendantIds, coverUrl, MODEL_GROUPS, modelGroupByKey, type CatNode, type DownloadItem } from '../../lib/content';

const sp = Astro.url.searchParams;
const rawType = (sp.get('type') || 'su').toLowerCase();
if (rawType === 'text') {
  const next = new URLSearchParams(Astro.url.searchParams);
  next.delete('type');
  next.set('format', 'text');
  return Astro.redirect(`/c/texture?${next.toString()}`);
}
const type = (rawType === 'max' ? 'max' : 'su') as 'su' | 'max';
const group = sp.get('group') || '';
const category = Number(sp.get('category')) || 0;
const sort = (sp.get('sort') as 'newest' | 'popular' | 'downloads') || 'newest';
const q = sp.get('q') || '';
const page = Math.max(1, Number(sp.get('page')) || 1);
const PER = 30;

// 叶子分类 id→name
const tree = await getCategoryTree(107);
const nameMap = new Map<number, string>();
(function walk(ns: CatNode[]) { for (const n of ns) { nameMap.set(n.id, n.name); walk(n.children); } })(tree);
const groupedFilters = MODEL_GROUPS.map((g) => ({
  ...g,
  children: g.ids.map((id) => ({ id, name: nameMap.get(id) || `栏目 ${id}` })).filter((item) => item.name),
}));

// 先确定过滤条件，再分页查询 + 计总数
let filter: { categoryIds?: number[]; categoryId?: number; rootCategoryId?: number; assetKind?: string; modelFormat?: string; includeUnformatted?: boolean; excludeModelFormat?: string } | null = null;
let items: DownloadItem[] = [];
let total = 0;
let activeLabel = '全部模型';
if (type === 'max') {
  if (group) {
    const g = modelGroupByKey(group);
    if (g) {
      const ids = (await Promise.all(g.ids.map(getDescendantIds))).flat();
      filter = { categoryIds: ids, assetKind: 'model', modelFormat: 'MAX' };
      activeLabel = g.name;
    }
  } else if (category) {
    filter = { categoryId: category, assetKind: 'model', modelFormat: 'MAX' };
    activeLabel = nameMap.get(category) || '分类';
  } else {
    filter = { assetKind: 'model', modelFormat: 'MAX' };
    activeLabel = '全部 MAX';
  }
} else if (type === 'su') {
  if (group) {
    const g = modelGroupByKey(group);
    if (g) { const ids = (await Promise.all(g.ids.map(getDescendantIds))).flat(); filter = { categoryIds: ids, modelFormat: 'SU', includeUnformatted: true }; activeLabel = g.name; }
  } else if (category) {
    filter = { categoryId: category, modelFormat: 'SU', includeUnformatted: true }; activeLabel = nameMap.get(category) || '分类';
  } else {
    filter = { rootCategoryId: 107, modelFormat: 'SU', includeUnformatted: true };
  }
}
if (filter) {
  const opts = { ...filter, q, sort };
  [items, total] = await Promise.all([
    getDownloads({ ...opts, limit: PER, offset: (page - 1) * PER }),
    countDownloads(opts),
  ]);
}
const totalPages = Math.max(1, Math.ceil(total / PER));

const qs = (over: Record<string, string | number | undefined>) => {
  const u = new URLSearchParams();
  const t = over.type ?? type;
  if (t && t !== 'su') u.set('type', String(t));
  const g = 'group' in over ? over.group : group;
  const c = 'category' in over ? over.category : category;
  if (g) u.set('group', String(g));
  else if (c) u.set('category', String(c));
  const s = over.sort ?? sort;
  if (s && s !== 'newest') u.set('sort', String(s));
  const query = over.q ?? (q || undefined);
  if (query) u.set('q', String(query));
  const pg = 'page' in over ? over.page : undefined; // 切筛选默认回第1页；翻页时显式传 page
  if (pg && Number(pg) > 1) u.set('page', String(pg));
  const str = u.toString();
  return '/c/model' + (str ? `?${str}` : '');
};
function priceLabel(_it: DownloadItem) { return '免费'; }
const sorts: { k: 'newest' | 'popular' | 'downloads'; t: string }[] = [{ k: 'newest', t: '最新' }, { k: 'popular', t: '最热' }, { k: 'downloads', t: '下载' }];
---
<Base title="模型 — 薛大大设计网">
  <section class="m-list">
    <header class="m-page-head center">
      <a class="m-icon-btn" href="/" aria-label="返回首页">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </a>
      <strong>模型素材</strong>
      <a class="m-icon-btn" href="/search" aria-label="搜索">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      </a>
    </header>

    <nav class="m-tabs">
      <a href={qs({ type: 'su', group: '', category: '' })} class={type === 'su' ? 'active' : ''}>SU模型</a>
      <a href={qs({ type: 'max', group: '', category: '' })} class={type === 'max' ? 'active' : ''}>MAX模型</a>
    </nav>

    <nav class="m-chip-tabs">
      <a href={qs({ group: '', category: '' })} class={!group && !category ? 'active' : ''}>全部</a>
      {groupedFilters.map((top) => <a href={qs({ group: top.key, category: '' })} class={group === top.key ? 'active' : ''}>{top.name}</a>)}
    </nav>

    <details class="m-filter-panel" aria-label="完整模型分类">
      <summary class="m-filter-trigger">
        <span><b>分类</b><em>{activeLabel}</em></span>
        <i></i>
      </summary>
      <div class="m-order-filter">
        <nav class="m-order-left">
          <a href={qs({ group: '', category: '' })} class={!group && !category ? 'active' : ''}>{type === 'max' ? '全部 MAX' : '全部模型'}</a>
          {groupedFilters.map((top) => {
            const isActive = group === top.key || top.children.some((child) => child.id === category);
            return <a href={qs({ group: top.key, category: '' })} class={isActive ? 'active' : ''}>{top.name}<small>{top.children.length}</small></a>;
          })}
        </nav>
        <div class="m-order-right">
          {groupedFilters.map((top) => {
            const isActive = group === top.key || top.children.some((child) => child.id === category);
            if (!isActive) return null;
            return (
              <div class="m-order-group">
                {category ? <span class="m-order-current">当前：{activeLabel}</span> : null}
                <a href={qs({ group: top.key, category: '' })} class={`m-order-all ${group === top.key ? 'active' : ''}`}>全部{top.name}</a>
                <div class="m-order-grid">
                  {top.children.map((child) => (
                    <a href={qs({ category: child.id, group: '' })} class={category === child.id ? 'active' : ''}>{child.name}</a>
                  ))}
                </div>
              </div>
            );
          })}
          {!group && !category ? (
            <div class="m-order-hint">选择左侧大类后查看下级栏目</div>
          ) : null}
        </div>
      </div>
    </details>

    <div class="m-list-control">
      <span>共 {total} 个模型</span>
      <div>
        {sorts.map((s) => <a href={qs({ sort: s.k })} class={sort === s.k ? 'active' : ''}>{s.t}</a>)}
      </div>
    </div>

    {items.length === 0 ? (
      <div class="m-empty">该分类暂无资源{q ? `（搜索：${q}）` : ''}</div>
    ) : (
      <div class="m-card-grid">
        {items.map((m) => (
          <a href={`/d/${m.id}`} class="m-asset-card">
            <span class="m-cover">
              {coverUrl(m.cover) ? <img src={coverUrl(m.cover)} alt={m.title} loading="lazy" /> : <i>MODEL</i>}
              <b>{priceLabel(m)}</b>
            </span>
            <strong>{m.title}</strong>
            <span class="m-asset-meta">{m.size || '-- MB'} · {m.fileType || (type === 'max' ? 'MAX 模型' : 'SKP 模型')}</span>
          </a>
        ))}
      </div>
    )}
  </section>

  <div class="container desktop-page">
    <div class="mpage-bc" style="padding-top:18px;">
      <a href="/">首页</a> <span>/</span> <b>模型{type === 'max' ? ' · MAX' : (group || category ? ` · ${activeLabel}` : '')}</b>
    </div>

    <!-- 类型分区 -->
    <div class="mtabs">
      <a href={qs({ type: 'su', group: '', category: '' })} class={`mtab ${type === 'su' ? 'active' : ''}`}>SU模型</a>
      <a href={qs({ type: 'max', group: '', category: '' })} class={`mtab ${type === 'max' ? 'active' : ''}`}>MAX模型</a>
    </div>

    <div class="mpage">
        <aside class="filter-side">
          <div class="filter-card">
            <div class="filter-head">
              <span class="fi"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 7v10l9 4 9-4V7"/></svg></span>
              <div><strong>{type === 'max' ? 'MAX 分类' : '模型分类'}</strong><span>建筑 / 景观 / 室内</span></div>
            </div>
            <nav class="filter-nav">
              <a href={qs({ group: '', category: '' })} class={`filter-link ${!group && !category ? 'active' : ''}`}>{type === 'max' ? '全部 MAX' : '全部模型'}</a>
              {groupedFilters.map((top) => (
                <div class="filter-det">
                  <a href={qs({ group: top.key, category: '' })} class={`filter-link filter-group-link ${group === top.key ? 'active' : ''}`}>{top.name}<span class="filter-count">{top.children.length}</span></a>
                  {top.children.map((c) => (
                    <a href={qs({ category: c.id, group: '' })} class={`filter-link sub ${category === c.id ? 'active' : ''}`}>{c.name}</a>
                  ))}
                </div>
              ))}
            </nav>
          </div>
        </aside>
        <div class="mpage-main">
          <div class="toolbar">
            <form action="/c/model" method="get">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--text-lo)"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
              <input name="q" value={q} placeholder="搜索模型…" />
              {type !== 'su' ? <input type="hidden" name="type" value={type} /> : null}
              {group ? <input type="hidden" name="group" value={group} /> : null}
              {category ? <input type="hidden" name="category" value={category} /> : null}
            </form>
            <div class="sort-group">
              {sorts.map((s) => (<a href={qs({ sort: s.k })} class={`sort-btn ${sort === s.k ? 'active' : ''}`}>{s.t}</a>))}
            </div>
          </div>

          {items.length === 0 ? (
            <div class="mpage-empty">{type === 'max' ? `暂无 MAX 模型素材${q ? `（搜索：${q}）` : ''}，上传后会自动显示。` : `该分类暂无资源${q ? `（搜索：${q}）` : ''}`}</div>
          ) : (
            <div class="grid-5">
              {items.map((m) => (
                <article data-card-id={m.id} class="card reveal visible">
                  <button class="card-img-wrap" type="button" data-preview-src={coverUrl(m.cover)} data-preview-title={m.title} aria-label={`预览 ${m.title}`}>
                    {coverUrl(m.cover) ? <img src={coverUrl(m.cover)} alt={m.title} loading="lazy" /> : null}
                    <span class={`card-cat ${type === 'max' ? 'cat-inter' : 'cat-arch'}`}>{priceLabel(m)}</span>
                  </button>
                  <div class="card-body">
                    <h3 class="card-title">{m.title}</h3>
                    <p class="card-desc">{m.summary || '暂无简介'}</p>
                    <div class="card-footer download-footer">
                      <span class="card-size">{m.size || '-- MB'}</span>
                      <span class="card-foot-r"><span class="card-type">{m.fileType || (type === 'max' ? 'MAX 模型' : 'SKP 模型')}</span><span class="btn-dl" data-dl data-download-id={m.id} role="button" tabindex="0">下载</span></span>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          )}

          {totalPages > 1 && (
            <nav class="pager">
              <span class="pager-info">共 {total} 条 · 第 {page}/{totalPages} 页</span>
              <div class="pager-btns">
                {page > 1 ? <a href={qs({ page: page - 1 })} class="pager-btn">← 上一页</a> : <span class="pager-btn disabled">← 上一页</span>}
                {Array.from({ length: totalPages }, (_, i) => i + 1)
                  .filter((n) => n === 1 || n === totalPages || Math.abs(n - page) <= 2)
                  .map((n, idx, arr) => (
                    <>
                      {idx > 0 && n - arr[idx - 1] > 1 ? <span class="pager-gap">…</span> : null}
                      <a href={qs({ page: n })} class={`pager-btn ${n === page ? 'active' : ''}`}>{n}</a>
                    </>
                  ))}
                {page < totalPages ? <a href={qs({ page: page + 1 })} class="pager-btn">下一页 →</a> : <span class="pager-btn disabled">下一页 →</span>}
              </div>
            </nav>
          )}
        </div>
      </div>
  </div>

  <style>
    .pager { display:flex; flex-direction:column; align-items:center; gap:12px; padding:36px 0 10px; }
    .pager-info { font-size:13px; color:var(--text-lo); }
    .pager-btns { display:flex; flex-wrap:wrap; gap:6px; justify-content:center; }
    .pager-btn { min-width:38px; text-align:center; padding:8px 13px; border:1px solid var(--border); border-radius:var(--radius-sm); font-size:13px; color:var(--text-md); background:var(--bg-card); transition:all .15s; }
    .pager-btn:hover { border-color:var(--gold); color:var(--gold); }
    .pager-btn.active { background:var(--gold); color:#0d0900; border-color:var(--gold); font-weight:700; }
    .pager-btn.disabled { opacity:.4; pointer-events:none; }
    .pager-gap { padding:8px 4px; color:var(--text-lo); }
    .mpage-main.is-loading { opacity:.5; pointer-events:none; transition:opacity .15s; }
  </style>

  <script>
    // Partial navigation: clicking a filter / sort / pager link swaps only the
    // results column (.mpage-main) and updates the sidebar's active state in
    // place — so the filter sidebar never reloads and its scroll position +
    // the page scroll are preserved. Card/download handlers are delegated on
    // document (Base.astro), so swapping innerHTML keeps them working.
    (() => {
      const root = document.querySelector('.mpage');
      if (!root) return;
      let busy = false;

      async function go(url, push) {
        if (busy) return;
        busy = true;
        const main = document.querySelector('.mpage-main');
        main && main.classList.add('is-loading');
        try {
          const res = await fetch(url, { headers: { 'X-Requested-With': 'partial' } });
          const html = await res.text();
          const doc = new DOMParser().parseFromString(html, 'text/html');
          const newMain = doc.querySelector('.mpage-main');
          const curMain = document.querySelector('.mpage-main');
          if (newMain && curMain) curMain.innerHTML = newMain.innerHTML;

          // Transfer active classes onto the EXISTING sidebar links (don't
          // replace the sidebar element — that would reset its scroll).
          const oldLinks = document.querySelectorAll('.filter-nav .filter-link');
          const newLinks = doc.querySelectorAll('.filter-nav .filter-link');
          oldLinks.forEach((a, i) => { if (newLinks[i]) a.className = newLinks[i].className; });

          // Keep breadcrumb + active sort in sync.
          const bc = document.querySelector('.mpage-bc');
          const newBc = doc.querySelector('.mpage-bc');
          if (bc && newBc) bc.innerHTML = newBc.innerHTML;

          if (push) history.pushState({}, '', url);
        } catch {
          location.href = url;
          return;
        } finally {
          const m = document.querySelector('.mpage-main');
          m && m.classList.remove('is-loading');
          busy = false;
        }
      }

      document.addEventListener('click', (e) => {
        const a = e.target.closest('.filter-nav a.filter-link, .mpage-main .sort-btn, .mpage-main .pager-btn');
        if (!a || a.classList.contains('disabled')) return;
        const href = a.getAttribute('href') || '';
        if (!href.startsWith('/c/model')) return;
        e.preventDefault();
        go(href, true);
      });

      window.addEventListener('popstate', () => go(location.pathname + location.search, false));
    })();
  </script>
</Base>
