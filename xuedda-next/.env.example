# 复制为 .env 后填写。本地可使用 Docker MySQL；生产环境改成阿里云数据库或服务器内网 MySQL。
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=xuedda_dev_pwd
DB_NAME=xuedda

# 如果旧 PHP 数据库和新站数据库拆库，可填写库名；同库时留空。
LEGACY_DB_NAME=
APP_DB_NAME=

# 会话密钥：生产环境必须改成 32 位以上随机字符串，不要使用示例值。
SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# 生产环境默认关闭公开注册。确实需要开放时再改成 true。
PUBLIC_REGISTRATION_ENABLED=false

# 前后端分离或多域名部署时填写允许调用接口的前端 Origin，多个用英文逗号分隔。
ALLOWED_ORIGINS=

# 站点外部访问地址。QQ/微信回调会使用它生成 callback URL。
PUBLIC_SITE_URL=https://xuedda.com
SITE_URL=https://xuedda.com

# QQ 登录。申请后在 QQ 互联后台配置回调：
# https://xuedda.com/api/member/oauth/qq/callback
QQ_APP_ID=
QQ_APP_KEY=
# 如果 QQ 后台仍使用旧 PHP 回调地址，可填完整地址，例如：
# https://www.xuedda.com/index/member/other_login.html
QQ_CALLBACK_URL=

# 微信扫码登录。申请后在微信开放平台配置授权回调域：
# xuedda.com
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# 如微信后台要求固定完整回调地址，可填完整地址；通常只配置授权回调域即可。
WECHAT_CALLBACK_URL=

# 阿里云 OSS（后台上传直传）
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PUBLIC_BASE=

# 微信支付（商业化后再启用）
WX_APP_ID=
WX_MCH_ID=
WX_API_KEY=
WX_NOTIFY_URL=https://www.xuedda.com/api/pay/notify

# 并行运行旧站地址。当前新站直接接管时留空。
OLD_SITE_URL=

# 独立 AI 生图站入口。暂未开放时可留空，前台会置灰。
AI_IMAGE_URL=

# 首页封面登录门槛。默认关闭，游客可浏览；需要恢复封面页时改成 true。
INTRO_GATE_ENABLED=false
AI_IMAGE_ENABLED=false
WXPAY_APP_ID=
WXPAY_MCH_ID=
WXPAY_API_KEY=
WXPAY_NOTIFY_URL=https://www.xuedda.com/api/payment/wechat/notify
AI_IMAGE_ALLOW_UNSTABLE_MODELS=false
IMAGE_PROXY_BASE_URL=https://zexapi.com/v1
IMAGE_PROXY_MODEL=image2
# IMAGE_PROXY_API_KEY=server-only-secret
# 多密钥时可用换行、逗号或分号分隔；后端会轮询并在 401/403/429/5xx 时自动切换。
# IMAGE_PROXY_API_KEYS=sk-key-1
# sk-key-2
# 新图像接口接入后再配置以下变量；未开启时生图 API 不会调用任何旧代理。
