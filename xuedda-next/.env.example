# 复制为 .env 并填写。本地用 Docker MySQL (重启后由 docker compose 启动)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=xuedda_dev_pwd
DB_NAME=xuedda

# 会话密钥
SESSION_SECRET=change_me_to_a_long_random_string

# 阿里云 OSS (后台上传直传) — 阶段4 填写
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PUBLIC_BASE=

# 微信支付 — 阶段3 填写
WX_APP_ID=
WX_MCH_ID=
WX_API_KEY=
WX_NOTIFY_URL=https://www.xuedda.com/api/pay/notify

# 并行运行期：旧站地址。设了就在新站顶栏显示「旧版 ↗」切换入口；留空则不显示
OLD_SITE_URL=
