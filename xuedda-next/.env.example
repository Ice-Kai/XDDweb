# 复制为 .env 后填写。本地可使用 Docker MySQL；生产环境请改成阿里云数据库。
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=xuedda_dev_pwd
DB_NAME=xuedda

# 会话密钥：生产环境必须填写 32 位以上随机字符串，不要使用示例值。
SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# 生产环境默认关闭公开注册。确实需要开放时再改成 true。
PUBLIC_REGISTRATION_ENABLED=false

# 前后端分离或多域部署时填写允许调用后台接口的前端 Origin，多个用英文逗号分隔。
ALLOWED_ORIGINS=

# 阿里云 OSS（后台上传直传）
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PUBLIC_BASE=

# 微信支付
WX_APP_ID=
WX_MCH_ID=
WX_API_KEY=
WX_NOTIFY_URL=https://www.xuedda.com/api/pay/notify

# 并行运行旧站地址。设置后会在新站顶部显示“旧版”入口；留空则不显示。
OLD_SITE_URL=

# 独立 AI 生图站入口。本地可填 http://127.0.0.1:3000/ai-image；生产建议 https://ai.xuedda.com/ai-image
AI_IMAGE_URL=
